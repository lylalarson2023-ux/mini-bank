@* Champ mot de passe réutilisable avec bouton « œil » afficher/masquer.
   Usage : <PasswordInput @bind-Value="mdp" Placeholder="••••••••" />
   La valeur remonte à chaque frappe (oninput) pour garder les validations
   en direct (jauge de robustesse, correspondance de confirmation…) réactives. *@

<div style="position: relative;">
    <input type="@(_show ? "text" : "password")"
           class="@CssClass"
           style="@($"padding-right: 42px;{ExtraStyle}")"
           placeholder="@Placeholder"
           disabled="@Disabled"
           autocomplete="@Autocomplete"
           value="@Value"
           @oninput="OnInput" />
    <button type="button"
            tabindex="-1"
            title="@(_show ? "Masquer le mot de passe" : "Afficher le mot de passe")"
            aria-label="@(_show ? "Masquer le mot de passe" : "Afficher le mot de passe")"
            @onclick="Toggle"
            style="position: absolute; top: 50%; right: 6px; transform: translateY(-50%);
                   background: none; border: none; cursor: pointer; color: var(--text-muted);
                   padding: 6px; display: flex; align-items: center; line-height: 0;">
        <i class="bi @(_show ? "bi-eye-slash" : "bi-eye")"></i>
    </button>
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    // Classe CSS de l'input (par défaut celle du thème). ExtraStyle : style inline
    // additionnel éventuel (le padding-droit pour l'œil est toujours appliqué).
    [Parameter] public string CssClass { get; set; } = "form-input";
    [Parameter] public string? ExtraStyle { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string Autocomplete { get; set; } = "current-password";

    private bool _show;
    private void Toggle() => _show = !_show;

    private async Task OnInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString() ?? "";
        await ValueChanged.InvokeAsync(Value);
    }
}
