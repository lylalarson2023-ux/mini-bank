<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    @* Image de marque au partage (WhatsApp, LinkedIn…) — URLs absolues de prod. *@
    <meta name="description" content="ADN_pay — la néobanque mobile des étudiants : compte, épargne, dépôts et transferts, en ligne sur adnpay.net." />
    <meta name="theme-color" content="#0099CC" />
    <meta property="og:title" content="ADN_pay — La néobanque mobile des étudiants" />
    <meta property="og:description" content="Compte, épargne, dépôts et transferts. La néobanque 100 % digitale, en ligne sur adnpay.net." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://adnpay.net/" />
    <meta property="og:image" content="https://adnpay.net/images/og-adnpay.png" />
    <meta property="og:site_name" content="ADN_pay" />
    <meta property="og:locale" content="fr_FR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="ADN_pay — La néobanque mobile des étudiants" />
    <meta name="twitter:description" content="Compte, épargne, dépôts et transferts. En ligne sur adnpay.net." />
    <meta name="twitter:image" content="https://adnpay.net/images/og-adnpay.png" />
    <ResourcePreloader />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sora:wght@500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["css/theme.css"]?v=@(ADN_pay.Services.BuildInfo.CacheTag)" />
    <link rel="stylesheet" href="@Assets["app.css"]?v=@(ADN_pay.Services.BuildInfo.CacheTag)" />
    <link rel="stylesheet" href="@Assets["ADN_pay.styles.css"]?v=@(ADN_pay.Services.BuildInfo.CacheTag)" />
    <ImportMap />
    <link rel="icon" type="image/png" href="images/adn-pay-logo.png" />
    <script>!function(){var e=localStorage.getItem('adn_theme')||'dark';document.documentElement.setAttribute('data-theme',e)}();</script>
    <HeadOutlet @rendermode="InteractiveServer" />
</head>
<body>
    <CascadingAuthenticationState>
        <Routes @rendermode="InteractiveServer" />
    </CascadingAuthenticationState>
    @* Overlay piloté par Blazor via les classes components-reconnect-show / -failed
       / -rejected (cf. theme.css). Les états sont gérés en CSS, pas en JS. *@
    <div id="components-reconnect-modal">
        <div class="reconnect-content">
            <div class="reconnect-spinner"></div>
            <p class="reconnect-retrying">Reconnexion en cours...</p>
            <p class="reconnect-lost">Connexion perdue. <a href="" onclick="location.reload();return false;">Actualiser</a></p>
        </div>
    </div>
    <script src="_framework/blazor.web.js" autostart="false"></script>
    <script>
        Blazor.start({
            circuit: {
                reconnectionOptions: {
                    maxRetries: 12,
                    retryIntervalMilliseconds: function (previousAttempts) {
                        if (previousAttempts >= 12) return null;
                        return Math.min(500 * Math.pow(1.8, previousAttempts), 20000);
                    }
                }
            }
        });
    </script>
    <script src="js/theme.js"></script>
    <script src="js/upload.js"></script>
</body>
</html>
