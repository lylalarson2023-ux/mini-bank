@page "/courant"
@attribute [Authorize]
@inject BankService Bank
@inject NotificationService Notif

<div class="cyber-panel">
    <h3>GESTION COMPTE COURANT</h3>

    <div class="warning-box">
        DISPONIBLE : <span class="highlight">@((Bank.Profil.Solde / 100m).ToString("N2")) DH</span>
    </div>

    <div style="margin-top: 24px;">
        <div class="form-group">
            <label>MONTANT (DH)</label>
            <input type="number" @bind="montantSaisie" class="form-input" placeholder="0.00" />
        </div>

        <div class="form-row">
            @if (Bank.Profil.IsAdmin)
            {
                <button class="btn btn-success btn-block" @onclick='() => Valider("DEPOT")' disabled="@isProcessing">
                    <i class="bi bi-plus-circle"></i> Deposer
                </button>
            }
            else
            {
                <div class="empty-state" style="padding: 16px; font-size: 0.7rem;">
                    <p>DEPOT RESERVE A L'ADMINISTRATEUR</p>
                </div>
            }
            <button class="btn btn-primary btn-block" @onclick='() => Valider("RETRAIT")' disabled="@isProcessing">
                <i class="bi bi-dash-circle"></i> Retirer
            </button>
        </div>
    </div>

    <div style="margin-top: 32px;">
        <h5 class="section-title">HISTORIQUE RECENT</h5>
        @foreach (var tr in historique.Take(5))
        {
            <div class="transaction-item">
                <div class="transaction-info">
                    <div class="tx-type">@tr.Type</div>
                    <div class="tx-date">@tr.Date.ToString("dd/MM HH:mm")</div>
                </div>
                <div class="transaction-amount @(tr.IsEntree ? "tx-positive" : "tx-negative")">
                    @(tr.IsEntree ? "+" : "-") @((tr.Montant / 100m).ToString("N2"))
                </div>
            </div>
        }
    </div>

    <div style="margin-top: 24px; text-align: center;">
        <a href="/" style="color: var(--text-muted); font-size: 0.8rem; font-weight: 600;">&larr; RETOUR DASHBOARD</a>
    </div>
</div>

@code {
    private decimal? montantSaisie;
    private List<Transaction> historique = new();
    private bool isProcessing;

    protected override async Task OnInitializedAsync()
    {
        historique = await Bank.GetHistoriqueAsync();
    }

    private async Task Valider(string type)
    {
        if (isProcessing || montantSaisie is null or <= 0) return;
        isProcessing = true;
        try
        {
            var success = await Bank.ExecuterOperationAsync((long)(montantSaisie.Value * 100), "", type);
            if (success)
            {
                Notif.Success($"{type} EFFECTUE");
                montantSaisie = null;
                historique = await Bank.GetHistoriqueAsync();
            }
            else
                Notif.Error("FONDS INSUFFISANTS");
        }
        finally { isProcessing = false; }
    }
}
