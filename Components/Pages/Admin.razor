    private async Task OngletTuteurs()
    {
        activeTab = "tuteurs";
        await ChargerTuteurs();
    }

    private async Task ChargerTuteurs()
    {
        if (isTuteurLoading) return;
        isTuteurLoading = true;
        try
        {
            studentsSansTuteur = await AdminSvc.GetStudentsSansTuteurAsync();
            relationsTuteur = await AdminSvc.GetRelationsTuteurAsync();
        }
        finally { isTuteurLoading = false; }
    }

    private async Task SearchTuteurUser()
    {
        if (string.IsNullOrWhiteSpace(tuteurSearch)) { tuteurSearchError = "Entrez un email, nom ou prénom"; return; }
        tuteurSearchError = null; tuteurSearching = true; selectedStudent = null;
        try
        {
            tuteurSearchResults = await AdminSvc.SearchUsersAsync(tuteurSearch);
            if (!tuteurSearchResults.Any()) tuteurSearchError = "Aucun utilisateur trouvé";
        }
        catch { tuteurSearchError = "Erreur de recherche"; }
        finally { tuteurSearching = false; }
    }

    private void SelectTuteurStudent(UserProfile u)
    {
        selectedStudent = u;
        assignTuteurEmail = "";
        tuteurSearch = "";
        tuteurSearchResults = new();
    }

    private async Task AssignerTuteur()
    {
        if (isProcessing || selectedStudent == null || string.IsNullOrWhiteSpace(assignTuteurEmail)) return;
        isProcessing = true;
        try
        {
            var (success, msg) = await AdminSvc.AssignerTuteurAsync(selectedStudent.Id, assignTuteurEmail);
            Notif.Notify(msg, success ? NotificationType.SUCCESS : NotificationType.ERROR);
            if (success)
            {
                selectedStudent = null;
                assignTuteurEmail = "";
                await ChargerTuteurs();
            }
        }
        finally { isProcessing = false; }
    }

    private async Task RevoquerTuteurAdmin(int studentId)
    {
        if (isProcessing) return;
        isProcessing = true;
        try
        {
            var (success, msg) = await AdminSvc.RevoquerTuteurParAdminAsync(studentId);
            Notif.Notify(msg, success ? NotificationType.SUCCESS : NotificationType.ERROR);
            if (success) await ChargerTuteurs();
        }
        finally { isProcessing = false; }
    }

