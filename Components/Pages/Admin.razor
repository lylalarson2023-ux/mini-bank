                builder.OpenElement(18, "span");
                builder.AddAttribute(19, "class", "log-ts");
                builder.AddContent(20, $"[{log.Timestamp:yyyy-MM-dd HH:mm:ss}]");
                builder.CloseElement();
                builder.OpenElement(21, "span");
                builder.AddAttribute(22, "class", "log-act");
                builder.AddContent(23, log.Action);
                builder.CloseElement();
                builder.OpenElement(24, "span");
                builder.AddAttribute(25, "class", "log-sep");
                builder.AddContent(26, " :: ");
                builder.CloseElement();
                builder.OpenElement(27, "span");
                builder.AddAttribute(28, "class", "log-det");
                builder.AddContent(29, log.Details);
                builder.CloseElement();
                builder.CloseElement();
            }
        }
        builder.CloseElement();
        builder.CloseElement();
        builder.CloseElement();
    };
