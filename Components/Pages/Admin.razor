        builder.CloseElement();
        builder.CloseElement();
        builder.OpenElement(8, "div");
        builder.AddAttribute(9, "class", "card-body");
        builder.OpenElement(10, "div");
        builder.AddAttribute(11, "class", "terminal-view");
        builder.AddAttribute(12, "style", "max-height: 400px;");
        if (!logs.Any())
        {
            builder.OpenElement(13, "div");
            builder.AddAttribute(14, "class", "empty-notif");
            builder.AddContent(15, "Aucune action enregistrée");
            builder.CloseElement();
        }
        else
        {
