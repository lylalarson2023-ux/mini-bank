@page "/admin"
@attribute [Authorize(Policy = "AdminOnly")]
@using ADN_pay.Models
@using ADN_pay.Services
@inject AdminService AdminSvc
@inject BankService Bank
@inject NotificationService Notif
@inject NavigationManager Nav
@inject ILoggerFactory LoggerFactory

<div class="content-area" style="max-width: 100%;">
    <div class="admin-header-bar">
        <div>
            <h1 class="admin-title">PANEL D'ADMINISTRATION</h1>
            <div class="admin-status">
                <span class="dot"></span> SESSION ADMIN ACTIVE
            </div>
        </div>
        <div class="admin-stats">
            <div class="admin-stat">
                <span class="label">RÉSERVES TOTALES</span>
                <span class="value gold">@((totalBalance / 100m).ToString("N2")) MAD</span>
            </div>
            <div class="admin-stat">
                <span class="label">UTILISATEURS</span>
                <span class="value">@totalUsers</span>
            </div>
        </div>
    </div>

    <div class="admin-tabs">
        <button class="admin-tab @(activeTab == "dashboard" ? "active" : "")" @onclick='() => activeTab = "dashboard"'>
            <i class="bi bi-speedometer2"></i> TABLEAU DE BORD
        </button>
        <button class="admin-tab @(activeTab == "dossiers" ? "active" : "")" @onclick='() => activeTab = "dossiers"'>
            <i class="bi bi-shield-check"></i> DOSSIERS KYC
            @if (pendingPremiumCount > 0) { <span class="tab-badge">@pendingPremiumCount</span> }
        </button>
        <button class="admin-tab @(activeTab == "credits" ? "active" : "")" @onclick='() => activeTab = "credits"'>
            <i class="bi bi-currency-exchange"></i> CRÉDITS
            @if (pendingCreditCount > 0) { <span class="tab-badge">@pendingCreditCount</span> }
        </button>
        <button class="admin-tab @(activeTab == "depot" ? "active" : "")" @onclick='() => activeTab = "depot"'>
            <i class="bi bi-cash-stack"></i> DÉPÔT
        </button>
        <button class="admin-tab @(activeTab == "utilisateurs" ? "active" : "")" @onclick='() => activeTab = "utilisateurs"'>
            <i class="bi bi-people"></i> UTILISATEURS
        </button>
        <button class="admin-tab @(activeTab == "logs" ? "active" : "")" @onclick='() => activeTab = "logs"'>
            <i class="bi bi-journal-text"></i> LOGS
        </button>
        <button class="admin-tab @(activeTab == "tuteurs" ? "active" : "")" @onclick="OngletTuteurs">
            <i class="bi bi-people-fill"></i> TUTEURS
        </button>
    </div>

    @if (isLoading)
    {
        <div class="adn-loader">CHARGEMENT...</div>
    }
    else
    {
        @switch (activeTab)
        {
            case "dashboard":
                @RenderDashboard
                break;
            case "dossiers":
                @RenderDossiers
                break;
            case "credits":
                @RenderCredits
                break;
            case "depot":
                @RenderDepot
                break;
            case "utilisateurs":
                @RenderUtilisateurs
                break;
            case "logs":
                @RenderLogs
                break;
            case "tuteurs":
                @RenderTuteurs
                break;
        }
    }
</div>

@* ─── MODAL RÉINITIALISATION MOT DE PASSE ─── *@
@if (showResetModal)
{
    <div class="modal-overlay" @onclick='() => showResetModal = false'>
        <div class="modal-card" @onclick:stopPropagation>
            <div class="card-head">
                <i class="bi bi-key-fill"></i>
                <h2>RÉINITIALISER LE MOT DE PASSE</h2>
            </div>
            <div class="card-body">
                <p style="color: var(--text-secondary); font-size: 0.8rem; margin-bottom: 16px;">
                    Utilisateur #@resetUserId
                </p>
                <div class="form-group">
                    <label>NOUVEAU MOT DE PASSE</label>
                    <PasswordInput @bind-Value="resetPassword" Placeholder="Min. 8 car. (maj, min, chiffre, spécial)" Autocomplete="new-password" />
                </div>
                <div class="form-group">
                    <label>CONFIRMER LE MOT DE PASSE</label>
                    <PasswordInput @bind-Value="resetConfirmPassword" Placeholder="Confirmer" Autocomplete="new-password" />
                </div>
                <div style="display: flex; gap: 12px; margin-top: 20px;">
                    <button class="btn btn-primary btn-block" @onclick="ConfirmResetPassword" disabled="@isProcessing">
                        @(isProcessing ? "TRAITEMENT..." : "CONFIRMER")
                    </button>
                    <button class="btn btn-ghost btn-block" @onclick='() => showResetModal = false'>
                        ANNULER
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ─── MODAL REJET CRÉDIT ─── *@
@if (showRejectCreditModal)
{
    <div class="modal-overlay" @onclick='() => showRejectCreditModal = false'>
        <div class="modal-card" @onclick:stopPropagation>
            <div class="card-head">
                <i class="bi bi-x-circle-fill" style="color: var(--danger);"></i>
                <h2>REJETER LA DEMANDE DE CRÉDIT</h2>
            </div>
            <div class="card-body">
                <p style="color: var(--text-secondary); font-size: 0.8rem; margin-bottom: 16px;">
                    Utilisateur #@rejectCreditUserId
                </p>
                <div class="form-group">
                    <label>MOTIF DU REJET</label>
                    <textarea @bind="rejectCreditMotif" class="form-input" rows="3" placeholder="Raison du rejet (visible par l'utilisateur)"></textarea>
                </div>
                <div style="display: flex; gap: 12px; margin-top: 20px;">
                    <button class="btn btn-danger btn-block" @onclick="ConfirmRejectCredit" disabled="@isProcessing">
                        @(isProcessing ? "TRAITEMENT..." : "REJETER LE CRÉDIT")
                    </button>
                    <button class="btn btn-ghost btn-block" @onclick='() => showRejectCreditModal = false'>
                        ANNULER
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ─── MODAL REJET KYC ─── *@
@if (showRejectKycModal)
{
    <div class="modal-overlay" @onclick='() => showRejectKycModal = false'>
        <div class="modal-card" @onclick:stopPropagation>
            <div class="card-head">
                <i class="bi bi-shield-exclamation" style="color: var(--danger);"></i>
                <h2>REJETER LE DOSSIER KYC</h2>
            </div>
            <div class="card-body">
                <p style="color: var(--text-secondary); font-size: 0.8rem; margin-bottom: 16px;">
                    Utilisateur #@rejectKycUserId — 50 DH seront remboursés
                </p>
                <div class="form-group">
                    <label>MOTIF DU REJET</label>
                    <textarea @bind="rejectKycMotif" class="form-input" rows="3" placeholder="Expliquer le motif du rejet (visible par l'utilisateur)"></textarea>
                </div>
                <div style="display: flex; gap: 12px; margin-top: 20px;">
                    <button class="btn btn-danger btn-block" @onclick="ConfirmRejectKyc" disabled="@isProcessing">
                        @(isProcessing ? "TRAITEMENT..." : "REJETER LE DOSSIER")
                    </button>
                    <button class="btn btn-ghost btn-block" @onclick='() => showRejectKycModal = false'>
                        ANNULER
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private ILogger _logger = default!;
    private string activeTab = "dashboard";
    private bool isLoading = true;
    private long totalBalance;
    private int totalUsers;
    private int pendingPremiumCount;
    private int pendingCreditCount;
    private List<UserProfile> dossiersEnAttente = new();
    private List<UserProfile> historiqueDossiers = new();
    private string dossierSubTab = "en_attente";
    private List<AdminLog> logs = new();
    private string logSearch = "";
    private List<(DateTime Jour, int Count)> registrations = new();

    private IEnumerable<AdminLog> LogsFiltres =>
        string.IsNullOrWhiteSpace(logSearch)
            ? logs
            : logs.Where(l =>
                (l.Action?.Contains(logSearch, StringComparison.OrdinalIgnoreCase) ?? false)
                || (l.Details?.Contains(logSearch, StringComparison.OrdinalIgnoreCase) ?? false)
                || (l.Cible?.Contains(logSearch, StringComparison.OrdinalIgnoreCase) ?? false));

    private int targetId;
    private decimal creditAmount;
    private int depotTargetId;
    private decimal depotMontant;

    private string searchQuery = "";
    private List<UserProfile> searchResults = new();
    private bool isSearching;
    private string? searchError;

    private string creditSearch = "";
    private List<UserProfile> creditSearchResults = new();
    private bool creditSearching;
    private bool isProcessing;
    private string? creditSearchError;
    private UserProfile? creditTarget;

    private string depotSearch = "";
    private List<UserProfile> depotSearchResults = new();
    private bool depotSearching;
    private string? depotSearchError;
    private UserProfile? depotTarget;

    private int resetUserId;
    private string resetPassword = "";
    private string resetConfirmPassword = "";
    private bool showResetModal;
    private bool showRejectCreditModal;
    private int rejectCreditUserId;
    private string rejectCreditMotif = "";
    private bool showRejectKycModal;
    private int rejectKycUserId;
    private string rejectKycMotif = "";

    // Tuteurs
    private List<UserProfile> studentsSansTuteur = new();
    private List<(UserProfile Student, UserProfile? Tuteur)> relationsTuteur = new();
    private string tuteurSearch = "";
    private List<UserProfile> tuteurSearchResults = new();
    private bool tuteurSearching;
    private string? tuteurSearchError;
    private UserProfile? selectedStudent;
    private string assignTuteurEmail = "";
    private bool isTuteurLoading;

    protected override async Task OnInitializedAsync()
    {
        _logger = LoggerFactory.CreateLogger("Admin");
        try
        {
            await ChargerDonnees();
            var uri = Nav.ToAbsoluteUri(Nav.Uri);
            var section = System.Web.HttpUtility.ParseQueryString(uri.Query).Get("section");
            if (section == "historique")
            {
                activeTab = "dossiers";
                dossierSubTab = "historique";
            }
        }
        catch (Exception ex) { _logger.LogError(ex, "Erreur chargement admin"); Notif.Notify("Erreur de chargement", NotificationType.ERROR); }
        finally { isLoading = false; }
    }

    private async Task ChargerDonnees()
    {
        totalBalance = await AdminSvc.GetTotalBankBalanceAsync();
        totalUsers = await AdminSvc.GetTotalUsersAsync();
        pendingPremiumCount = await AdminSvc.GetPendingPremiumCountAsync();
        pendingCreditCount = await AdminSvc.GetPendingCreditCountAsync();
        dossiersEnAttente = await AdminSvc.GetDossiersEnAttenteAsync();
        historiqueDossiers = await AdminSvc.GetHistoriqueDossiersAsync();
        logs = await AdminSvc.GetAdminLogsAsync(200);
        registrations = await AdminSvc.GetRegistrationsPerDayAsync(14);
    }

    private async Task ApprouverDossier(int id)
    {
        if (isProcessing) return;
        isProcessing = true;
        try
        {
            if (await AdminSvc.ApprouverPremium(id))
            {
                Notif.Notify("Dossier validé : accès Premium octroyé", NotificationType.SUCCESS);
                dossiersEnAttente = await AdminSvc.GetDossiersEnAttenteAsync();
                historiqueDossiers = await AdminSvc.GetHistoriqueDossiersAsync();
                dossierSubTab = "historique";
            }
        }
        finally { isProcessing = false; }
    }

    private async Task LancerCredit()
    {
        if (isProcessing) return;
        if (targetId <= 0 || creditAmount <= 0) { Notif.Notify("Valeurs non valides", NotificationType.ERROR); return; }
        isProcessing = true;
        try
        {
            if (await AdminSvc.ApprouverCredit(targetId, (long)(creditAmount * 100)))
            {
                Notif.Notify($"Crédit de {creditAmount:N2} MAD accordé au compte {targetId}", NotificationType.SUCCESS);
                targetId = 0; creditAmount = 0;
                await ChargerDonnees();
            }
            else
                Notif.Notify("Échec : compte introuvable", NotificationType.ERROR);
        }
        finally { isProcessing = false; }
    }

    private async Task LancerDepot()
    {
        if (isProcessing) return;
        if (depotTargetId <= 0 || depotMontant <= 0) { Notif.Notify("Valeurs non valides", NotificationType.ERROR); return; }
        isProcessing = true;
        try
        {
            if (await AdminSvc.AdminDepot(depotTargetId, (long)(depotMontant * 100)))
            {
                Notif.Notify($"Dépôt de {depotMontant:N2} MAD effectué sur le compte {depotTargetId}", NotificationType.SUCCESS);
                depotTargetId = 0; depotMontant = 0;
                await ChargerDonnees();
            }
            else
                Notif.Notify("Échec : compte introuvable", NotificationType.ERROR);
        }
        finally { isProcessing = false; }
    }

    private async Task ApprouverDemandeCredit(int userId)
    {
        if (isProcessing) return;
        isProcessing = true;
        try
        {
            if (await AdminSvc.ApprouverCredit(userId))
            {
                Notif.Notify("Crédit approuvé et versé au compte", NotificationType.SUCCESS);
                await ChargerDonnees();
            }
            else
                Notif.Notify("Échec de l'approbation : utilisateur introuvable", NotificationType.ERROR);
        }
        finally { isProcessing = false; }
    }

    private async Task ConfirmRejectCredit()
    {
        if (isProcessing || rejectCreditUserId <= 0 || string.IsNullOrWhiteSpace(rejectCreditMotif)) return;
        isProcessing = true;
        try
        {
            if (await AdminSvc.RejeterCreditAsync(rejectCreditUserId, rejectCreditMotif))
            {
                Notif.Notify("Demande de crédit rejetée", NotificationType.ERROR);
                showRejectCreditModal = false;
                rejectCreditMotif = "";
                await ChargerDonnees();
            }
            else
                Notif.Notify("Échec du rejet : utilisateur introuvable", NotificationType.ERROR);
        }
        finally { isProcessing = false; }
    }

    private async Task ConfirmRejectKyc()
    {
        if (isProcessing || rejectKycUserId <= 0) return;
        isProcessing = true;
        try
        {
            var (success, msg) = await AdminSvc.RejeterDossierKycAsync(rejectKycUserId, rejectKycMotif);
            if (success)
            {
                Notif.Notify($"Dossier KYC rejeté", NotificationType.ERROR);
                showRejectKycModal = false;
                rejectKycMotif = "";
                await ChargerDonnees();
            }
            else
                Notif.Notify(msg, NotificationType.ERROR);
        }
        finally { isProcessing = false; }
    }

    private async Task VerifierEligibilite()
    {
        if (isProcessing) return;
        if (targetId <= 0) { Notif.Notify("ID manquant", NotificationType.ERROR); return; }
        isProcessing = true;
        try
        {
            var eligible = await Bank.VerifierEligibiliteCredit(targetId);
            Notif.Notify(eligible ? "Cible éligible" : "Cible rejetée : dossier incomplet ou solde négatif",
                eligible ? NotificationType.SUCCESS : NotificationType.ERROR);
        }
        finally { isProcessing = false; }
    }

    private async Task SearchUsers()
    {
        if (string.IsNullOrWhiteSpace(searchQuery)) { searchError = "Veuillez entrer un terme de recherche"; return; }
        searchError = null;
        isSearching = true;
        try
        {
            searchResults = await AdminSvc.SearchUsersAsync(searchQuery);
            if (!searchResults.Any())
                searchError = "Aucun utilisateur trouvé";
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Erreur recherche utilisateur");
            searchError = "Erreur lors de la recherche";
        }
        finally { isSearching = false; }
    }

    private async Task SearchCreditUser()
    {
        if (string.IsNullOrWhiteSpace(creditSearch)) { creditSearchError = "Entrez un email, nom ou prénom"; return; }
        creditSearchError = null; creditSearching = true; creditTarget = null; targetId = 0;
        try
        {
            creditSearchResults = await AdminSvc.SearchUsersAsync(creditSearch);
            if (!creditSearchResults.Any()) creditSearchError = "Aucun utilisateur trouvé";
        }
        catch { creditSearchError = "Erreur de recherche"; }
        finally { creditSearching = false; }
    }

    private void SelectCreditUser(UserProfile u)
    {
        creditTarget = u;
        targetId = u.Id;
        creditSearch = "";
        creditSearchResults = new();
    }

    private async Task SearchDepotUser()
    {
        if (string.IsNullOrWhiteSpace(depotSearch)) { depotSearchError = "Entrez un email, nom ou prénom"; return; }
        depotSearchError = null; depotSearching = true; depotTarget = null; depotTargetId = 0;
        try
        {
            depotSearchResults = await AdminSvc.SearchUsersAsync(depotSearch);
            if (!depotSearchResults.Any()) depotSearchError = "Aucun utilisateur trouvé";
        }
        catch { depotSearchError = "Erreur de recherche"; }
        finally { depotSearching = false; }
    }

    private void SelectDepotUser(UserProfile u)
    {
        depotTarget = u;
        depotTargetId = u.Id;
        depotSearch = "";
        depotSearchResults = new();
    }

    private void OpenResetModal(int userId)
    {
        resetUserId = userId;
        resetPassword = "";
        resetConfirmPassword = "";
        showResetModal = true;
    }

    private async Task ConfirmResetPassword()
    {
        if (isProcessing) return;
        if (string.IsNullOrWhiteSpace(resetPassword) || resetPassword.Length < 8)
        { Notif.Notify("Le mot de passe doit contenir au moins 8 caractères", NotificationType.ERROR); return; }
        if (!resetPassword.Any(char.IsUpper))
        { Notif.Notify("Le mot de passe doit contenir au moins une majuscule", NotificationType.ERROR); return; }
        if (!resetPassword.Any(char.IsLower))
        { Notif.Notify("Le mot de passe doit contenir au moins une minuscule", NotificationType.ERROR); return; }
        if (!resetPassword.Any(char.IsDigit))
        { Notif.Notify("Le mot de passe doit contenir au moins un chiffre", NotificationType.ERROR); return; }
        if (!resetPassword.Any(c => !char.IsLetterOrDigit(c)))
        { Notif.Notify("Le mot de passe doit contenir au moins un caractère spécial", NotificationType.ERROR); return; }
        if (resetPassword != resetConfirmPassword)
        { Notif.Notify("Les mots de passe ne correspondent pas", NotificationType.ERROR); return; }
        isProcessing = true;
        try
        {
            if (await AdminSvc.ResetPasswordAsync(resetUserId, resetPassword))
            {
                Notif.Notify("Mot de passe réinitialisé avec succès", NotificationType.SUCCESS);
                showResetModal = false;
                await SearchUsers();
            }
            else
                Notif.Notify("Échec de la réinitialisation", NotificationType.ERROR);
        }
        finally { isProcessing = false; }
    }

    private string BuildRegistrationsSvg()
    {
        if (registrations.Count == 0) return "<p style=\"color:var(--text-muted);font-size:0.8rem;\">Aucune donnée</p>";

        int n = registrations.Count;
        int max = Math.Max(1, registrations.Max(r => r.Count));
        double w = 600, h = 180, padL = 24, padR = 10, padT = 16, padB = 28;
        double plotW = w - padL - padR, plotH = h - padT - padB;
        double slot = plotW / n;
        double barW = slot * 0.6;
        double baseY = padT + plotH;

        var sb = new System.Text.StringBuilder();
        sb.Append(FormattableString.Invariant(
            $"<svg viewBox=\"0 0 {w} {h}\" xmlns=\"http://www.w3.org/2000/svg\" style=\"width:100%;height:auto;display:block;\">"));
        sb.Append("<defs><linearGradient id=\"gradReg\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">");
        sb.Append("<stop offset=\"0%\" stop-color=\"#0099CC\"/><stop offset=\"100%\" stop-color=\"#30B880\"/></linearGradient></defs>");
        sb.Append(FormattableString.Invariant(
            $"<line x1=\"{padL}\" y1=\"{baseY}\" x2=\"{padL + plotW}\" y2=\"{baseY}\" stroke=\"var(--border)\" stroke-width=\"1\"/>"));

        for (int i = 0; i < n; i++)
        {
            var (jour, count) = registrations[i];
            double bh = plotH * count / max;
            double x = padL + slot * i + (slot - barW) / 2;
            double y = baseY - bh;
            sb.Append(FormattableString.Invariant(
                $"<rect x=\"{x:F1}\" y=\"{y:F1}\" width=\"{barW:F1}\" height=\"{bh:F1}\" rx=\"2\" fill=\"url(#gradReg)\"/>"));
            if (count > 0)
                sb.Append(FormattableString.Invariant(
                    $"<text x=\"{x + barW / 2:F1}\" y=\"{y - 3:F1}\" text-anchor=\"middle\" font-size=\"9\" fill=\"var(--text-secondary)\">{count}</text>"));
            if (i % 2 == 0 || i == n - 1)
                sb.Append(FormattableString.Invariant(
                    $"<text x=\"{x + barW / 2:F1}\" y=\"{baseY + 14:F1}\" text-anchor=\"middle\" font-size=\"8\" fill=\"var(--text-muted)\">{jour:dd/MM}</text>"));
        }
        sb.Append("</svg>");
        return sb.ToString();
    }

