@page "/register"
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using System.Text.RegularExpressions
@inject BankService Bank
@inject NavigationManager Nav
@inject NotificationService Notif

<NotificationOverlay />

@if (showSuccess)
{
    <div class="auth-wrapper register-success">
        <div class="auth-card" style="text-align: center; padding: 60px 40px;">
            <div class="success-check">
                <svg viewBox="0 0 52 52" class="checkmark-svg">
                    <circle cx="26" cy="26" r="25" fill="none" class="checkmark-circle" />
                    <path fill="none" d="M14 27l7 7 16-16" class="checkmark-check" />
                </svg>
            </div>
            <h2 style="color: var(--gold-500); margin: 20px 0 8px; font-weight: 700;">COMPTE CRÉÉ</h2>
            <p style="color: var(--text-secondary); font-size: 0.85rem;">REDIRECTION VERS LE TERMINAL DE CONNEXION...</p>
        </div>
    </div>
}
else if (showEmailVerif)
{
    <div class="auth-wrapper" style="max-width: 520px;">
        <div class="auth-card">
            <div class="auth-header">
                <img src="images/logo_adn_pay_auth.png" alt="ADN_pay" class="auth-logo" style="max-width: 140px; margin-bottom: 14px;" />
                <h1 class="auth-title" style="font-size: 1.45rem;">Confirmez votre e-mail</h1>
                <p class="auth-subtitle">VÉRIFICATION</p>
                <div style="height: 3px; width: 56px; margin: 14px auto 0; background: linear-gradient(90deg, #0099CC, #30B880); border-radius: 3px;"></div>
            </div>

            <p style="color: var(--text-secondary); font-size: 0.78rem; text-align:center; margin-bottom: 18px;">
                Un code à 6 chiffres a été envoyé à <strong>@newUser.Email</strong>. Saisissez-le pour confirmer votre adresse.
            </p>

            @if (!string.IsNullOrEmpty(verifError))
            {
                <div style="background: var(--danger-bg); border: 1px solid var(--danger); color: var(--danger); padding: 12px; border-radius: var(--radius-md); margin-bottom: 16px; font-size: 0.8rem;">
                    <i class="bi bi-exclamation-triangle-fill"></i> @verifError
                </div>
            }
            @if (!string.IsNullOrEmpty(verifInfo))
            {
                <div style="background: rgba(48,184,128,0.10); border: 1px solid rgba(48,184,128,0.4); color: var(--success); padding: 10px 12px; border-radius: var(--radius-md); margin-bottom: 16px; font-size: 0.78rem; text-align:center;">
                    <i class="bi bi-envelope-check"></i> @verifInfo
                </div>
            }

            <div class="form-group">
                <input @bind="verifCode" maxlength="6" inputmode="numeric" class="form-input" placeholder="000000"
                       style="text-align:center; font-size:1.4rem; letter-spacing:8px; font-family: var(--font-mono);" />
            </div>

            <button type="button" class="btn btn-adn btn-block" @onclick="ConfirmerEmail" disabled="@verifLoading" style="margin-top:8px;">
                @(verifLoading ? "VÉRIFICATION..." : "CONFIRMER MON E-MAIL")
            </button>

            <div class="auth-footer" style="display:flex; gap:16px; justify-content:center;">
                <a href="#" @onclick="RenvoyerCodeEmail" @onclick:preventDefault="true">Renvoyer le code</a>
                <a href="#" @onclick="PasserVerif" @onclick:preventDefault="true">Plus tard</a>
            </div>
        </div>
    </div>
}
else if (showAdnChoice)
{
    <div class="auth-wrapper" style="max-width: 520px;">
        <div class="auth-card">
            <div class="auth-header">
                <img src="images/logo_adn_pay_auth.png" alt="ADN_pay" class="auth-logo" style="max-width: 140px; margin-bottom: 14px;" />
                <h1 class="auth-title" style="font-size: 1.45rem;">Votre adresse ADN_pay</h1>
                <p class="auth-subtitle">CHOISISSEZ VOTRE @@adnpay.ma</p>
                <div style="height: 3px; width: 56px; margin: 14px auto 0; background: linear-gradient(90deg, #0099CC, #30B880); border-radius: 3px;"></div>
            </div>

            <p style="color: var(--text-secondary); font-size: 0.78rem; text-align:center; margin-bottom: 18px;">
                Compte créé ✓ — réservez dès maintenant votre adresse <strong>@@adnpay.ma</strong> (vous pourrez l'utiliser plus tard).
            </p>

            @if (!string.IsNullOrEmpty(adnError))
            {
                <div style="background: var(--danger-bg); border: 1px solid var(--danger); color: var(--danger); padding: 12px; border-radius: var(--radius-md); margin-bottom: 16px; font-size: 0.8rem;">
                    @adnError
                </div>
            }

            <div class="form-section" style="padding: 20px;">
                @foreach (var opt in adnOptions)
                {
                    var o = opt;
                    <label style="display:flex; align-items:center; gap:12px; padding:12px 14px; margin-bottom:10px; border:1px solid @(selectedAdn == o ? "var(--blue-500)" : "var(--border)"); border-radius: var(--radius-md); cursor:pointer; background:@(selectedAdn == o ? "var(--blue-glow)" : "transparent");">
                        <input type="radio" name="adnchoice" checked="@(selectedAdn == o)" @onchange="@(() => selectedAdn = o)" />
                        <span style="font-weight:600;">@o</span>
                    </label>
                }
            </div>

            <button type="button" class="btn btn-adn btn-block" @onclick="ConfirmerAdn" disabled="@adnLoading" style="margin-top:8px;">
                @(adnLoading ? "RÉSERVATION..." : "RÉSERVER CETTE ADRESSE")
            </button>

            <div class="auth-footer">
                <a href="#" @onclick="PasserAdn" @onclick:preventDefault="true">Passer pour l'instant</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="auth-wrapper" style="max-width: 520px;">
        <div class="auth-card">
            <div class="auth-header">
                <img src="images/logo_adn_pay_auth.png" alt="ADN_pay" class="auth-logo" style="max-width: 140px; margin-bottom: 14px;" />
                <h1 class="auth-title" style="font-size: 1.45rem;">Créer votre compte</h1>
                <p class="auth-subtitle">ENRÔLEMENT ADN_ID</p>
                <div style="height: 3px; width: 56px; margin: 14px auto 0; background: linear-gradient(90deg, #0099CC, #30B880); border-radius: 3px;"></div>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div style="background: var(--danger-bg); border: 1px solid var(--danger); color: var(--danger); padding: 12px; border-radius: var(--radius-md); margin-bottom: 16px; font-size: 0.8rem;">
                    <i class="bi bi-exclamation-triangle-fill"></i> @errorMessage
                </div>
            }

            <div class="form-section" style="margin-bottom: 20px; padding: 20px;">
                <h6 class="section-title" style="margin-bottom: 16px;">1. IDENTITE ET ACCES ADN</h6>
                <div class="form-row">
                    <div class="form-group">
                        <label>PRENOM</label>
                        <input @bind="newUser.Prenom" class="form-input" placeholder="Dan" />
                    </div>
                    <div class="form-group">
                        <label>NOM</label>
                        <input @bind="newUser.Nom" class="form-input" placeholder="Larson" />
                    </div>
                </div>
                <div class="form-group">
                    <label>VOTRE E-MAIL (ACTUEL)</label>
                    <input @bind="newUser.Email" type="email" class="form-input" placeholder="vous@exemple.com" />
                    <small style="color: var(--text-muted); font-size: 0.6rem; margin-top: 4px; display: block;">Votre e-mail personnel, utilisé pour vous connecter. Vous réserverez une adresse @@adnpay.ma juste après.</small>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>MOT DE PASSE</label>
                        <PasswordInput @bind-Value="newUser.MotDePasse" Placeholder="••••••••" Autocomplete="new-password" />
                        @if (!string.IsNullOrEmpty(newUser.MotDePasse))
                        {
                            <div class="pwd-meter">
                                <div class="pwd-meter-track">
                                    <div class="pwd-meter-fill" style="width:@(PwdScore * 20)%; background:@PwdColor;"></div>
                                </div>
                                <span class="pwd-meter-label" style="color:@PwdColor;">@PwdLabel</span>
                            </div>
                        }
                        <small style="color: var(--text-muted); font-size: 0.6rem; margin-top: 4px; display: block;">8+ car., 1 maj, 1 min, 1 chiffre, 1 spécial</small>
                    </div>
                    <div class="form-group">
                        <label>CONFIRMER</label>
                        <PasswordInput @bind-Value="confirmPassword" Placeholder="••••••••" Autocomplete="new-password" />
                        @if (!string.IsNullOrEmpty(confirmPassword))
                        {
                            <small style="font-size:0.62rem; margin-top:6px; display:block; color:@(confirmPassword == newUser.MotDePasse ? "var(--success)" : "var(--danger)");">
                                @(confirmPassword == newUser.MotDePasse ? "✓ Les mots de passe correspondent" : "✗ Les mots de passe diffèrent")
                            </small>
                        }
                    </div>
                </div>
            </div>

            <div class="form-section" style="margin-bottom: 20px; padding: 20px;">
                <h6 class="section-title" style="margin-bottom: 16px;">2. COORDONNEES RESEAU</h6>
                <div class="form-row">
                    <div class="form-group">
                        <label>VILLE</label>
                        <select @bind="ville" class="form-select">
                            <option value="">-- Choix --</option>
                            @foreach (var v in optsV)
                            {
                                <option value="@v">@v</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>TELEPHONE</label>
                        <input @bind="tel" class="form-input" placeholder="06..." />
                    </div>
                </div>
            </div>

            <div class="form-group" style="margin-bottom: 20px;">
                <label class="checkbox-container">
                    <input type="checkbox" @bind="newUser.CguAcceptees" />
                    <span style="font-size: 0.7rem; color: var(--text-secondary);">J'accepte les <a href="/cgu" target="_blank">Conditions Générales d'Utilisation</a> et la <a href="/confidentialite" target="_blank">Politique de Confidentialité</a></span>
                </label>
            </div>

            <button type="button" class="btn btn-adn btn-block" @onclick="HandleRegister" disabled="@isLoading">
                @(isLoading ? "CRÉATION EN COURS..." : "CRÉER MON ACCÈS ADN_ID")
            </button>

            <div class="auth-footer">
                <a href="/login">DEJA ENROLE ? ACCEDER AU TERMINAL</a>
            </div>
        </div>
    </div>
}

@code {
    private UserProfile newUser = new();
    private string confirmPassword = "";
    private string ville = "";
    private string tel = "";
    private string errorMessage = "";
    private bool isLoading = false;
    private bool showSuccess = false;

    // --- Étape « confirmer l'e-mail » (juste après la création du compte) ---
    private bool showEmailVerif = false;
    private string verifCode = "";
    private string verifError = "";
    private string verifInfo = "";
    private bool verifLoading = false;

    // --- Étape « choisir son adresse @adnpay.ma » (après création du compte) ---
    private bool showAdnChoice = false;
    private List<string> adnOptions = new();
    private string selectedAdn = "";
    private string adnError = "";
    private bool adnLoading = false;
    private List<string> optsV = new() { "Casablanca", "Rabat", "Marrakech", "Tanger", "Agadir", "Fès", "Oujda", "Kenitra", "Meknès", "Safi" , "Tétouan", "Khouribga", "El Jadida", "Nador", "Béni Mellal", "Kénitra", "Settat", "Larache", "Sidi Kacem", "Guelmim", "Taza", "Ouarzazate", "Dakhla", "Tan-Tan", "Errachidia", "Sidi Ifni", "Zagora", "Boujdour", "Laayoune", "Assilah", "Fnideq", "Martil", "Al Hoceima", "Tiznit", "Sidi Slimane", "Ouazzane", "Azrou", "Midelt", "Ifrane", "Kelaat M'Gouna" };

    // --- Jauge de force du mot de passe (live) ---
    private int PwdScore
    {
        get
        {
            var p = newUser.MotDePasse ?? "";
            int s = 0;
            if (p.Length >= 8) s++;
            if (p.Any(char.IsUpper)) s++;
            if (p.Any(char.IsLower)) s++;
            if (p.Any(char.IsDigit)) s++;
            if (p.Any(c => !char.IsLetterOrDigit(c))) s++;
            return s;
        }
    }
    private string PwdColor => PwdScore switch { <= 2 => "var(--danger)", 3 => "var(--warning)", 4 => "var(--blue-500)", _ => "var(--success)" };
    private string PwdLabel => PwdScore switch { <= 2 => "Faible", 3 => "Moyen", 4 => "Bon", _ => "Fort" };

    private static readonly Regex EmailRegex = new(@"^[^@\s]+@[^@\s]+\.[^@\s]+$", RegexOptions.Compiled);
    private static readonly Regex PhoneRegex = new(@"^(?:\+212|0)[5-7][0-9]{8}$", RegexOptions.Compiled);

    private async Task HandleRegister()
    {
        errorMessage = "";
        newUser.Prenom = newUser.Prenom?.Trim() ?? "";
        newUser.Nom = newUser.Nom?.Trim() ?? "";
        newUser.Ville = ville;
        newUser.Telephone = tel?.Trim() ?? "";
        newUser.Role = "STUDENT";
        newUser.Email = newUser.Email?.Trim().ToLower() ?? "";
        var password = newUser.MotDePasse;

        if (string.IsNullOrEmpty(newUser.Prenom) || string.IsNullOrEmpty(newUser.Nom))
        {
            errorMessage = "Prénom et nom requis.";
            return;
        }
        if (string.IsNullOrEmpty(newUser.Email) || !EmailRegex.IsMatch(newUser.Email))
        {
            errorMessage = "Adresse e-mail invalide.";
            return;
        }
        if (string.IsNullOrEmpty(newUser.Ville))
        {
            errorMessage = "Veuillez sélectionner votre ville.";
            return;
        }
        if (string.IsNullOrEmpty(newUser.Telephone) || !PhoneRegex.IsMatch(newUser.Telephone.Replace(" ", "")))
        {
            errorMessage = "Numéro de téléphone invalide (ex : 0612345678 ou +212612345678).";
            return;
        }
        if (string.IsNullOrEmpty(password) || password.Length < 8)
        {
            errorMessage = "Mot de passe trop court (min. 8 caractères).";
            return;
        }
        if (!password.Any(char.IsUpper) || !password.Any(char.IsLower) ||
            !password.Any(char.IsDigit) || !password.Any(c => !char.IsLetterOrDigit(c)))
        {
            errorMessage = "Le mot de passe doit contenir 1 majuscule, 1 minuscule, 1 chiffre et 1 caractère spécial.";
            return;
        }
        if (password != confirmPassword)
        {
            errorMessage = "Les mots de passe sont différents.";
            return;
        }
        if (!newUser.CguAcceptees)
        {
            errorMessage = "Acceptez les CGU et la Politique de Confidentialité.";
            return;
        }

        isLoading = true;
        try
        {
            var (success, msg) = await Bank.CreerNouveauCompte(newUser, password);

            if (success)
            {
                Notif.Notify("COMPTE CRÉÉ — confirmez votre adresse e-mail", NotificationType.SUCCESS);
                showEmailVerif = true;
                StateHasChanged();
            }
            else
            {
                errorMessage = msg;
                Notif.Notify(msg, NotificationType.ERROR);
            }
        }
        catch
        {
            errorMessage = "Une erreur technique est survenue. Veuillez réessayer.";
            Notif.Notify("ERREUR LORS DE LA CREATION", NotificationType.ERROR);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ConfirmerEmail()
    {
        verifError = ""; verifInfo = "";
        if (string.IsNullOrWhiteSpace(verifCode)) { verifError = "Saisissez le code reçu par e-mail."; return; }
        verifLoading = true;
        try
        {
            var (ok, msg) = await Bank.VerifyEmailCodeAsync(newUser.Email, verifCode);
            if (ok)
            {
                Notif.Notify("ADRESSE E-MAIL CONFIRMÉE", NotificationType.SUCCESS);
                await AllerAdnChoice();
            }
            else verifError = msg;
        }
        catch { verifError = "Erreur technique. Veuillez réessayer."; }
        finally { verifLoading = false; }
    }

    private async Task RenvoyerCodeEmail()
    {
        verifError = "";
        verifInfo = await Bank.ResendEmailVerificationAsync(newUser.Email);
    }

    private async Task PasserVerif() => await AllerAdnChoice();

    private async Task AllerAdnChoice()
    {
        showEmailVerif = false;
        adnOptions = await Bank.GenererAdnEmailsAsync(newUser.Prenom, newUser.Nom);
        selectedAdn = adnOptions.FirstOrDefault() ?? "";
        showAdnChoice = true;
        StateHasChanged();
    }

    private async Task ConfirmerAdn()
    {
        adnError = "";
        if (string.IsNullOrEmpty(selectedAdn)) { adnError = "Choisissez une adresse."; return; }
        adnLoading = true;
        try
        {
            var (ok, msg) = await Bank.ReserverAdnEmailAsync(newUser.Email, selectedAdn);
            if (ok)
            {
                await FinaliserAsync();
            }
            else
            {
                adnError = msg;
                adnOptions = await Bank.GenererAdnEmailsAsync(newUser.Prenom, newUser.Nom);
                selectedAdn = adnOptions.FirstOrDefault() ?? "";
            }
        }
        catch
        {
            adnError = "Erreur technique. Veuillez réessayer.";
        }
        finally
        {
            adnLoading = false;
        }
    }

    private async Task PasserAdn() => await FinaliserAsync();

    private async Task FinaliserAsync()
    {
        showAdnChoice = false;
        showSuccess = true;
        StateHasChanged();
        await Task.Delay(1800);
        Nav.NavigateTo("/login", forceLoad: true);
    }
}
