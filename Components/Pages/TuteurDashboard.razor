@page "/tuteur-dashboard"
@attribute [Authorize]
@inject BankService Bank
@inject NotificationService Notif
@inject IJSRuntime JS

<div class="cyber-panel" style="border-color: var(--blue-border); max-width: 800px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h3 style="color: var(--blue-500); margin: 0;">ESPACE TUTEUR</h3>
        <span class="badge badge-info">SÉCURISÉ</span>
    </div>

    @* ─── STATS ─── *@
    <div class="form-row" style="margin-bottom: 24px;">
        <div class="stat-card">
            <div class="stat-label">ÉTUDIANTS SUIVIS</div>
            <div class="stat-value">@etudiantsSuivis</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">TOTAL INVESTI</div>
            <div class="stat-value green">@((pochesSurveillees.Sum(x => x.Pocket.CapitalActuel) / 100m).ToString("N2")) DH</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">INVESTI CE MOIS</div>
            <div class="stat-value" style="color: var(--blue-500);">+@((totalInvestiMois / 100m).ToString("N2")) DH</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">NICHES ACTIVES</div>
            <div class="stat-value">@pochesSurveillees.Count</div>
        </div>
    </div>

    @if (!pochesSurveillees.Any())
    {
        <div class="empty-state">
            <p>AUCUN ÉTUDIANT NE VOUS A AUTORISÉ COMME TUTEUR</p>
        </div>
    }
    else
    {
        @* ─── LISTE ÉTUDIANTS AVEC POCKETS ─── *@
        <div style="display: flex; flex-direction: column; gap: 16px;">
            @foreach (var group in pochesSurveillees.GroupBy(x => x.StudentEmail))
            {
                var first = group.First();
                var totalGroup = group.Sum(x => x.Pocket.CapitalActuel);
                <div class="card" style="border-left: 4px solid var(--blue-500);">
                    <div class="card-body" style="padding: 16px;">
                        @* Student header *@
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                            <div>
                                <div style="font-weight: 700; color: var(--blue-500);">@first.StudentName.ToUpper()</div>
                                <div style="font-size: 0.65rem; color: var(--text-muted);">@first.StudentEmail · @group.Count() poche(s)</div>
                            </div>
                            <div style="text-align: right;">
                                <div style="font-size: 0.8rem; font-weight: 600; color: var(--success);">@((totalGroup / 100m).ToString("N2")) DH</div>
                            </div>
                        </div>

                        @* Pockets for this student *@
                        @foreach (var item in group)
                        {
                            var p = item.Pocket;
                            var pct = p.Progression;
                            <div style="padding: 8px 0; border-top: 1px solid var(--border-color);">
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                                    <span style="font-size: 0.75rem; font-weight: 600;">@p.Objectif.ToUpper()</span>
                                    <span style="font-size: 0.7rem; font-weight: 700;">@((p.CapitalActuel / 100m).ToString("N2")) DH</span>
                                </div>
                                @* Progress bar *@
                                <div style="height: 6px; background: var(--bg-secondary); border-radius: 4px; overflow: hidden; margin-bottom: 2px;">
                                    <div style="height: 100%; width: @(Math.Min(pct, 100))%; background: linear-gradient(90deg, var(--success), var(--blue-500)); border-radius: 4px;"></div>
                                </div>
                                <div style="display: flex; justify-content: space-between; font-size: 0.55rem; color: var(--text-muted);">
                                    <span>@pct% · Cible: @((p.MontantCible / 100m).ToString("N2")) DH</span>
                                    <span>Échéance: @p.DateCible.ToShortDateString()</span>
                                </div>
                                @* Quick boost buttons *@
                                <div style="display: flex; gap: 6px; margin-top: 6px;">
                                    @foreach (var mnt in new[] { 100m, 200m, 500m, 1000m })
                                    {
                                        <button class="btn btn-primary btn-sm" style="flex: 1; font-size: 0.6rem; padding: 4px;" @onclick="() => BoosterMontant(p, mnt)" disabled="@isProcessing">
                                            +@mnt
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        @* ─── ACTIVITÉ RÉCENTE ─── *@
        @if (recentActivity.Any())
        {
            <h5 class="section-title" style="margin-top: 24px;">ACTIVITÉ RÉCENTE DES ÉTUDIANTS</h5>
            <div class="terminal-view" style="max-height: 200px;">
                @foreach (var tx in recentActivity)
                {
                    <div class="log-line">
                        <span class="log-ts">[@tx.Date.ToString("dd/MM HH:mm")]</span>
                        <span class="log-act">@tx.Type</span>
                        <span class="log-det">:: @((tx.Montant / 100m).ToString("N2")) DH — @tx.Motif</span>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private List<TuteurPocketView> pochesSurveillees = new();
    private int etudiantsSuivis;
    private long totalInvestiMois;
    private bool isProcessing;
    private List<Transaction> recentActivity = new();

    protected override async Task OnInitializedAsync()
    {
        await ChargerDonnees();
    }

    private async Task ChargerDonnees()
    {
        pochesSurveillees = await Bank.GetPocketsForTuteurAsync();
        etudiantsSuivis = pochesSurveillees.Select(x => x.StudentEmail).Distinct().Count();
        totalInvestiMois = await Bank.GetTotalInvestiThisMonthAsync();
        recentActivity = await Bank.GetRecentActivityForTuteurAsync(15);
    }

    private async Task BoosterMontant(SavingsPocket p, decimal montant)
    {
        isProcessing = true;
        try
        {
            bool success = await Bank.BoosterPocheAsync(p.Id, (long)(montant * 100));
            if (success)
            {
                Notif.Notify($"Poche boostée de {montant:N2} DH", NotificationType.SUCCESS);
                await ChargerDonnees();
            }
            else
                Notif.Notify("FONDS INSUFFISANTS", NotificationType.ERROR);
        }
        finally { isProcessing = false; }
    }
}
