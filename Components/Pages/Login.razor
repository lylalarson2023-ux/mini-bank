@page "/login"
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using System.Security.Cryptography
@using System.Text
@using MBANK_ETUDIANT.Services
@inject BankService Bank
@inject NavigationManager Nav
@inject NotificationService Notif
@inject IConfiguration Config
<NotificationOverlay />
@using MBANK_ETUDIANT.Models

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <h1 class="auth-title"><span class="gold">M</span>BANK</h1>
            <div class="auth-subtitle">ADNcorporation | TERMINAL</div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div style="background: var(--danger-bg); border: 1px solid var(--danger); color: var(--danger); padding: 12px; border-radius: var(--radius-md); margin-bottom: 16px; font-size: 0.8rem;">
                <i class="bi bi-exclamation-triangle-fill"></i> @errorMessage
            </div>
        }

        <div class="form-group">
            <label>ADRESSE E-MAIL</label>
            <input @bind="email" type="email" placeholder="nom@exemple.com" class="form-input" />
        </div>

        <div class="form-group">
            <label>MOT DE PASSE</label>
            <input @bind="mdp" type="password" placeholder="......" class="form-input" />
        </div>

        <button class="btn btn-gold btn-block" @onclick="HandleLogin" disabled="@isLoading">
            @(isLoading ? "CONNEXION..." : "SE CONNECTER")
        </button>

        <div class="auth-footer">
            <a href="/register">(inscription)</a>
        </div>
    </div>
</div>

@code
{
    private string email = "";
    private string mdp = "";
    private string errorMessage = "";
    private bool isLoading = false;

    private static string SignToken(string payload) =>
        Convert.ToHexString(SHA256.HashData(Encoding.UTF8.GetBytes(payload)));

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var errorParam = System.Web.HttpUtility.ParseQueryString(uri.Query).Get("error");
        if (errorParam == "invalid")
            errorMessage = "Échec de l'authentification : signature invalide. Veuillez réessayer.";
        else if (errorParam == "session")
            errorMessage = "Session expirée. Veuillez vous reconnecter.";
    }

    private async Task HandleLogin()
    {
        errorMessage = "";
        isLoading = true;

        try
        {
            if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(mdp))
            {
                errorMessage = "Email et mot de passe requis.";
                return;
            }

            var success = await Bank.SeConnecter(email, mdp);

            if (success)
            {
                Notif.Notify("ACCES ACCORDE", NotificationType.SUCCESS);
                var userId = Bank.Profil.Id;
                if (userId == 0)
                {
                    errorMessage = "ERREUR : ID UTILISATEUR INVALIDE";
                    return;
                }
                var secret = Config["LoginSecret"];
                if (string.IsNullOrEmpty(secret))
                {
                    errorMessage = "ERREUR DE CONFIGURATION SERVEUR";
                    return;
                }
                var sig = SignToken($"{userId}:{secret}");
                Nav.NavigateTo($"/api/auth/login-handler?userId={userId}&sig={sig}", forceLoad: true);
            }
            else
            {
                errorMessage = "Email ou mot de passe incorrect.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur technique : {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
