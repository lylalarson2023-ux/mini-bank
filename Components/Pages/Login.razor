@page "/login"
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using System.Security.Cryptography
@using System.Text
@inject BankService Bank
@inject NavigationManager Nav
@inject NotificationService Notif
@inject IConfiguration Config
<NotificationOverlay />

<div class="auth-wrapper login-page">

    <div class="login-shape login-shape-1"></div>
    <div class="login-shape login-shape-2"></div>
    <div class="login-shape login-shape-3"></div>
    <div class="login-shape login-shape-4"></div>
    <div class="login-shape login-shape-5"></div>

    <div class="auth-card">
        <div class="auth-header">
            <h1 class="auth-title"><img src="images/logo_adn_pay_auth.png" alt="ADN_pay" class="auth-logo" /></h1>
            <div class="auth-subtitle">BY ADNCORP | TERMINAL</div>
            <div class="auth-subtitle-line adn"></div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="login-error">
                <i class="bi bi-exclamation-triangle-fill"></i> @errorMessage
            </div>
        }

        @if (!showTwoFactor)
        {
            <div class="form-group">
                <label>ADRESSE E-MAIL</label>
                <input @bind="email" type="email" placeholder="nom@exemple.com" class="form-input" disabled="@isLoading" />
            </div>

            <div class="form-group">
                <label>MOT DE PASSE</label>
                <PasswordInput @bind-Value="mdp" Placeholder="......" Disabled="isLoading" />
            </div>

            <button class="btn btn-adn btn-block @(isLoading ? "btn-loading" : "")" @onclick="HandleLogin" disabled="@isLoading">
                @(isLoading ? "CONNEXION..." : "SE CONNECTER")
            </button>

            <div class="auth-footer" style="display: flex; gap: 16px; justify-content: center;">
                <a href="/mot-de-passe-oublie">(mot de passe oublié)</a>
                <a href="/register">(inscription)</a>
            </div>
        }
        else
        {
            <div style="text-align: center; margin-bottom: 20px;">
                <i class="bi bi-shield-lock-fill" style="font-size: 2rem; color: var(--blue-500);"></i>
                <p style="margin: 8px 0 4px; font-size: 0.85rem; font-weight: 600;">AUTHENTIFICATION À DEUX FACTEURS</p>
                <p style="font-size: 0.7rem; color: var(--text-muted);">
                    @(useRecoveryCode ? "Saisissez un de vos codes de secours" : "Saisissez le code généré par votre application")
                </p>
            </div>

            @if (!useRecoveryCode)
            {
                <div class="form-group">
                    <label>CODE 2FA</label>
                    <input @bind="twoFactorCode" type="text" inputmode="numeric" maxlength="6" placeholder="000000" class="form-input" style="text-align: center; font-size: 1.4rem; letter-spacing: 8px; font-family: var(--font-mono);" />
                </div>
                <button class="btn btn-adn btn-block @(isLoading ? "btn-loading" : "")" @onclick="ValidateTwoFactor" disabled="@isLoading">
                    @(isLoading ? "VÉRIFICATION..." : "VALIDER LE CODE")
                </button>
            }
            else
            {
                <div class="form-group">
                    <label>CODE DE SECOURS</label>
                    <input @bind="recoveryCode" type="text" maxlength="11" placeholder="xxxxx-xxxxx" class="form-input" style="text-align: center; letter-spacing: 3px; font-family: var(--font-mono);" />
                </div>
                <button class="btn btn-adn btn-block @(isLoading ? "btn-loading" : "")" @onclick="ValidateRecoveryCode" disabled="@isLoading">
                    @(isLoading ? "VÉRIFICATION..." : "UTILISER CE CODE")
                </button>
            }

            <div class="auth-footer" style="display: flex; gap: 16px; justify-content: center;">
                <a href="javascript:void(0)" @onclick="ToggleRecoveryMode">
                    @(useRecoveryCode ? "(utiliser l'application)" : "(code de secours)")
                </a>
                <a href="javascript:void(0)" @onclick="CancelTwoFactor">(annuler)</a>
            </div>
        }
    </div>
</div>

@code
{
    private string email = "";
    private string mdp = "";
    private string errorMessage = "";
    private bool isLoading = false;
    private bool showTwoFactor;
    private string twoFactorCode = "";
    private bool useRecoveryCode;
    private string recoveryCode = "";

    private static string SignToken(string payload, string secret) =>
        Convert.ToHexString(HMACSHA256.HashData(Encoding.UTF8.GetBytes(secret), Encoding.UTF8.GetBytes(payload)));

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var errorParam = System.Web.HttpUtility.ParseQueryString(uri.Query).Get("error");
        if (errorParam == "invalid")
            errorMessage = "Échec de l'authentification : signature invalide. Veuillez réessayer.";
        else if (errorParam == "session")
            errorMessage = "Session expirée. Veuillez vous reconnecter.";
    }

    private async Task HandleLogin()
    {
        errorMessage = "";
        isLoading = true;

        try
        {
            if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(mdp))
            {
                errorMessage = "Email et mot de passe requis.";
                return;
            }

            var success = await Bank.SeConnecter(email, mdp);

            if (success)
            {
                if (Bank.IsTwoFactorRequired)
                {
                    showTwoFactor = true;
                    return;
                }

                await CompleteLogin(Bank.Profil.Id);
            }
            else
            {
                errorMessage = "Email ou mot de passe incorrect.";
            }
        }
        catch
        {
            errorMessage = "Une erreur technique est survenue. Veuillez réessayer.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ValidateTwoFactor()
    {
        errorMessage = "";
        isLoading = true;

        try
        {
            if (string.IsNullOrWhiteSpace(twoFactorCode) || twoFactorCode.Length != 6)
            {
                errorMessage = "Code 2FA invalide (6 chiffres requis).";
                return;
            }

            if (Bank.IsTwoFactorRequired && Bank.VerifyTwoFactorCode(Bank.Profil.TwoFactorSecret ?? "", twoFactorCode))
            {
                await CompleteLogin(Bank.Profil.Id);
            }
            else
            {
                errorMessage = "Code 2FA incorrect. Réessayez.";
            }
        }
        catch
        {
            errorMessage = "Erreur technique lors de la vérification 2FA.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ValidateRecoveryCode()
    {
        errorMessage = "";
        isLoading = true;
        try
        {
            if (string.IsNullOrWhiteSpace(recoveryCode))
            {
                errorMessage = "Saisissez un code de secours.";
                return;
            }
            if (await Bank.VerifyAndConsumeRecoveryCodeAsync(Bank.Profil.Id, recoveryCode))
            {
                await CompleteLogin(Bank.Profil.Id);
            }
            else
            {
                errorMessage = "Code de secours invalide ou déjà utilisé.";
            }
        }
        catch
        {
            errorMessage = "Erreur technique lors de la vérification du code de secours.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleRecoveryMode()
    {
        useRecoveryCode = !useRecoveryCode;
        errorMessage = "";
        twoFactorCode = "";
        recoveryCode = "";
    }

    private void CancelTwoFactor()
    {
        showTwoFactor = false;
        useRecoveryCode = false;
        twoFactorCode = "";
        recoveryCode = "";
        Bank.Deconnexion();
    }

    private async Task CompleteLogin(int userId)
    {
        if (userId == 0)
        {
            errorMessage = "ERREUR : ID UTILISATEUR INVALIDE";
            return;
        }
        var secret = Config["LoginSecret"];
        if (string.IsNullOrEmpty(secret))
        {
            errorMessage = "ERREUR DE CONFIGURATION SERVEUR";
            return;
        }
        Notif.Notify("ACCES ACCORDE", NotificationType.SUCCESS);
        // Lien de passation à durée de vie courte : signe userId + expiration (anti-rejeu
        // si l'URL fuit via logs/historique/referer).
        var exp = DateTimeOffset.UtcNow.AddSeconds(120).ToUnixTimeSeconds();
        var sig = SignToken($"{userId}.{exp}", secret);
        Nav.NavigateTo($"/api/auth/login-handler?userId={userId}&exp={exp}&sig={sig}", forceLoad: true);
    }
}
