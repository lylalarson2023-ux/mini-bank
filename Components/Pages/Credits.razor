@page "/credits"
@attribute [Authorize]
@inject BankService Bank
@inject NotificationService Notif

<div class="content-area" style="max-width: 800px;">
    <div class="page-header">
        <h3>Crédit</h3>
        <span class="page-header-badge">Simulation avec tableau d'amortissement</span>
    </div>

    @* ─── ÉLIGIBILITÉ ─── *@
    @if (!eligible)
    {
        <div class="credit-elig-banner">
            <div class="elig-icon">!</div>
            <div class="elig-content">
                <div class="elig-title">Critères non remplis</div>
                <ul class="elig-list">
                    <li class="@(Bank.Profil.Statut != UserStatus.STANDARD ? "pass" : "fail")">
                        Statut Premium ou VIP requis
                    </li>
                    <li class="@(nbTransactions >= 3 ? "pass" : "fail")">
                        Minimum 3 transactions validées (actuel : @nbTransactions)
                    </li>
                    <li class="elig-neutral">
                        Volume de flux : @((fluxTotal / 100m).ToString("N2")) DH (requis : 2x le montant du prêt)
                    </li>
                </ul>
            </div>
        </div>
    }

    @* ─── SIMULATEUR ─── *@
    <div class="form-section">
        <h6>Simulateur de crédit</h6>

        <div class="credit-categories">
            <button class="credit-cat-btn @(categorie == "MICRO" ? "selected" : "")" @onclick='() => ChoisirCategorie("MICRO")'>
                <span class="cat-icon">📋</span>
                <span class="cat-name">Micro-crédit</span>
                <span class="cat-rate">TAUX 5%</span>
            </button>
            <button class="credit-cat-btn @(categorie == "PERSONNEL" ? "selected" : "")" @onclick='() => ChoisirCategorie("PERSONNEL")'>
                <span class="cat-icon">👤</span>
                <span class="cat-name">Prêt personnel</span>
                <span class="cat-rate">TAUX 10%</span>
            </button>
            <button class="credit-cat-btn @(categorie == "BUSINESS" ? "selected" : "")" @onclick='() => ChoisirCategorie("BUSINESS")'>
                <span class="cat-icon">💼</span>
                <span class="cat-name">Prêt business</span>
                <span class="cat-rate">TAUX 15%</span>
            </button>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Montant souhaité (DH)</label>
                <input type="number" @bind="montantDemande" @bind:event="oninput" class="form-input" min="0" placeholder="Ex: 10000" />
            </div>
            <div class="form-group">
                <label>Durée (mois)</label>
                <select @bind="dureeMois" class="form-select">
                    <option value="3">3 mois</option>
                    <option value="6">6 mois</option>
                    <option value="9">9 mois</option>
                    <option value="12">12 mois</option>
                    <option value="18">18 mois</option>
                    <option value="24">24 mois</option>
                </select>
            </div>
        </div>
    </div>

    @* ─── RÉSULTATS SIMULATION (AMORTISSEMENT FRANÇAIS) ─── *@
    @if (montantDemande > 0)
    {
        var tauxMensuel = TauxMensuel();
        var mensualite = CalculerMensualite();

        <div class="credit-result-grid">
            <div class="credit-result-item">
                <div class="cri-label">Montant du prêt</div>
                <div class="cri-value">@montantDemande.ToString("N2") DH</div>
            </div>
            <div class="credit-result-item">
                <div class="cri-label">Mensualité fixe</div>
                <div class="cri-value positive">@mensualite.ToString("N2") DH</div>
                <div class="cri-sub">sur @dureeMois mois (amort. français)</div>
            </div>
            <div class="credit-result-item">
                <div class="cri-label">TAE</div>
                <div class="cri-value">@(Math.Round(tauxMensuel * 12 * 100, 2))%</div>
            </div>
        </div>

        var interetsTotal = 0m;
        var amortTotal = 0m;

        @* ─── SCORING ─── *@
        <div class="credit-score-card" style="border-left-color: @scoreCouleur;">
            <div class="score-top">
                <div>
                    <div class="score-label">Score de solvabilité</div>
                    <div class="score-points" style="color: @scoreCouleur;">@scorePoints / 100</div>
                </div>
                <span class="badge" style="background: @scoreCouleur; color: white;">@scoreLabel</span>
            </div>
            <div class="score-details">@scoreDetails</div>
        </div>

        @* ─── TABLEAU D'AMORTISSEMENT FRANÇAIS ─── *@
        <div class="credit-table-wrap">
            <div class="credit-table-scroll">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Mois</th>
                            <th>Mensualité</th>
                            <th>Intérêts</th>
                            <th>Capital remboursé</th>
                            <th>Capital restant</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var soldeRestant = montantDemande;
                        }
                        @for (int m = 1; m <= dureeMois; m++)
                        {
                            var interetMois = soldeRestant * tauxMensuel;
                            var amortMois = mensualite - interetMois;
                            if (m == dureeMois) amortMois = soldeRestant; // dernier mois : ajustement
                            soldeRestant -= amortMois;
                            if (soldeRestant < 0.005m) soldeRestant = 0;
                            interetsTotal += interetMois;
                            amortTotal += amortMois;
                            <tr>
                                <td>@m</td>
                                <td>@((interetMois + amortMois).ToString("N2"))</td>
                                <td>@interetMois.ToString("N2")</td>
                                <td>@amortMois.ToString("N2")</td>
                                <td>@soldeRestant.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th>Total</th>
                            <th>@((interetsTotal + amortTotal).ToString("N2"))</th>
                            <th>@interetsTotal.ToString("N2")</th>
                            <th>@amortTotal.ToString("N2")</th>
                            <th>0.00</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }

    @* ─── SOUMISSION ─── *@
    <button class="btn btn-primary btn-block"
            @onclick="SoumettreDemande"
            disabled="@(isProcessing || !eligible || montantDemande <= 0 || nbTransactions < 3)">
        @(isProcessing ? "Traitement en cours..." : "Soumettre la demande")
    </button>
</div>

@code {
    private void ChoisirCategorie(string cat)
    {
        categorie = cat;
    }

    private string categorie = "MICRO";
    private decimal montantDemande;
    private int dureeMois = 6;
    private bool eligible;
    private int nbTransactions;
    private long fluxTotal;  // centimes (ADR-001)
    private bool isProcessing;

    // Scoring
    private int scorePoints;
    private string scoreLabel = "";
    private string scoreCouleur = "";
    private string scoreDetails = "";

    protected override async Task OnInitializedAsync()
    {
        await VerifierConditions();
    }

    private async Task VerifierConditions()
    {
        var historique = await Bank.GetHistoriqueAsync();
        nbTransactions = historique.Count;
        fluxTotal = historique.Sum(t => t.MontantBrut);
        eligible = await Bank.VerifierEligibiliteCredit(Bank.Profil.Id);
        CalculerScore();
    }

    private void CalculerScore()
    {
        int points = 0;
        var reasons = new List<string>();

        if (Bank.Profil.Statut == UserStatus.VIP) { points += 30; reasons.Add("VIP: +30"); }
        else if (Bank.Profil.Statut == UserStatus.PREMIUM) { points += 20; reasons.Add("Premium: +20"); }
        else if (Bank.Profil.Statut == UserStatus.STANDARD) { points += 5; reasons.Add("Standard: +5"); }

        points += Math.Min(nbTransactions * 5, 25);
        if (nbTransactions >= 10) reasons.Add("Activité élevée: +25");
        else if (nbTransactions >= 5) reasons.Add($"Activité ({nbTransactions} tx): +{nbTransactions * 5}");
        else reasons.Add($"Activité ({nbTransactions} tx): +{nbTransactions * 5}");

        if (fluxTotal > 5_000_000L) { points += 25; reasons.Add("Flux > 50k: +25"); }
        else if (fluxTotal > 1_000_000L) { points += 15; reasons.Add("Flux > 10k: +15"); }
        else if (fluxTotal > 100_000L) { points += 5; reasons.Add("Flux > 1k: +5"); }

        if (Bank.Profil.DateInscription < DateTime.UtcNow.AddDays(-30)) { points += 10; reasons.Add("Ancienneté: +10"); }
        else { points += 3; reasons.Add("Compte récent: +3"); }

        if (Bank.Profil.Solde > 1_000_000L) { points += 10; reasons.Add("Solde élevé: +10"); }

        scorePoints = Math.Min(points, 100);

        if (scorePoints >= 80) { scoreLabel = "EXCELLENT"; scoreCouleur = "var(--success)"; }
        else if (scorePoints >= 60) { scoreLabel = "BON"; scoreCouleur = "var(--blue-500)"; }
        else if (scorePoints >= 40) { scoreLabel = "MOYEN"; scoreCouleur = "var(--gold-400)"; }
        else { scoreLabel = "FAIBLE"; scoreCouleur = "var(--danger)"; }

        scoreDetails = string.Join(" · ", reasons);
    }

    private decimal TauxMensuel()
    {
        decimal tauxAnnuel = categorie switch
        {
            "MICRO" => 0.05m,
            "PERSONNEL" => 0.10m,
            "BUSINESS" => 0.15m,
            _ => 0.10m
        };
        if (Bank.Profil.Statut == UserStatus.VIP) tauxAnnuel -= 0.03m;
        else if (Bank.Profil.Statut == UserStatus.PREMIUM) tauxAnnuel -= 0.015m;
        return tauxAnnuel / 12m;
    }

    private decimal CalculerMensualite()
    {
        if (montantDemande <= 0 || dureeMois <= 0) return 0;
        var r = TauxMensuel();
        if (r == 0) return montantDemande / dureeMois;
        var unPlusR = 1m + r;
        var denom = (decimal)(Math.Pow((double)unPlusR, dureeMois) - 1d);
        return denom == 0 ? montantDemande / dureeMois : montantDemande * r * (decimal)Math.Pow((double)unPlusR, dureeMois) / denom;
    }

    private async Task SoumettreDemande()
    {
        if (isProcessing || montantDemande <= 0) return;
        if (fluxTotal < (long)(montantDemande * 2 * 100))
        {
            Notif.Notify("Volume de transactions insuffisant (2x requis)", NotificationType.ERROR);
            return;
        }
        isProcessing = true;
        try
        {
            var success = await Bank.SoumettreDemandeCredit((long)(montantDemande * 100), categorie, dureeMois);
            if (success)
            {
                Notif.Notify("Demande transmise - En attente de validation par l'administrateur", NotificationType.INFO);
                montantDemande = 0;
            }
            else
                Notif.Notify("Erreur lors de l'enregistrement de la demande", NotificationType.ERROR);
        }
        finally { isProcessing = false; }
    }
}
