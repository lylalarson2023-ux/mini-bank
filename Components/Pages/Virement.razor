@page "/virement"
@attribute [Authorize]
@implements IDisposable
@inject BankService Bank
@inject NotificationService Notif
@inject NavigationManager Nav

<div class="cyber-panel" style="max-width: 560px;">
    <h3>MODULE DE VIREMENT</h3>

    <div class="warning-box">
        SOLDE DISPONIBLE : <span class="highlight">@((Bank.Profil.Solde / 100m).ToString("N2")) DH</span>
        @if (Bank.Profil.PlafondJournalier > 0)
        {
            <span style="display: block; font-size: 0.7rem; margin-top: 4px; color: var(--text-muted);">
                Plafond journalier : @((Bank.Profil.PlafondJournalier / 100m).ToString("N0")) DH
                | Utilisé : @((Bank.Profil.MontantJournalierUtilise / 100m).ToString("N0")) DH
            </span>
        }
    </div>

    @if (step == Step.Success)
    {
        <div class="depot-success">
            <div class="success-check">
                <svg viewBox="0 0 52 52" class="checkmark-svg">
                    <circle cx="26" cy="26" r="25" fill="none" class="checkmark-circle" />
                    <path fill="none" d="M14 27l7 7 16-16" class="checkmark-check" />
                </svg>
            </div>
            <div class="depot-success-text">VIREMENT EFFECTUÉ</div>
            <div class="depot-success-sub">@montantVire.ToString("N2") DH</div>
        </div>
    }
    else if (step == Step.Processing)
    {
        <div class="depot-loading">
            <div class="depot-spinner"></div>
            <div class="depot-loading-text">TRAITEMENT EN COURS...</div>
        </div>
    }
    else if (step == Step.Confirm)
    {
        <div style="margin-top: 24px;">
            <div style="border-left: 4px solid var(--primary); background: var(--bg-secondary);
                        border-radius: 10px; padding: 20px; margin-bottom: 20px;">
                <div style="font-size: 0.65rem; letter-spacing: 1.5px; color: var(--text-muted); margin-bottom: 14px;">
                    RÉCAPITULATIF DU VIREMENT
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                    <span style="font-size: 0.75rem; color: var(--text-muted);">DESTINATAIRE</span>
                    <span style="font-weight: 700; font-size: 0.9rem;">
                        @if (!string.IsNullOrEmpty(nomDestinataire))
                        {
                            <span>@nomDestinataire</span>
                            <span style="display: block; font-size: 0.7rem; font-weight: 400; color: var(--text-muted);">@destinataire</span>
                        }
                        else
                        {
                            @destinataire
                        }
                    </span>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                    <span style="font-size: 0.75rem; color: var(--text-muted);">MONTANT</span>
                    <span style="font-weight: 800; font-size: 1.5rem; color: var(--danger);">
                        -@((montant ?? 0).ToString("N2")) <span style="font-size: 0.8rem;">DH</span>
                    </span>
                </div>

                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                    <span style="font-size: 0.75rem; color: var(--text-muted);">FRAIS DE VIREMENT</span>
                    @if (frais > 0)
                    {
                        <span style="font-weight: 700; font-size: 0.9rem;">-@((frais / 100m).ToString("N2")) DH</span>
                    }
                    else
                    {
                        <span style="font-weight: 700; font-size: 0.8rem; color: var(--success);">
                            <i class="bi bi-check-circle-fill"></i> GRATUIT
                        </span>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(motif))
                {
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                        <span style="font-size: 0.75rem; color: var(--text-muted);">MOTIF</span>
                        <span style="font-size: 0.85rem;">@motif</span>
                    </div>
                }

                <div style="border-top: 1px solid var(--border-color); margin-top: 8px; padding-top: 12px;
                            display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 0.75rem; color: var(--text-muted);">SOLDE APRÈS</span>
                    <span style="font-weight: 700; color: @(soldeApres >= 0 ? "var(--success)" : "var(--danger)");">
                        @((soldeApres / 100m).ToString("N2")) DH
                    </span>
                </div>
            </div>

            <div class="form-row">
                <button class="btn btn-block" style="background: var(--bg-secondary); color: var(--text-muted);
                        border: 1px solid var(--border-color);" @onclick="() => step = Step.Form">
                    <i class="bi bi-arrow-left"></i> MODIFIER
                </button>
                <button class="btn btn-primary btn-block" @onclick="EffectuerVirement">
                    <i class="bi bi-check-lg"></i> CONFIRMER
                </button>
            </div>
        </div>
    }
    else
    {
        <div style="margin-top: 24px;">
            @if (beneficiaires.Any())
            {
                <div class="form-group">
                    <label>BENEFICIAIRE RAPIDE</label>
                    <select class="form-select" @onchange="SelectBeneficiaire">
                        <option value="">-- Choisir un bénéficiaire --</option>
                        @foreach (var b in beneficiaires)
                        {
                            <option value="@b.Email">@b.Nom - @b.Email</option>
                        }
                    </select>
                </div>
            }

            <div class="form-group">
                <label>DESTINATAIRE (EMAIL)</label>
                <input type="email" @bind="destinataire" @bind:event="oninput" @bind:after="OnDestinataireChanged" class="form-input" placeholder="email@adnpay.ma" />
                @if (recipientChecked && !string.IsNullOrEmpty(nomDestinataire))
                {
                    <div style="font-size: 0.72rem; margin-top: 6px; color: var(--success); font-weight: 600;">
                        <i class="bi bi-check-circle-fill"></i> @nomDestinataire
                    </div>
                    @if (!DejaFavori)
                    {
                        <label style="display: flex; align-items: center; gap: 8px; margin-top: 8px; font-size: 0.72rem; color: var(--text-muted);">
                            <input type="checkbox" @bind="saveAsFavorite" /> Enregistrer ce contact en favori
                        </label>
                    }
                }
                else if (recipientChecked && !string.IsNullOrWhiteSpace(destinataire))
                {
                    <div style="font-size: 0.72rem; margin-top: 6px; color: var(--warning);">
                        <i class="bi bi-exclamation-triangle-fill"></i> Aucun compte ADN_pay à cette adresse
                    </div>
                }
            </div>

            <div class="form-group">
                <label>MONTANT (DH)</label>
                <input type="number" @bind="montant" class="form-input" placeholder="0.00" />
            </div>

            <div class="form-group">
                <label>MOTIF (OPTIONNEL)</label>
                <input type="text" @bind="motif" class="form-input" placeholder="Ex: Remboursement" />
            </div>

            @if (!string.IsNullOrEmpty(erreur))
            {
                <div class="error-box" style="margin-bottom: 12px;">@erreur</div>
            }

            <button class="btn btn-primary btn-block" @onclick="AllerConfirmation"
                    disabled="@(string.IsNullOrWhiteSpace(destinataire) || montant is null or <= 0)">
                <i class="bi bi-arrow-right"></i> CONTINUER
            </button>
        </div>
    }

    <div style="margin-top: 24px; display: flex; justify-content: space-between;">
        <a href="/parametres" style="color: var(--text-muted); font-size: 0.75rem;">Gérer mes bénéficiaires</a>
        <a href="/" style="color: var(--text-muted); font-size: 0.8rem; font-weight: 600;">&larr; RETOUR</a>
    </div>
</div>

@code {
    private enum Step { Form, Confirm, Processing, Success }
    private Step step = Step.Form;

    private string destinataire = "";
    private string nomDestinataire = "";
    private bool recipientChecked;
    private bool saveAsFavorite;
    private decimal? montant;
    private decimal montantVire;
    private string motif = "";
    private string erreur = "";
    private long soldeApres;
    private long frais;
    private List<Beneficiaire> beneficiaires = new();

    private bool DejaFavori => beneficiaires.Any(b => string.Equals(b.Email, destinataire?.Trim(), StringComparison.OrdinalIgnoreCase));

    // Retardateur : la recherche du destinataire (appel serveur) n'est lancée
    // qu'après une courte pause de frappe, pas à chaque caractère saisi.
    private readonly Debouncer _lookupDebouncer = new();

    private async Task OnDestinataireChanged()
    {
        await _lookupDebouncer.DebounceAsync(400, async () =>
        {
            await LookupRecipient();
            await InvokeAsync(StateHasChanged);
        });
    }

    public void Dispose() => _lookupDebouncer.Dispose();

    private async Task LookupRecipient()
    {
        nomDestinataire = "";
        recipientChecked = false;
        saveAsFavorite = false;
        var e = destinataire?.Trim() ?? "";
        if (e.Length < 3 || !e.Contains('@')) return;
        nomDestinataire = await Bank.TrouverNomDestinataireAsync(e) ?? "";
        recipientChecked = true;
    }

    protected override async Task OnInitializedAsync()
    {
        try { beneficiaires = await Bank.GetBeneficiairesAsync(); } catch { }
    }

    private void SelectBeneficiaire(ChangeEventArgs e)
    {
        var email = e.Value?.ToString();
        if (string.IsNullOrEmpty(email)) return;
        destinataire = email;
        var b = beneficiaires.FirstOrDefault(x => x.Email == email);
        if (b != null)
        {
            nomDestinataire = b.Nom;
            recipientChecked = true;
            saveAsFavorite = false;
            if (string.IsNullOrEmpty(motif)) motif = $"Virement à {b.Nom}";
        }
    }

    private void AllerConfirmation()
    {
        erreur = "";
        var montantCentimes = (long)((montant ?? 0) * 100);

        if (montantCentimes <= 0) { erreur = "Montant invalide."; return; }

        frais = FraisVirement.Calculer(montantCentimes, Bank.Profil.Statut);
        var totalDebit = montantCentimes + frais;
        if (Bank.Profil.Solde < totalDebit) { erreur = "Solde insuffisant."; return; }

        var (allow, msg) = Bank.VerifierPlafond(montantCentimes);
        if (!allow) { erreur = msg; return; }

        // Résoudre le nom si non déjà fait (saisie manuelle)
        if (string.IsNullOrEmpty(nomDestinataire))
        {
            var b = beneficiaires.FirstOrDefault(x => x.Email == destinataire.Trim().ToLower());
            nomDestinataire = b?.Nom ?? "";
        }

        soldeApres = Bank.Profil.Solde - totalDebit;
        step = Step.Confirm;
    }

    private async Task EffectuerVirement()
    {
        step = Step.Processing;
        montantVire = montant ?? 0;
        try
        {
            var montantCentimes = (long)((montant ?? 0) * 100);
            var success = await Bank.EffectuerVirementAsync(destinataire.Trim(), montantCentimes, motif);
            if (success)
            {
                // Enregistrement en favori si demandé (et pas déjà présent).
                if (saveAsFavorite && !string.IsNullOrEmpty(nomDestinataire) && !DejaFavori)
                {
                    try { await Bank.AjouterBeneficiaireAsync(nomDestinataire, destinataire.Trim(), null, null); } catch { }
                }
                step = Step.Success;
                await Task.Delay(2000);
                Nav.NavigateTo("/", forceLoad: true);
            }
            else
            {
                Notif.Notify("DESTINATAIRE INTROUVABLE OU FONDS INSUFFISANTS", NotificationType.ERROR);
                step = Step.Form;
            }
        }
        catch
        {
            Notif.Notify("UNE ERREUR EST SURVENUE", NotificationType.ERROR);
            step = Step.Form;
        }
    }
}
