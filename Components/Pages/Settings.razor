    private string Truncate(string s, int max) => s?.Length > max ? s[..max] + "..." : s ?? "";

    // Jauge de force du mot de passe (identique à l'inscription)
    private int PwdScore
    {
        get
        {
            var p = passwordModel.NewPassword ?? "";
            int s = 0;
            if (p.Length >= 8) s++;
            if (p.Any(char.IsUpper)) s++;
            if (p.Any(char.IsLower)) s++;
            if (p.Any(char.IsDigit)) s++;
            if (p.Any(c => !char.IsLetterOrDigit(c))) s++;
            return s;
        }
    }
    private string PwdColor => PwdScore switch { <= 2 => "var(--danger)", 3 => "var(--warning)", 4 => "var(--blue-500)", _ => "var(--success)" };
    private string PwdLabel => PwdScore switch { <= 2 => "Faible", 3 => "Moyen", 4 => "Bon", _ => "Fort" };

    private static readonly Regex EmailRegex = new(@"^[^@\s]+@[^@\s]+\.[^@\s]+$", RegexOptions.Compiled);
    private static readonly Regex PhoneRegex = new(@"^(?:\+212|0)[5-7][0-9]{8}$", RegexOptions.Compiled);

