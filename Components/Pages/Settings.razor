    private void StartTwoFactorSetup()
    {
        showTwoFactorSetup = true;
        twoFactorSecret = Bank.GenerateTwoFactorSecret();
        twoFactorQrUri = Bank.GenerateTwoFactorQrUri(twoFactorSecret, Bank.Profil.Email);
        twoFactorSetupCode = "";
        twoFactorMsg = "";
    }

    private void CancelTwoFactorSetup()
    {
        showTwoFactorSetup = false;
        twoFactorSecret = "";
        twoFactorQrUri = "";
        twoFactorSetupCode = "";
    }

    private async Task ConfirmTwoFactorSetup()
    {
        if (string.IsNullOrEmpty(twoFactorSetupCode) || twoFactorSetupCode.Length != 6) return;
        saving = true;
        twoFactorMsg = "";
        twoFactorSuccess = false;
        try
        {
            Bank.Profil.TwoFactorSecret = twoFactorSecret;
            var (success, msg, codes) = await Bank.EnableTwoFactorAsync(twoFactorSetupCode);
            twoFactorMsg = msg;
            twoFactorSuccess = success;
            if (success)
            {
                showTwoFactorSetup = false;
                recoveryCodes = codes;
            }
        }
        catch { twoFactorMsg = "Erreur technique"; }
        finally { saving = false; }
    }

    private async Task DisableTwoFactor()
    {
        saving = true;
        twoFactorMsg = "";
        try
        {
            await Bank.DisableTwoFactorAsync();
            recoveryCodes = new();
            twoFactorMsg = "2FA désactivée.";
            twoFactorSuccess = true;
        }
        catch { twoFactorMsg = "Erreur technique"; }
        finally { saving = false; }
    }

    private async Task RegenerateRecoveryCodes()
    {
        saving = true; twoFactorMsg = "";
        try
        {
            recoveryCodes = await Bank.RegenerateRecoveryCodesAsync();
            twoFactorSuccess = true;
            twoFactorMsg = "Nouveaux codes générés. Les anciens ne sont plus valides.";
        }
        catch { twoFactorMsg = "Erreur technique"; }
        finally { saving = false; }
    }

    private void DismissRecoveryCodes() => recoveryCodes = new();

