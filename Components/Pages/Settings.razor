@page "/parametres"
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Forms
@using System.Text.Json
@using System.Text.RegularExpressions
@inject BankService Bank
@inject NotificationService Notif
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="cyber-panel" style="max-width: 900px; margin: auto;">
    <div class="admin-tabs">
        <button class='admin-tab @(activeTab == "profile" ? "active" : "")' @onclick="GoProfile">
            <i class="bi bi-person-gear"></i> PROFIL
        </button>
        <button class='admin-tab @(activeTab == "password" ? "active" : "")' @onclick="GoPassword">
            <i class="bi bi-shield-lock"></i> MOT DE PASSE
        </button>
        <button class='admin-tab @(activeTab == "security" ? "active" : "")' @onclick="GoSecurity">
            <i class="bi bi-shield-lock-fill"></i> SÉCURITÉ
        </button>
        <button class='admin-tab @(activeTab == "legal" ? "active" : "")' @onclick="GoLegal">
            <i class="bi bi-incognito"></i> LÉGAL
        </button>
        <button class='admin-tab @(activeTab == "connexions" ? "active" : "")' @onclick="GoConnexions">
            <i class="bi bi-clock-history"></i> CONNEXIONS
        </button>
        <button class='admin-tab @(activeTab == "plafonds" ? "active" : "")' @onclick="GoPlafonds">
            <i class="bi bi-sliders"></i> PLAFONDS
        </button>
        <button class='admin-tab @(activeTab == "notifs" ? "active" : "")' @onclick="GoNotifs">
            <i class="bi bi-sliders2"></i> PRÉFÉRENCES
        </button>
    </div>

    @if (activeTab == "profile")
    {
        <div class="form-section">
            <h6><i class="bi bi-person-gear"></i> INFORMATIONS PERSONNELLES</h6>
            <EditForm Model="@profileModel" OnValidSubmit="SaveProfile">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Nom</label>
                        <InputText @bind-Value="profileModel.Nom" class="form-input" placeholder="Votre nom" />
                    </div>
                    <div class="form-group">
                        <label>Prénom</label>
                        <InputText @bind-Value="profileModel.Prenom" class="form-input" placeholder="Votre prénom" />
                    </div>
                    <div class="form-group">
                        <label>Email</label>
                        <InputText @bind-Value="profileModel.Email" class="form-input" type="email" placeholder="email@exemple.com" />
                    </div>
                    <div class="form-group">
                        <label>Téléphone</label>
                        <InputText @bind-Value="profileModel.Telephone" class="form-input" placeholder="+212..." />
                    </div>
                </div>
                @if (EmailModifie)
                {
                    <div class="form-group full-width" style="margin-top: 4px;">
                        <label><i class="bi bi-shield-lock"></i> Mot de passe actuel (requis pour changer l'e-mail)</label>
                        <input @bind="emailChangePassword" type="password" class="form-input" placeholder="••••••••" />
                        <small style="color: var(--text-muted); font-size: 0.6rem; margin-top: 4px; display: block;">
                            L'e-mail sert d'identifiant de connexion : sa modification nécessite votre mot de passe.
                        </small>
                    </div>
                }
                <button type="submit" class="btn btn-primary" disabled="@saving">
                    @(saving ? "ENREGISTREMENT..." : "ENREGISTRER")
                </button>
            </EditForm>
            @if (!string.IsNullOrEmpty(profileMsg))
            {
                <div class="@(profileSuccess ? "status-banner success" : "status-banner error")" style="margin-top: 12px;">
                    @profileMsg
                </div>
            }
        </div>
    }

    @if (activeTab == "password")
    {
        <div class="form-section">
            <h6><i class="bi bi-shield-lock"></i> CHANGER LE MOT DE PASSE</h6>
            <EditForm Model="@passwordModel" OnValidSubmit="ChangePassword">
                <div class="form-grid">
                    <div class="form-group full-width">
                        <label>Mot de passe actuel</label>
                        <input @bind="passwordModel.CurrentPassword" class="form-input" type="password" placeholder="••••••••" />
                    </div>
                    <div class="form-group full-width">
                        <label>Nouveau mot de passe</label>
                        <input @bind="passwordModel.NewPassword" @bind:event="oninput" class="form-input" type="password" placeholder="••••••••" />
                        @if (!string.IsNullOrEmpty(passwordModel.NewPassword))
                        {
                            <div class="pwd-meter">
                                <div class="pwd-meter-track">
                                    <div class="pwd-meter-fill" style="width:@(PwdScore * 20)%; background:@PwdColor;"></div>
                                </div>
                                <span class="pwd-meter-label" style="color:@PwdColor;">@PwdLabel</span>
                            </div>
                        }
                        <small style="color: var(--text-muted); font-size: 0.6rem; margin-top: 4px; display: block;">8+ car., 1 majuscule, 1 minuscule, 1 chiffre, 1 caractère spécial (!@@#$%^&*)</small>
                    </div>
                    <div class="form-group full-width">
                        <label>Confirmer le nouveau mot de passe</label>
                        <input @bind="passwordModel.ConfirmPassword" @bind:event="oninput" class="form-input" type="password" placeholder="••••••••" />
                        @if (!string.IsNullOrEmpty(passwordModel.ConfirmPassword))
                        {
                            <small style="font-size:0.62rem; margin-top:6px; display:block; color:@(passwordModel.ConfirmPassword == passwordModel.NewPassword ? "var(--success)" : "var(--danger)");">
                                @(passwordModel.ConfirmPassword == passwordModel.NewPassword ? "✓ Les mots de passe correspondent" : "✗ Les mots de passe diffèrent")
                            </small>
                        }
                    </div>
                </div>
                <button type="submit" class="btn btn-primary" disabled="@saving">
                    @(saving ? "CHANGEMENT..." : "CHANGER LE MOT DE PASSE")
                </button>
            </EditForm>
            @if (!string.IsNullOrEmpty(pwdMsg))
            {
                <div class="@(pwdSuccess ? "status-banner success" : "status-banner error")" style="margin-top: 12px;">
                    @pwdMsg
                </div>
            }
        </div>
    }

    @if (activeTab == "security")
    {
        <div class="form-section">
            <h6><i class="bi bi-shield-lock-fill"></i> AUTHENTIFICATION À DEUX FACTEURS</h6>
            <p style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 16px;">
                Ajoutez une couche de sécurité supplémentaire avec Google Authenticator, Microsoft Authenticator ou Authy.
            </p>

            @if (recoveryCodes.Any())
            {
                <div style="background: rgba(48,184,128,0.06); border: 1px solid var(--success); border-radius: var(--radius-sm); padding: 16px; margin-bottom: 16px;">
                    <p style="font-size: 0.8rem; font-weight: 600; color: var(--success); margin: 0 0 8px;">
                        <i class="bi bi-key-fill"></i> VOS CODES DE SECOURS
                    </p>
                    <p style="font-size: 0.72rem; color: var(--text-muted); margin: 0 0 12px;">
                        Conservez-les en lieu sûr. Chaque code n'est utilisable <strong>qu'une seule fois</strong> pour vous connecter
                        si vous perdez l'accès à votre application. Ils ne seront <strong>plus jamais affichés</strong>.
                    </p>
                    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 6px; font-family: var(--font-mono); font-size: 0.85rem; letter-spacing: 1px; margin-bottom: 12px;">
                        @foreach (var c in recoveryCodes)
                        {
                            <div style="background: var(--bg-secondary); padding: 6px 10px; border-radius: 4px; text-align: center;">@c</div>
                        }
                    </div>
                    <button class="btn btn-primary btn-sm" @onclick="DismissRecoveryCodes">
                        <i class="bi bi-check2"></i> J'AI NOTÉ MES CODES
                    </button>
                </div>
            }

            @if (!Bank.Profil.TwoFactorEnabled)
            {
                @if (!showTwoFactorSetup)
                {
                    <button class="btn btn-primary" @onclick="StartTwoFactorSetup" disabled="@saving">
                        @(saving ? "..." : "ACTIVER LA 2FA")
                    </button>
                }
                else
                {
                    <div style="background: rgba(59,130,246,0.05); border: 1px solid var(--blue-border); border-radius: var(--radius-sm); padding: 20px; margin-bottom: 16px;">
                        <p style="font-size: 0.8rem; margin-bottom: 12px; color: var(--text-secondary);">
                            1. Scannez le QR code avec votre application d'authentification
                        </p>

                        @if (!string.IsNullOrEmpty(twoFactorQrUri))
                        {
                            <div style="text-align: center; margin-bottom: 16px;">
                                <img src="https://chart.googleapis.com/chart?chs=200x200&cht=qr&chl=@Uri.EscapeDataString(twoFactorQrUri)&choe=UTF-8"
                                     alt="QR Code 2FA" style="border-radius: var(--radius-sm); background: white; padding: 8px;" />
                            </div>
                            <p style="font-size: 0.75rem; text-align: center; margin-bottom: 12px; color: var(--text-muted);">
                                Ou saisissez manuellement la clé :
                                <code style="display: block; margin-top: 4px; font-size: 0.8rem; letter-spacing: 2px; color: var(--blue-500);">@twoFactorSecret</code>
                            </p>
                        }

                        <div class="form-group" style="margin-bottom: 0;">
                            <label>2. Saisissez le code à 6 chiffres</label>
                            <input type="text" @bind="twoFactorSetupCode" maxlength="6" class="form-input" placeholder="000000" style="text-align: center; font-size: 1.2rem; letter-spacing: 6px; font-family: var(--font-mono);" />
                        </div>
                    </div>

                    <div style="display: flex; gap: 8px;">
                        <button class="btn btn-primary" @onclick="ConfirmTwoFactorSetup" disabled="@saving || string.IsNullOrEmpty(twoFactorSetupCode) || twoFactorSetupCode.Length != 6">
                            @(saving ? "VÉRIFICATION..." : "CONFIRMER")
                        </button>
                        <button class="btn btn-ghost" @onclick="CancelTwoFactorSetup">ANNULER</button>
                    </div>
                }
            }
            else
            {
                <div class="setting-row">
                    <div>
                        <span class="badge badge-success"><i class="bi bi-shield-check"></i> 2FA ACTIVE</span>
                        <p style="color: var(--text-muted); font-size: 0.75rem; margin: 8px 0 0;">
                            Vos identifiants sont protégés par l'authentification à deux facteurs.
                        </p>
                    </div>
                    <button class="btn btn-danger btn-sm" @onclick="DisableTwoFactor" disabled="@saving">
                        @(saving ? "..." : "DÉSACTIVER")
                    </button>
                </div>
                <div class="setting-row">
                    <div>
                        <strong style="color: var(--text-primary);">Codes de secours</strong>
                        <p style="color: var(--text-muted); font-size: 0.75rem; margin: 4px 0 0;">
                            @Bank.CountRemainingRecoveryCodes() code(s) restant(s). Régénérer invalide les anciens.
                        </p>
                    </div>
                    <button class="btn btn-ghost btn-sm" @onclick="RegenerateRecoveryCodes" disabled="@saving">
                        @(saving ? "..." : "RÉGÉNÉRER")
                    </button>
                </div>
            }

            @if (!string.IsNullOrEmpty(twoFactorMsg))
            {
                <div class="@(twoFactorSuccess ? "status-banner success" : "status-banner error")" style="margin-top: 12px;">
                    @twoFactorMsg
                </div>
            }
        </div>
    }

    @if (activeTab == "legal")
    {
        <div class="form-section">
            <h6><i class="bi bi-incognito"></i> CONFIDENTIALITE</h6>
            <p style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 16px;">
                Conformément à la Loi 09-08 et au RGPD : gérez vos données personnelles et vos préférences.
            </p>

            <div class="setting-row">
                <div>
                    <strong style="color: var(--text-primary);">Tuteur</strong>
                    <p style="color: var(--text-muted); font-size: 0.75rem; margin: 4px 0 0;">
                        @if (!string.IsNullOrEmpty(Bank.Profil.TuteurEmail))
                        {
                            <span>Tuteur actuel : <strong>@Bank.Profil.TuteurEmail</strong></span>
                        }
                        else
                        {
                            <span>Aucun tuteur défini</span>
                        }
                    </p>
                </div>
                <button class="btn btn-ghost btn-sm" @onclick="ToggleTuteur">
                    @(Bank.Profil.TuteurAutorise ? "REVOQUER" : "CONFIGURER")
                </button>
            </div>

            @if (showTuteurInput)
            {
                <div class="form-group" style="margin-top: 12px;">
                    <label>Email du tuteur</label>
                    <input type="email" @bind="tuteurEmail" class="form-input" placeholder="email@tuteur.com" />
                    <button class="btn btn-primary btn-sm" @onclick="SaveTuteur" style="margin-top: 8px;" disabled="@saving">VALIDER</button>
                </div>
            }
        </div>

        <div class="form-section">
            <h6><i class="bi bi-download"></i> EXPORT DE DONNEES</h6>
            <p style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 16px;">
                Téléchargez l'ensemble de vos données personnelles conformément au droit d'accès et de portabilité (Loi 09-08, art. 4-4).
            </p>
            <button class="btn btn-primary" @onclick="ExportData" disabled="@saving">
                @(saving ? "EXPORT EN COURS..." : "EXPORTER MES DONNEES")
            </button>
            @if (!string.IsNullOrEmpty(exportMsg))
            {
                <div class="@(exportSuccess ? "status-banner success" : "status-banner error")" style="margin-top: 12px;">
                    @exportMsg
                </div>
            }
        </div>

        <div class="form-section" style="border-color: var(--danger);">
            <h6 style="color: var(--danger);"><i class="bi bi-trash"></i> CLÔTURE DE COMPTE</h6>
            <p style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 16px;">
                La clôture anonymise définitivement vos données personnelles (droit à l'effacement — Loi 09-08, art. 4-5).
                Conformément à la réglementation anti-blanchiment (loi 43-05), l'historique de vos transactions est
                <strong>conservé sous forme anonymisée</strong> pendant la durée légale de rétention.
                Cette action est <strong style="color: var(--danger);">irréversible</strong>.
            </p>

            @if (!PeutCloturer)
            {
                <div class="status-banner error">
                    <i class="bi bi-exclamation-triangle"></i> Clôture impossible tant que :
                    <ul style="margin: 8px 0 0; padding-left: 18px;">
                        @if (Bank.Profil.Solde > 0)
                        {
                            <li>votre solde n'est pas nul (@((Bank.Profil.Solde / 100m).ToString("N2")) DH à retirer)</li>
                        }
                        @if (epargneTotale > 0)
                        {
                            <li>vos poches d'épargne ne sont pas vidées (@((epargneTotale / 100m).ToString("N2")) DH)</li>
                        }
                        @if (Bank.Profil.Dette > 0)
                        {
                            <li>votre crédit n'est pas remboursé (@((Bank.Profil.Dette / 100m).ToString("N2")) DH)</li>
                        }
                    </ul>
                </div>
            }
            else if (showDeleteConfirm)
            {
                <div style="background: var(--danger-bg); border: 1px solid var(--danger); border-radius: var(--radius-sm); padding: 16px; margin-bottom: 12px;">
                    <p style="color: var(--text-primary); font-size: 0.8rem; margin-bottom: 12px;">
                        <i class="bi bi-exclamation-triangle"></i>
                        Pour confirmer, tapez <strong>SUPPRIMER</strong> ci-dessous. Vous serez déconnecté immédiatement.
                    </p>
                    <input @bind="deleteConfirmText" @bind:event="oninput" class="form-input" placeholder="SUPPRIMER" style="margin-bottom: 12px;" />
                    <div style="display: flex; gap: 8px;">
                        <button class="btn btn-danger btn-sm" @onclick="ConfirmDelete"
                                disabled="@(saving || deleteConfirmText.Trim().ToUpperInvariant() != "SUPPRIMER")">
                            @(saving ? "CLÔTURE..." : "CONFIRMER LA CLÔTURE")
                        </button>
                        <button class="btn btn-ghost btn-sm" @onclick="CancelDelete">ANNULER</button>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(deleteMsg))
                {
                    <div class="@(deleteSuccess ? "status-banner success" : "status-banner error")">
                        @deleteMsg
                    </div>
                }
            }
            else
            {
                <button class="btn btn-danger" @onclick="() => showDeleteConfirm = true">
                    <i class="bi bi-trash"></i> CLÔTURER MON COMPTE
                </button>
            }
        </div>

        <div class="form-section">
            <h6><i class="bi bi-file-earmark-text"></i> MENTIONS LEGALES</h6>
            <p style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 16px;">
                Consultez les documents légaux et réglementaires d'ADN_pay.
            </p>
            <div class="legal-links" style="display: flex; flex-direction: column; gap: 8px;">
                <a href="/cgu" target="_blank" class="btn btn-ghost" style="justify-content: flex-start;">
                    <i class="bi bi-file-earmark-text"></i> Conditions Générales d'Utilisation
                </a>
                <a href="/confidentialite" target="_blank" class="btn btn-ghost" style="justify-content: flex-start;">
                    <i class="bi bi-shield-check"></i> Politique de Confidentialité
                </a>
                <a href="/mentions-legales" target="_blank" class="btn btn-ghost" style="justify-content: flex-start;">
                    <i class="bi bi-info-circle"></i> Mentions Légales
                </a>
            </div>
        </div>
    }

    @if (activeTab == "connexions")
    {
        <div class="form-section">
            <h6><i class="bi bi-clock-history"></i> HISTORIQUE DES CONNEXIONS</h6>
            <p style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 16px;">
                Dernières connexions à votre compte. En cas d'activité suspecte, révoquez toutes les sessions.
            </p>
            @if (!loginHistory.Any())
            {
                <div class="empty-state"><p>Aucune connexion enregistrée</p></div>
            }
            else
            {
                <div style="overflow-x: auto;">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>DATE</th>
                                <th>ADRESSE IP</th>
                                <th>NAVIGATEUR</th>
                                <th>STATUT</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var l in loginHistory)
                            {
                                <tr>
                                    <td style="font-size: 0.75rem;">@l.Date.ToString("dd/MM/yy HH:mm")</td>
                                    <td style="font-size: 0.75rem; color: var(--text-muted);">@l.IpAddress</td>
                                    <td style="font-size: 0.65rem; color: var(--text-muted); max-width: 200px; overflow: hidden; text-overflow: ellipsis;">@Truncate(l.UserAgent, 60)</td>
                                    <td>
                                        <span class="badge @(l.Success ? "badge-success" : "badge-danger")">
                                            @(l.Success ? "OK" : "ÉCHEC")
                                        </span>
                                        @if (!l.Success && !string.IsNullOrEmpty(l.FailureReason))
                                        {
                                            <span style="font-size: 0.65rem; color: var(--text-muted); display: block;">@l.FailureReason</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            <div style="margin-top: 16px;">
                <button class="btn btn-danger btn-sm" @onclick="HandleRevokeSessions">
                    <i class="bi bi-shield-exclamation"></i> REVOQUER TOUTES LES SESSIONS
                </button>
            </div>
        </div>
    }

    @if (activeTab == "plafonds")
    {
        <div class="form-section">
            <h6><i class="bi bi-sliders"></i> PLAFONDS DE TRANSACTIONS</h6>
            <p style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 16px;">
                Limites maximales de vos transactions. Réinitialisées automatiquement chaque jour/mois.
            </p>
            <div class="form-grid">
                <div class="form-group">
                    <label>Plafond journalier (DH)</label>
                    <input type="number" @bind="plafondJournalier" class="form-input" placeholder="5000" />
                </div>
                <div class="form-group">
                    <label>Plafond mensuel (DH)</label>
                    <input type="number" @bind="plafondMensuel" class="form-input" placeholder="50000" />
                </div>
            </div>
            <button class="btn btn-primary" @onclick="SavePlafonds" disabled="@saving">
                @(saving ? "ENREGISTREMENT..." : "ENREGISTRER")
            </button>
            @if (!string.IsNullOrEmpty(plafondMsg))
            {
                <div class="@(plafondSuccess ? "status-banner success" : "status-banner error")" style="margin-top: 12px;">
                    @plafondMsg
                </div>
            }
        </div>
    }

    @if (activeTab == "notifs")
    {
        <div class="form-section">
            <h6><i class="bi bi-palette"></i> APPARENCE</h6>
            <div class="setting-row">
                <div>
                    <strong style="color: var(--text-primary);">Thème</strong>
                    <p style="color: var(--text-muted); font-size: 0.75rem; margin: 4px 0 0;">
                        Passer entre le thème sombre et clair
                    </p>
                </div>
                <button class="btn btn-ghost btn-sm" @onclick="ToggleTheme">
                    <i class="bi @(currentTheme == "light" ? "bi-moon-stars" : "bi-sun")"></i>
                    @(currentTheme == "light" ? "SOMBRE" : "CLAIR")
                </button>
            </div>
        </div>

        <div class="form-section">
            <h6><i class="bi bi-bell"></i> PREFERENCES DE NOTIFICATIONS</h6>
            <p style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 16px;">
                Activez ou désactivez les notifications par email pour chaque type d'opération.
            </p>
            @foreach (var (key, label, icon) in notifItems)
            {
                <div class="setting-row">
                    <div>
                        <strong style="color: var(--text-primary);"><i class="bi @icon"></i> @label</strong>
                    </div>
                    <label class="switch">
                        <input type="checkbox" checked="@GetNotif(key)" @onclick="() => ToggleNotif(key)" />
                        <span class="switch-slider"></span>
                    </label>
                </div>
            }
            <button class="btn btn-primary" @onclick="SaveNotifs" disabled="@saving">
                @(saving ? "ENREGISTREMENT..." : "ENREGISTRER")
            </button>
            @if (!string.IsNullOrEmpty(notifMsg))
            {
                <div class="@(notifSuccess ? "status-banner success" : "status-banner error")" style="margin-top: 12px;">
                    @notifMsg
                </div>
            }
        </div>
    }
</div>

@code {
    private string activeTab = "profile";
    private string currentTheme = "dark";
    private bool saving;
    private string profileMsg = "";
    private bool profileSuccess;
    private string pwdMsg = "";
    private bool pwdSuccess;
    private bool showTuteurInput;
    private string tuteurEmail = "";
    private ProfileModel profileModel = new();
    private PasswordModel passwordModel = new();
    private string emailChangePassword = "";
    private bool EmailModifie => (profileModel.Email?.Trim().ToLowerInvariant() ?? "") != Bank.Profil.Email;
    private string exportMsg = "";
    private bool exportSuccess;
    private string deleteMsg = "";
    private bool deleteSuccess;
    private bool showDeleteConfirm;
    private string deleteConfirmText = "";
    private long epargneTotale;
    private bool PeutCloturer => Bank.Profil.Solde <= 0 && Bank.Profil.Dette <= 0 && epargneTotale <= 0;

    // 2FA
    private bool showTwoFactorSetup;
    private string twoFactorSecret = "";
    private string twoFactorQrUri = "";
    private string twoFactorSetupCode = "";
    private string twoFactorMsg = "";
    private bool twoFactorSuccess;
    private List<string> recoveryCodes = new();

    // Connexions
    private List<UserLogin> loginHistory = new();

    // Plafonds
    private decimal plafondJournalier = 5000;
    private decimal plafondMensuel = 50000;
    private string plafondMsg = "";
    private bool plafondSuccess;

    // Notifications
    private Dictionary<string, bool> notifPrefs = new();
    private string notifMsg = "";
    private bool notifSuccess;
    private List<(string Key, string Label, string Icon)> notifItems = new()
    {
        ("connexion", "Connexion", "bi-shield-check"),
