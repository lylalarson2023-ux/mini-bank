@page "/depot"
@attribute [Authorize]
@using ADN_pay.Models
@using ADN_pay.Services
@inject BankService Bank
@inject BankTransferService Virements
@inject NotificationService Notif
@inject IConfiguration Config

@* Dépôt réduit au seul canal Airtel Money (Mobile Money) — phase pilote « Alex ».
   Carte bancaire (Stripe) et virement bancaire retirés de l'UI ; leur code
   backend (StripeService, canal VIREMENT de BankTransferService) reste intact
   pour réintégration ultérieure. *@
<div class="cyber-panel" style="max-width: 480px;">
    <h3>MODULE DE DÉPÔT</h3>

    <div class="warning-box">
        SOLDE ACTUEL : <span class="highlight">@((Bank.Profil.Solde / 100m).ToString("N2")) DH</span>
    </div>

    @if (demande is not null)
    {
        <!-- Instructions après création de la demande de dépôt -->
        <div class="depot-step" style="margin-top: 16px;">
            <div class="depot-step-label">VOTRE DEMANDE EST ENREGISTRÉE</div>
            <div class="warning-box" style="text-align:center; margin-top: 10px;">
                RÉFÉRENCE :<br />
                <span class="highlight" style="font-size:1.4rem; letter-spacing:2px;">@demande.Reference</span><br />
                MONTANT À ENVOYER : <span class="highlight">@demande.MontantConverti @demande.DeviseConvertie</span>
                <span style="font-size:.75rem;"> (= @((demande.MontantCentimes / 100m).ToString("N2")) DH crédités)</span>
            </div>
            <div style="margin-top: 14px; font-size: .85rem; line-height: 1.7;">
                <div><strong>Envoi Airtel Money :</strong></div>
                <div>Opérateur : <strong>@mmOperateur</strong></div>
                <div>Numéro : <strong style="letter-spacing:1px">@mmNumero</strong></div>
                <div>Titulaire : <strong>@mmTitulaire</strong></div>
                @if (!string.IsNullOrEmpty(mmCodeAgent))
                {
                    <div>Code agent : <strong>@mmCodeAgent</strong></div>
                }
            </div>
            <ol style="margin-top: 14px; font-size: .8rem; color: var(--text-muted); padding-left: 18px; line-height: 1.8;">
                <li>Envoyez le montant exact (<strong>@demande.MontantConverti @demande.DeviseConvertie</strong>) au numéro ci-dessus.</li>
                <li>Indiquez impérativement la référence <strong>@demande.Reference</strong> dans le motif/message.</li>
                <li>Votre compte est crédité après vérification (en journée, généralement sous quelques heures).</li>
            </ol>
            <div style="margin-top: 10px; font-size: .7rem; color: var(--text-muted);">
                Service en phase pilote : dépôt limité à @((BankTransferService.MontantMaxMobileMoney / 100m).ToString("N0")) DH,
                plafond de @((BankTransferService.PlafondMensuelMobileMoney / 100m).ToString("N0")) DH par mois.
            </div>
            <button class="btn btn-primary btn-block" style="margin-top: 10px;" @onclick="() => demande = null">
                J'AI NOTÉ LES INSTRUCTIONS
            </button>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(configError))
        {
            <div class="alert alert-danger" style="margin-top: 16px; font-size: 0.75rem;">
                @configError
            </div>
        }

        <div class="depot-step">
            <div class="depot-step-label">1. MONTANT À DÉPOSER (DH)</div>
            <input type="number" @bind="montant" class="form-input depot-montant-input" placeholder="0.00" />
        </div>

        <div class="depot-step">
            <div class="depot-step-label">2. MOYEN DE PAIEMENT</div>
            <div class="depot-choices">
                @* Canal unique en phase pilote : Airtel Money. *@
                <div class="depot-choice active">
                    <span class="depot-choice-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <rect x="5" y="2" width="14" height="20" rx="2" />
                            <line x1="12" y1="18" x2="12.01" y2="18" />
                            <path d="M8 8h8v3H8z" />
                        </svg>
                    </span>
                    <span class="depot-choice-label">AIRTEL MONEY</span>
                    <span class="depot-choice-sub">@(mobileMoneyConfigured ? $"{mmOperateur} — max {BankTransferService.MontantMaxMobileMoney / 100m:N0} DH (pilote)" : "Bientôt disponible")</span>
                </div>
            </div>
        </div>

        <div class="depot-step">
            <button class="btn btn-primary btn-block depot-confirm" @onclick="EffectuerDepot" disabled="@(!canConfirm)">
                @(isProcessing ? "TRAITEMENT..." : "CONFIRMER LE DÉPÔT")
            </button>
        </div>
    }

    @if (mesDemandes.Count > 0)
    {
        <div class="depot-step" style="margin-top: 20px;">
            <div class="depot-step-label">MES DEMANDES DE DÉPÔT</div>
            @foreach (var d in mesDemandes)
            {
                <div style="display:flex; justify-content:space-between; align-items:center; gap:8px; padding:8px 0; border-bottom:1px solid rgba(255,255,255,.08); font-size:.8rem;">
                    <div>
                        <strong>@d.Reference</strong> · @((d.MontantCentimes / 100m).ToString("N2")) DH
                        @if (d.MontantConverti is not null)
                        {
                            <span style="color:var(--text-muted);"> (@d.MontantConverti @d.DeviseConvertie)</span>
                        }
                        <div style="color:var(--text-muted); font-size:.7rem;">
                            @(d.Canal == BankTransferRequest.CanalMobileMoney ? "Airtel Money" : "Virement") ·
                            @d.DateCreation.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </div>
                    </div>
                    <div style="display:flex; align-items:center; gap:8px;">
                        <span class="highlight" style="font-size:.7rem;">@StatutLabel(d)</span>
                        @if (d.Statut == BankTransferRequest.EnAttente)
                        {
                            <button class="btn btn-block" style="width:auto; padding:2px 8px; font-size:.65rem;" @onclick="() => Annuler(d.Id)">ANNULER</button>
                        }
                    </div>
                </div>
            }
        </div>
    }

    <div style="margin-top: 24px; text-align: center;">
        <a href="/" style="color: var(--text-muted); font-size: 0.8rem; font-weight: 600;">&larr; RETOUR DASHBOARD</a>
    </div>
</div>

@code {
    private decimal? montant;
    private bool isProcessing;
    private bool mobileMoneyConfigured;
    private string? configError;
    private string mmNumero = "", mmOperateur = "", mmTitulaire = "", mmCodeAgent = "";
    private decimal transfertTaux, transfertMarge;
    private BankTransferRequest? demande;
    private List<BankTransferRequest> mesDemandes = new();

    private bool canConfirm => montant is > 0 && !isProcessing && mobileMoneyConfigured;

    protected override async Task OnInitializedAsync()
    {
        mmNumero = Config["MobileMoney:Numero"] ?? "";
        mmOperateur = Config["MobileMoney:Operateur"] ?? "Airtel Money";
        mmTitulaire = Config["MobileMoney:Titulaire"] ?? "";
        mmCodeAgent = Config["MobileMoney:CodeAgent"] ?? "";
        transfertTaux = ParseDecimalInvariant(Config["Transfert:GabonMaroc:Taux"], 0.0156m);
        transfertMarge = ParseDecimalInvariant(Config["Transfert:GabonMaroc:Marge"], 0.10m);
        mobileMoneyConfigured = !string.IsNullOrEmpty(mmNumero);

        if (!mobileMoneyConfigured)
            configError = "Le dépôt Airtel Money n'est pas configuré. Contactez l'administrateur.";

        mesDemandes = await Virements.GetMesDemandesAsync();
    }

    private static decimal ParseDecimalInvariant(string? s, decimal fallback) =>
        decimal.TryParse(s, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var v) && v > 0
            ? v : fallback;

    private static string StatutLabel(BankTransferRequest d) => d.Statut switch
    {
        BankTransferRequest.EnAttente => "EN ATTENTE",
        BankTransferRequest.Valide => "VALIDÉ ✓",
        BankTransferRequest.Rejete => $"REJETÉ — {d.MotifRejet}",
        BankTransferRequest.Annule => "ANNULÉE",
        _ => d.Statut
    };

    private async Task Annuler(int id)
    {
        if (await Virements.AnnulerDemandeAsync(id))
            mesDemandes = await Virements.GetMesDemandesAsync();
    }

    private async Task EffectuerDepot()
    {
        if (isProcessing || montant is null or <= 0) return;
        isProcessing = true;
        try
        {
            var (ok, message, d) = await Virements.CreerDemandeAsync(
                (long)(montant.Value * 100), BankTransferRequest.CanalMobileMoney,
                transfertTaux, transfertMarge);
            if (ok && d is not null)
            {
                demande = d;
                montant = null;
                mesDemandes = await Virements.GetMesDemandesAsync();
            }
            else
            {
                Notif.Notify(message.ToUpper(), NotificationType.ERROR);
            }
        }
        catch (Exception ex)
        {
            Notif.Notify($"ERREUR : {ex.Message}", NotificationType.ERROR);
        }
        finally { isProcessing = false; }
    }
}
