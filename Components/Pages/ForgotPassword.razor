@page "/mot-de-passe-oublie"
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@inject BankService Bank
@inject NavigationManager Nav
@inject NotificationService Notif

<NotificationOverlay />

<div class="auth-wrapper login-page">

    <div class="login-shape login-shape-1"></div>
    <div class="login-shape login-shape-2"></div>
    <div class="login-shape login-shape-3"></div>
    <div class="login-shape login-shape-4"></div>
    <div class="login-shape login-shape-5"></div>

    <div class="auth-card">
        <div class="auth-header">
            <h1 class="auth-title"><img src="images/logo_adn_pay_auth.png" alt="ADN_pay" class="auth-logo" /></h1>
            <div class="auth-subtitle">RÉINITIALISATION DU MOT DE PASSE</div>
            <div class="auth-subtitle-line adn"></div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="login-error"><i class="bi bi-exclamation-triangle-fill"></i> @errorMessage</div>
        }

        @if (step == 1)
        {
            <p style="font-size: 0.78rem; color: var(--text-muted); text-align: center; margin-bottom: 18px; line-height: 1.6;">
                Saisissez l'adresse e-mail de votre compte. Si un compte existe, un code à 6 chiffres vous sera envoyé pour définir un nouveau mot de passe.
            </p>
            <div class="form-group">
                <label>ADRESSE E-MAIL</label>
                <input @bind="email" type="email" placeholder="nom@exemple.com" class="form-input" disabled="@isLoading" />
            </div>
            <button class="btn btn-adn btn-block @(isLoading ? "btn-loading" : "")" @onclick="RequestCode" disabled="@isLoading">
                @(isLoading ? "ENVOI..." : "ENVOYER LE CODE")
            </button>
        }
        else
        {
            @if (!string.IsNullOrEmpty(info))
            {
                <div style="background: rgba(48,184,128,0.10); border: 1px solid rgba(48,184,128,0.4); color: var(--success);
                            border-radius: var(--radius-sm); padding: 10px 12px; font-size: 0.75rem; margin-bottom: 16px; text-align: center;">
                    <i class="bi bi-envelope-check"></i> @info
                </div>
            }
            <div class="form-group">
                <label>CODE REÇU PAR E-MAIL</label>
                <input @bind="code" type="text" inputmode="numeric" maxlength="6" placeholder="000000" class="form-input"
                       style="text-align: center; font-size: 1.4rem; letter-spacing: 8px; font-family: var(--font-mono);" disabled="@isLoading" />
            </div>
            <div class="form-group">
                <label>NOUVEAU MOT DE PASSE</label>
                <PasswordInput @bind-Value="newPassword" Placeholder="••••••••" Autocomplete="new-password" Disabled="isLoading" />
                <small style="color: var(--text-muted); font-size: 0.6rem; margin-top: 4px; display: block;">8+ car., 1 maj, 1 min, 1 chiffre, 1 spécial</small>
            </div>
            <div class="form-group">
                <label>CONFIRMER LE MOT DE PASSE</label>
                <PasswordInput @bind-Value="confirmPassword" Placeholder="••••••••" Autocomplete="new-password" Disabled="isLoading" />
                @if (!string.IsNullOrEmpty(confirmPassword))
                {
                    <small style="font-size: 0.62rem; margin-top: 6px; display: block; color:@(confirmPassword == newPassword ? "var(--success)" : "var(--danger)");">
                        @(confirmPassword == newPassword ? "✓ Les mots de passe correspondent" : "✗ Les mots de passe diffèrent")
                    </small>
                }
            </div>
            <button class="btn btn-adn btn-block @(isLoading ? "btn-loading" : "")" @onclick="ResetPassword" disabled="@isLoading">
                @(isLoading ? "RÉINITIALISATION..." : "RÉINITIALISER LE MOT DE PASSE")
            </button>
            <div class="auth-footer">
                <a href="javascript:void(0)" @onclick="RequestCode">(renvoyer un code)</a>
            </div>
        }

        <div class="auth-footer">
            <a href="/login"><i class="bi bi-arrow-left"></i> retour à la connexion</a>
        </div>
    </div>
</div>

@code {
    private int step = 1;
    private string email = "";
    private string code = "";
    private string newPassword = "";
    private string confirmPassword = "";
    private string errorMessage = "";
    private string info = "";
    private bool isLoading;

    private async Task RequestCode()
    {
        errorMessage = "";
        if (string.IsNullOrWhiteSpace(email) || !email.Contains('@'))
        {
            errorMessage = "Saisissez une adresse e-mail valide.";
            return;
        }
        isLoading = true;
        try
        {
            // Message toujours générique (anti-énumération) : on passe à l'étape 2 quoi qu'il arrive.
            info = await Bank.RequestPasswordResetAsync(email);
            step = 2;
        }
        catch
        {
            errorMessage = "Une erreur technique est survenue. Veuillez réessayer.";
        }
        finally { isLoading = false; }
    }

    private async Task ResetPassword()
    {
        errorMessage = "";
        if (string.IsNullOrWhiteSpace(code))
        {
            errorMessage = "Saisissez le code reçu par e-mail.";
            return;
        }
        if (newPassword != confirmPassword)
        {
            errorMessage = "Les mots de passe ne correspondent pas.";
            return;
        }
        isLoading = true;
        try
        {
            var (ok, message) = await Bank.ResetPasswordWithCodeAsync(email, code, newPassword);
            if (ok)
            {
                Notif.Notify(message, NotificationType.SUCCESS);
                Nav.NavigateTo("/login");
            }
            else
            {
                errorMessage = message;
            }
        }
        catch
        {
            errorMessage = "Une erreur technique est survenue. Veuillez réessayer.";
        }
        finally { isLoading = false; }
    }
}
