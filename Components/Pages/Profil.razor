@page "/profil"
@page "/profil/{UserId:int}"
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Forms
@inject BankService Bank
@inject NotificationService Notif
@inject UserContext UserCtx
@inject NavigationManager Nav

<div class="cyber-panel" style="max-width: 900px; margin: auto;">

    @if (isAdminReview && targetUser != null)
    {
        @* ─── MODE ADMIN : REVUE KYC D'UN AUTRE UTILISATEUR ─── *@
        <div style="text-align: center; margin-bottom: 24px;">
            <h3 style="font-size: 1rem; color: var(--gold-500); font-weight: 700; text-transform: uppercase; letter-spacing: 2px;">
                REVUE_KYC_ADMIN
            </h3>
            <p style="font-size: 0.75rem; color: var(--blue-500);">
                Verification du dossier de <strong>@targetUser.Prenom @targetUser.Nom</strong> #@targetUser.Id
            </p>
        </div>

        @if (!string.IsNullOrEmpty(reviewError))
        {
            <div class="status-banner error">@reviewError</div>
        }

        <div class="form-section">
            <h6><i class="bi bi-person-vcard"></i> IDENTITE CIVILE</h6>
            <div class="form-grid">
                <div class="form-group"><label>Nom</label><div class="review-value">@targetUser.Nom</div></div>
                <div class="form-group"><label>Prenom</label><div class="review-value">@targetUser.Prenom</div></div>
                <div class="form-group"><label>Email</label><div class="review-value">@targetUser.Email</div></div>
                <div class="form-group"><label>Date de naissance</label><div class="review-value">@targetUser.DateNaissance?.ToString("dd/MM/yyyy")</div></div>
                <div class="form-group"><label>Lieu de naissance</label><div class="review-value">@targetUser.LieuNaissance</div></div>
                <div class="form-group"><label>Nationalite</label><div class="review-value">@targetUser.Nationalite</div></div>
                <div class="form-group"><label>N Passeport / CIN</label><div class="review-value">@targetUser.PassportOuCIN</div></div>
                <div class="form-group"><label>Situation matrimoniale</label><div class="review-value">@targetUser.SituationMatrimoniale</div></div>
            </div>
        </div>

        <div class="form-section">
            <h6><i class="bi bi-info-circle"></i> COORDONNEES</h6>
            <div class="form-grid">
                <div class="form-group full-width"><label>Adresse</label><div class="review-value">@targetUser.AdresseCasablanca</div></div>
                <div class="form-group"><label>Telephone</label><div class="review-value">@targetUser.Telephone</div></div>
                <div class="form-group"><label>Reseau social</label><div class="review-value">@targetUser.ReseauPrincipal</div></div>
                <div class="form-group"><label>Contact d'urgence</label><div class="review-value">@(string.IsNullOrEmpty(targetUser.UrgenceNom) ? "—" : $"{targetUser.UrgenceNom} · {targetUser.UrgenceTelephone}")</div></div>
                <div class="form-group"><label>Inscription</label><div class="review-value">@targetUser.DateInscription.ToString("dd/MM/yyyy HH:mm")</div></div>
            </div>
        </div>

        <div class="form-section">
            <h6><i class="bi bi-person-badge"></i> PROFIL DU DEMANDEUR</h6>
            <div class="form-grid">
                <div class="form-group"><label>Statut</label><div class="review-value">@(string.IsNullOrEmpty(targetUser.StatutKyc) ? "— (dossier antérieur)" : targetUser.StatutKyc)</div></div>
                <div class="form-group"><label>Source des fonds</label><div class="review-value">@(string.IsNullOrEmpty(targetUser.SourceFonds) ? "—" : targetUser.SourceFonds)</div></div>
                @if (targetUser.StatutKyc == "TRAVAILLEUR")
                {
                    <div class="form-group"><label>Profession</label><div class="review-value">@targetUser.Profession</div></div>
                    <div class="form-group"><label>Employeur</label><div class="review-value">@targetUser.Employeur</div></div>
                    <div class="form-group"><label>Secteur</label><div class="review-value">@targetUser.Secteur</div></div>
                    <div class="form-group"><label>Tranche de revenu</label><div class="review-value">@targetUser.TrancheRevenu</div></div>
                }
                else
                {
                    <div class="form-group"><label>Niveau d'etude</label><div class="review-value">@targetUser.NiveauEtude</div></div>
                    <div class="form-group"><label>Etablissement</label><div class="review-value">@targetUser.Etablissement</div></div>
                    <div class="form-group"><label>Filiere</label><div class="review-value">@targetUser.Filiere</div></div>
                }
            </div>
        </div>

        <div class="form-section">
            <h6><i class="bi bi-cloud-arrow-up"></i> JUSTIFICATIFS</h6>
            <div class="upload-grid">
                <div class="upload-card @(string.IsNullOrEmpty(targetUser.DocIdentiteUrl) ? "" : "has-file")">
                    <div class="upload-icon"><i class="bi bi-card-image"></i></div>
                    <label>SCAN PIECE D'IDENTITE</label>
                    @if (!string.IsNullOrEmpty(targetUser.DocIdentiteUrl))
                    {
                        <div style="display: flex; gap: 8px; justify-content: center; align-items: center; margin-top: 10px;">
                            <span class="badge badge-success">PRET</span>
                            <a href="@targetUser.DocIdentiteUrl" target="_blank" class="btn btn-ghost btn-sm">VOIR LE DOCUMENT</a>
                        </div>
                    }
                    else
                    {
                        <span class="badge badge-danger">MANQUANT</span>
                    }
                </div>
                <div class="upload-card @(string.IsNullOrEmpty(targetUser.SelfieUrl) ? "" : "has-file")">
                    <div class="upload-icon"><i class="bi bi-person-bounding-box"></i></div>
                    <label>SELFIE DE VERIFICATION</label>
                    @if (!string.IsNullOrEmpty(targetUser.SelfieUrl))
                    {
                        <div style="display: flex; gap: 8px; justify-content: center; align-items: center; margin-top: 10px;">
                            <span class="badge badge-success">PRET</span>
                            <a href="@targetUser.SelfieUrl" target="_blank" class="btn btn-ghost btn-sm">VOIR LE DOCUMENT</a>
                        </div>
                    }
                    else
                    {
                        <span class="badge badge-danger">MANQUANT</span>
                    }
                </div>
                @* Justificatif de domicile : plus collecté (refonte KYC) — affiché
                   seulement s'il existe sur un dossier antérieur. *@
                @if (!string.IsNullOrEmpty(targetUser.DocDomicileUrl))
                {
                    <div class="upload-card has-file">
                        <div class="upload-icon"><i class="bi bi-house-check"></i></div>
                        <label>JUSTIFICATIF DOMICILE (ANTERIEUR)</label>
                        <div style="display: flex; gap: 8px; justify-content: center; align-items: center; margin-top: 10px;">
                            <span class="badge badge-success">PRET</span>
                            <a href="@targetUser.DocDomicileUrl" target="_blank" class="btn btn-ghost btn-sm">VOIR LE DOCUMENT</a>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div style="display: flex; gap: 12px; margin-top: 24px;">
            <button class="btn btn-success btn-block" @onclick="ApprouverKyc" disabled="@isProcessing">
                @(isProcessing ? "TRAITEMENT..." : "VALIDER LE DOSSIER")
            </button>
            <button class="btn btn-danger btn-block" @onclick="RejeterKyc" disabled="@isProcessing">
                @(isProcessing ? "TRAITEMENT..." : "REJETER LE DOSSIER")
            </button>
        </div>
        <div style="text-align: center; margin-top: 12px;">
            <button class="btn btn-ghost" @onclick="RetourAdmin">
                <i class="bi bi-arrow-left"></i> RETOUR AU PANEL ADMIN
            </button>
        </div>
    }
    else
    {
        @* ─── MODE UTILISATEUR : SAISIE / SOUMISSION KYC ─── *@
        <div style="text-align: center; margin-bottom: 24px;">
            <h3 style="font-size: 1rem; color: var(--gold-500); font-weight: 700; text-transform: uppercase; letter-spacing: 2px;">
                DOSSIER_D'INSCRIPTION_V4
            </h3>
            <p style="font-size: 0.75rem; color: var(--blue-500);">
                Completez votre dossier KYC pour debloquer les services Premium <i class="bi bi-shield-check"></i>
            </p>
        </div>

        @if (Bank.Profil.Statut == UserStatus.PREMIUM)
        {
            <div class="status-banner" style="background: var(--success-bg); border: 1px solid var(--success); color: var(--success);">
                <i class="bi bi-shield-check"></i> COMPTE PREMIUM ACTIF — Vous avez acces a tous les services.
            </div>
        }
        else if (Bank.Profil.PendingPremiumUpgrade)
        {
            <div class="status-banner pending">
                <i class="bi bi-hourglass-split"></i> DOSSIER EN COURS DE VERIFICATION PAR L'ADMINISTRATION
            </div>
        }
        else
        {
            <div class="form-section">
                <h6><i class="bi bi-person-vcard"></i> IDENTITE CIVILE</h6>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Nom</label>
                        <input type="text" @bind-value="kyc.Nom" @bind-value:event="oninput" placeholder="Votre nom" class="form-input" />
                    </div>
                    <div class="form-group">
                        <label>Prenom</label>
                        <input type="text" @bind-value="kyc.Prenom" @bind-value:event="oninput" placeholder="Votre prenom" class="form-input" />
                    </div>
                    <div class="form-group">
                        <label>Date de naissance</label>
                        <input type="date" @bind-value="kyc.DateNaissance" @bind-value:event="oninput" class="form-input" />
                    </div>
                    <div class="form-group">
                        <label>Lieu de naissance</label>
                        <input type="text" @bind-value="kyc.LieuNaissance" @bind-value:event="oninput" placeholder="Ville" class="form-input" />
                    </div>
                    <div class="form-group">
                        <label>Nationalite</label>
                        <input type="text" @bind-value="kyc.Nationalite" @bind-value:event="oninput" placeholder="Marocaine, etc." class="form-input" />
                    </div>
                    <div class="form-group">
                        <label>N Passeport / CIN</label>
                        <input type="text" @bind-value="kyc.PassportOuCIN" @bind-value:event="oninput" placeholder="N de document" class="form-input" />
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h6><i class="bi bi-info-circle"></i> COORDONNEES</h6>
                <div class="form-grid">
                    <div class="form-group full-width">
                        <label>Adresse de residence (Casablanca)</label>
                        <input type="text" @bind-value="kyc.AdresseCasablanca" @bind-value:event="oninput" placeholder="Adresse complete" class="form-input" />
                    </div>
                    <div class="form-group">
                        <label>Situation matrimoniale</label>
                        <select @bind="kyc.SituationMatrimoniale" class="form-select">
                            <option value="CELIBATAIRE">CELIBATAIRE</option>
                            <option value="MARIE(E)">MARIE(E)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Telephone</label>
                        <input type="text" @bind-value="kyc.Telephone" @bind-value:event="oninput" placeholder="+212..." class="form-input" />
                    </div>
                    <div class="form-group">
                        <label>Reseau Social Principal</label>
                        <input type="text" @bind-value="kyc.ReseauPrincipal" @bind-value:event="oninput" placeholder="Optionnel (LinkedIn, TikTok...)" class="form-input" />
                    </div>
                    <div class="form-group">
                        <label>Contact d'urgence — nom</label>
                        <input type="text" @bind-value="kyc.UrgenceNom" @bind-value:event="oninput" placeholder="Nom et prenom" class="form-input" />
                    </div>
                    <div class="form-group">
                        <label>Contact d'urgence — telephone</label>
                        <input type="text" @bind-value="kyc.UrgenceTelephone" @bind-value:event="oninput" placeholder="+212... ou +241..." class="form-input" />
                    </div>
                </div>
            </div>

            @* ─── STATUT : les champs du dossier s'adaptent (Étudiant / Travailleur) ─── *@
            <div class="form-section">
                <h6><i class="bi bi-person-badge"></i> STATUT DU DEMANDEUR</h6>
                <div class="admin-tabs" style="margin-bottom: 16px;">
                    <button type="button" class='admin-tab @(kyc.StatutKyc == "ETUDIANT" ? "active" : "")' @onclick='() => ChangerStatut("ETUDIANT")'>
                        <i class="bi bi-mortarboard"></i> ÉTUDIANT
                    </button>
                    <button type="button" class='admin-tab @(kyc.StatutKyc == "TRAVAILLEUR" ? "active" : "")' @onclick='() => ChangerStatut("TRAVAILLEUR")'>
                        <i class="bi bi-briefcase"></i> TRAVAILLEUR
                    </button>
                </div>

                @if (kyc.StatutKyc == "ETUDIANT")
                {
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Niveau d'etude</label>
                            <select @bind="kyc.NiveauEtude" class="form-select">
                                <option value="1ERE ANNEE DEV">1ERE ANNEE DEVELOPPEMENT</option>
                                <option value="2EME ANNEE DEV">2EME ANNEE DEVELOPPEMENT</option>
                                <option value="MASTER">MASTER / BAC+5</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Etablissement</label>
                            <input type="text" @bind-value="kyc.Etablissement" @bind-value:event="oninput" placeholder="Nom de l'ecole / universite" class="form-input" />
                        </div>
                        <div class="form-group">
                            <label>Filiere</label>
                            <input type="text" @bind-value="kyc.Filiere" @bind-value:event="oninput" placeholder="Developpement, gestion..." class="form-input" />
                        </div>
                        <div class="form-group">
                            <label>Source des fonds</label>
                            <select @bind="kyc.SourceFonds" class="form-select">
                                <option value="">— SELECTIONNER —</option>
                                <option value="BOURSE">BOURSE</option>
                                <option value="FAMILLE">FAMILLE</option>
                                <option value="JOB ETUDIANT">JOB ETUDIANT</option>
                                <option value="AUTRE">AUTRE</option>
                            </select>
                        </div>
                    </div>
                }
                else
                {
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Profession</label>
                            <input type="text" @bind-value="kyc.Profession" @bind-value:event="oninput" placeholder="Votre metier" class="form-input" />
                        </div>
                        <div class="form-group">
                            <label>Employeur</label>
                            <input type="text" @bind-value="kyc.Employeur" @bind-value:event="oninput" placeholder="Nom de l'entreprise" class="form-input" />
                        </div>
                        <div class="form-group">
                            <label>Secteur</label>
                            <select @bind="kyc.Secteur" class="form-select">
                                <option value="">— SELECTIONNER —</option>
                                <option value="TECH">TECH</option>
                                <option value="COMMERCE">COMMERCE</option>
                                <option value="SANTE">SANTE</option>
                                <option value="EDUCATION">EDUCATION</option>
                                <option value="AUTRE">AUTRE</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Tranche de revenu mensuel</label>
                            <select @bind="kyc.TrancheRevenu" class="form-select">
                                <option value="">— SELECTIONNER —</option>
                                <option value="< 3000 DH">MOINS DE 3 000 DH</option>
                                <option value="3000-6000 DH">3 000 – 6 000 DH</option>
                                <option value="6000-10000 DH">6 000 – 10 000 DH</option>
                                <option value="> 10000 DH">PLUS DE 10 000 DH</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Source des fonds</label>
                            <select @bind="kyc.SourceFonds" class="form-select">
                                <option value="">— SELECTIONNER —</option>
                                <option value="SALAIRE">SALAIRE</option>
                                <option value="INDEPENDANT">INDEPENDANT</option>
                                <option value="AUTRE">AUTRE</option>
                            </select>
                        </div>
                    </div>
                }
            </div>

            <div class="form-section">
                <h6><i class="bi bi-cloud-arrow-up"></i> JUSTIFICATIFS (MAX 2MO)</h6>
                <div class="upload-grid">
                    <UploadCard Label="SCAN PIECE D'IDENTITE"
                                IconClass="bi bi-card-image"
                                CurrentUrl="@kyc.DocIdentiteUrl"
                                OnFileUploaded="@(url => { kyc.DocIdentiteUrl = url; UserCtx.KycFormState = kyc; })" />
                    <UploadCard Label="SELFIE DE VERIFICATION"
                                IconClass="bi bi-person-bounding-box"
                                CurrentUrl="@kyc.SelfieUrl"
                                OnFileUploaded="@(url => { kyc.SelfieUrl = url; UserCtx.KycFormState = kyc; })" />
                </div>
            </div>

            <div class="form-group" style="margin-top: 24px; text-align: center;">
                <label class="checkbox-container" style="justify-content: center; font-size: 0.8rem; color: var(--text-secondary);">
                    <input type="checkbox" @bind="kyc.CguAcceptees" />
                    J'accepte les conditions d'utilisation et le prelevement de 50 DH pour le passage en Premium.
                </label>
            </div>

            @if (ChampsManquants.Count > 0)
            {
                <div class="kyc-missing">
                    <i class="bi bi-info-circle"></i>
                    <span>Encore requis :</span>
                    @foreach (var champ in ChampsManquants)
                    {
                        <span class="kyc-missing-chip">@champ</span>
                    }
                </div>
            }

            <button class="btn btn-primary btn-block @(!PeutSoumettre || isProcessing ? "disabled" : "")"
                    disabled="@(!PeutSoumettre || isProcessing)"
                    @onclick="SoumettreDossier"
                    style="margin-top: 16px;">
                @(isProcessing ? "TRAITEMENT..." : "ENVOYER LE DOSSIER AU MASTER ADMIN")
            </button>
        }
    }
</div>

@code {
    [Parameter]
    public int? UserId { get; set; }

    private UserProfile kyc = new();
    private UserProfile? targetUser;
    private bool isAdminReview;
    private bool isProcessing;
    private string? reviewError;

    protected override async Task OnInitializedAsync()
    {
        if (UserId.HasValue && Bank.Profil.IsAdmin)
        {
            isAdminReview = true;
            targetUser = await Bank.GetUserByIdAsync(UserId.Value);
            if (targetUser == null)
            {
                reviewError = "Utilisateur introuvable";
                isAdminReview = false;
            }
        }
        else if (UserCtx.KycFormState != null)
        {
            kyc = UserCtx.KycFormState;
        }

        if (!isAdminReview)
        {
            // Statut par défaut : public cible étudiant.
            if (string.IsNullOrEmpty(kyc.StatutKyc)) kyc.StatutKyc = "ETUDIANT";
            // Résidu « ETUDIANT » dans la situation matrimoniale (ancienne option) :
            // on retombe sur CELIBATAIRE, seules Célibataire/Marié(e) sont valides.
            if (string.IsNullOrEmpty(kyc.SituationMatrimoniale) || kyc.SituationMatrimoniale == "ETUDIANT")
                kyc.SituationMatrimoniale = "CELIBATAIRE";
            if (string.IsNullOrEmpty(kyc.NiveauEtude)) kyc.NiveauEtude = "1ERE ANNEE DEV";
        }
    }

    // Bascule Étudiant/Travailleur : on vide les champs de l'autre volet et la
    // source des fonds (les options diffèrent) pour ne pas soumettre de résidus.
    private void ChangerStatut(string statut)
    {
        if (kyc.StatutKyc == statut) return;
        kyc.StatutKyc = statut;
        kyc.SourceFonds = "";
        if (statut == "ETUDIANT")
        {
            kyc.Profession = kyc.Employeur = kyc.Secteur = kyc.TrancheRevenu = "";
            if (string.IsNullOrEmpty(kyc.NiveauEtude)) kyc.NiveauEtude = "1ERE ANNEE DEV";
        }
        else
        {
            kyc.Etablissement = kyc.Filiere = "";
        }
        UserCtx.KycFormState = kyc;
    }

    private bool PeutSoumettre => ChampsManquants.Count == 0;

    private List<string> ChampsManquants
    {
        get
        {
            var m = new List<string>();
            if (string.IsNullOrWhiteSpace(kyc.Nom)) m.Add("Nom");
            if (string.IsNullOrWhiteSpace(kyc.Prenom)) m.Add("Prénom");
            if (string.IsNullOrWhiteSpace(kyc.PassportOuCIN)) m.Add("N° Passeport / CIN");
            if (string.IsNullOrWhiteSpace(kyc.AdresseCasablanca)) m.Add("Adresse");
            if (string.IsNullOrWhiteSpace(kyc.Telephone)) m.Add("Téléphone");
            if (string.IsNullOrWhiteSpace(kyc.UrgenceNom)) m.Add("Contact d'urgence (nom)");
            if (string.IsNullOrWhiteSpace(kyc.UrgenceTelephone)) m.Add("Contact d'urgence (téléphone)");
            if (kyc.StatutKyc == "TRAVAILLEUR")
            {
                if (string.IsNullOrWhiteSpace(kyc.Profession)) m.Add("Profession");
                if (string.IsNullOrWhiteSpace(kyc.Employeur)) m.Add("Employeur");
                if (string.IsNullOrWhiteSpace(kyc.Secteur)) m.Add("Secteur");
                if (string.IsNullOrWhiteSpace(kyc.TrancheRevenu)) m.Add("Tranche de revenu");
            }
            else
            {
                if (string.IsNullOrWhiteSpace(kyc.Etablissement)) m.Add("Établissement");
                if (string.IsNullOrWhiteSpace(kyc.Filiere)) m.Add("Filière");
            }
            if (string.IsNullOrWhiteSpace(kyc.SourceFonds)) m.Add("Source des fonds");
            if (string.IsNullOrEmpty(kyc.DocIdentiteUrl)) m.Add("Scan pièce d'identité");
            if (string.IsNullOrEmpty(kyc.SelfieUrl)) m.Add("Selfie de vérification");
            if (!kyc.CguAcceptees) m.Add("Acceptation des conditions");
            return m;
        }
    }

    private async Task SoumettreDossier()
    {
        if (isProcessing) return;

        // Validation de l'âge (compte étudiant : 15 ans minimum)
        if (kyc.DateNaissance.HasValue)
        {
            var age = DateTime.Today.Year - kyc.DateNaissance.Value.Year;
            if (kyc.DateNaissance.Value.Date > DateTime.Today.AddYears(-age)) age--;
            if (kyc.DateNaissance.Value.Date >= DateTime.Today || age < 15 || age > 100)
            {
                Notif.Notify("DATE DE NAISSANCE INVALIDE (15 ANS MINIMUM)", NotificationType.ERROR);
                return;
            }
        }

        if (Bank.Profil.Solde < 5_000L)
        {
            Notif.Notify("SOLDE INSUFFISANT (50 DH REQUIS)", NotificationType.ERROR);
            return;
        }

        isProcessing = true;
        try
        {
            var success = await Bank.SoumettreDossierKYC(kyc);
            if (success)
            {
                UserCtx.KycFormState = null;   // dossier transmis : on vide le brouillon
                Notif.Notify("DOSSIER TRANSMIS AVEC SUCCÈS (50 DH PRÉLEVÉS)", NotificationType.SUCCESS);
                // Bank.Profil.PendingPremiumUpgrade est désormais true → bascule sur la bannière d'attente
            }
            else
                Notif.Notify("ERREUR LORS DE LA TRANSMISSION", NotificationType.ERROR);
        }
        finally { isProcessing = false; }
    }

    private async Task ApprouverKyc()
    {
        if (targetUser == null) return;
        isProcessing = true;
        reviewError = null;
        try
        {
            if (await Bank.ApprouverPremium(targetUser.Id))
            {
                Notif.Notify($"Dossier KYC de {targetUser.Prenom} {targetUser.Nom} approuvé", NotificationType.SUCCESS);
                Nav.NavigateTo("/admin?section=historique");
            }
            else
                reviewError = "Erreur lors de l'approbation";
        }
        catch (Exception ex)
        {
            reviewError = $"Erreur : {ex.Message}";
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task RejeterKyc()
    {
        if (targetUser == null) return;
        isProcessing = true;
        reviewError = null;
        try
        {
            var (success, message) = await Bank.RejeterDossierKycAsync(targetUser.Id);
            if (success)
            {
                Notif.Notify(message, NotificationType.INFO);
                Nav.NavigateTo("/admin?section=historique");
            }
            else
                reviewError = message;
        }
        catch (Exception ex)
        {
            reviewError = $"Erreur : {ex.Message}";
        }
        finally
        {
            isProcessing = false;
        }
    }

    private void RetourAdmin() => Nav.NavigateTo("/admin");
}
