@page "/epargne"
@attribute [Authorize]
@inject BankService Bank
@inject NotificationService Notif

<div class="content-area" style="max-width: 800px;">
    @* Dégradé de marque réutilisé par les anneaux de progression *@
    <svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
        <defs>
            <linearGradient id="ringGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#0099CC" />
                <stop offset="100%" stop-color="#30B880" />
            </linearGradient>
        </defs>
    </svg>

    <div class="page-header">
        <h3>Épargne</h3>
        <span class="page-header-badge">@mesPoches.Count poche(s) · Total : @((totalEpargne / 100m).ToString("N2")) DH</span>
    </div>

    @* ─── FORMULAIRE DE CRÉATION ─── *@
    <div class="form-section">
        <h6>Nouvel objectif d'épargne</h6>
        <div class="form-row">
            <div class="form-group">
                <label>Nom de l'objectif</label>
                <input type="text" @bind="nouvelObjectif" class="form-input" placeholder="Ex: Voyage, Frais scolaires" @ref="objectifInputRef" />
            </div>
            <div class="form-group">
                <label>Montant initial (min 100 DH)</label>
                <input type="number" @bind="montantInitial" class="form-input" placeholder="Ex: 1000" />
            </div>
            <div class="form-group">
                <label>Objectif cible (DH)</label>
                <input type="number" @bind="montantCible" class="form-input" placeholder="Ex: 50000" />
            </div>
            <div class="form-group">
                <label>Date cible</label>
                <input type="date" @bind="dateCible" class="form-input" />
            </div>
        </div>
        @* Case « visible par mon tuteur » retirée avec le module Tuteur (MVP).
           Réintégration : décommenter (le champ tuteurVisible et la logique restent).
        <div class="form-group" style="display: flex; align-items: center; gap: 10px; margin-bottom: 16px;">
            <input type="checkbox" @bind="tuteurVisible" id="chk-tuteur" class="form-checkbox" style="width: 18px; height: 18px; accent-color: var(--blue-500);" />
            <label for="chk-tuteur" style="margin: 0; cursor: pointer; font-size: 0.8rem;">Visible par mon tuteur</label>
        </div>
        *@
        <button class="btn btn-primary" @onclick="CreerPoche" disabled="@isProcessing" style="width: auto;">@(isProcessing ? "Création..." : "Créer l'objectif")</button>
    </div>

    @* ─── STATUT TUTEUR — section retirée avec le module Tuteur (MVP).
       Réintégration : décommenter ce bloc (méthodes ValiderTuteur/RevoquerTuteur intactes).
    <div class="card" style="margin-bottom: 20px;">
        <div class="card-body">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                <span class="badge @(tuteurAutorise ? "badge-success" : "badge-danger")">
                    @(tuteurAutorise ? "Tuteur autorisé" : "Tuteur non connecté")
                </span>
            </div>

            @if (!tuteurAutorise)
            {
                <div class="form-row" style="grid-template-columns: 1fr auto;">
                    <div class="form-group" style="margin: 0;">
                        <input type="email" @bind="emailTuteur" class="form-input" placeholder="Email du tuteur à autoriser..." />
                    </div>
                    <button class="btn btn-primary btn-sm" @onclick="ValiderTuteur" disabled="@isProcessing" style="align-self: flex-end;">@(isProcessing ? "..." : "Autoriser")</button>
                </div>
            }
            else
            {
                <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
                    <span style="font-size: 0.8rem; color: var(--text-secondary);">
                        Accès accordé à : <strong style="color: var(--text-primary);">@emailTuteur</strong>
                    </span>
                    <button class="btn btn-danger btn-sm" @onclick="RevoquerTuteur" disabled="@isProcessing">@(isProcessing ? "..." : "Révoquer")</button>
                </div>
            }
        </div>
    </div>
    *@

    @* ─── PORTEFEUILLE D'ÉPARGNE ─── *@
    <h5 class="section-title" style="margin-bottom: 16px;">Portefeuille d'épargne</h5>

    @if (mesPoches != null && mesPoches.Any())
    {
        <div style="display: flex; flex-direction: column; gap: 14px;">
            @foreach (var p in mesPoches)
            {
                var pct = p.Progression;
                bool estTuteur = p.TuteurVisible || p.Objectif.Contains("TUTEUR", StringComparison.OrdinalIgnoreCase);
                bool atteint = pct >= 100;
                var cardClass = estTuteur ? "pocket-tuteur" : "pocket-standard";
                if (atteint) cardClass = "pocket-atteint";

                <div class="pocket-card @cardClass">
                    @* Anneau de progression circulaire (remplace l'ancienne barre) *@
                    <div class="pocket-main">
                        <div class="pocket-ring @(atteint ? "done" : "")">
                            <svg viewBox="0 0 36 36">
                                <circle class="ring-bg" cx="18" cy="18" r="15.9155" />
                                <circle class="ring-val" cx="18" cy="18" r="15.9155"
                                        stroke-dasharray="@((int)Math.Min(pct, 100)) 100" />
                            </svg>
                            <div class="pocket-ring-label">@((int)pct)<span>%</span></div>
                        </div>
                        <div class="pocket-details">
                            <div class="pocket-name">@p.Objectif.ToUpper()</div>
                            <div class="pocket-amount">
                                @((p.MontantActuel / 100m).ToString("N2")) DH
                                <span class="pocket-target">/ @((p.MontantCible / 100m).ToString("N2")) DH</span>
                            </div>
                            @if (atteint)
                            {
                                <span class="pocket-badge success">🎉 Objectif atteint</span>
                            }
                            else
                            {
                                <span class="pocket-remain">Reste @(((p.MontantCible - p.MontantActuel) / 100m).ToString("N2")) DH</span>
                            }
                            <div class="pocket-meta">
                                <span>Échéance @p.DateCible.ToShortDateString()</span>
                                @if (estTuteur)
                                {
                                    <span class="locked">Surveillée</span>
                                }
                            </div>
                        </div>
                    </div>

                    @* ─── PANEL BOOST INLINE ─── *@
                    @if (actionPocheId == p.Id && actionType == "boost")
                    {
                        <div class="pocket-inline-action">
                            <span style="font-size:0.75rem; color:var(--text-muted);">Montant à ajouter (DH)</span>
                            <div style="display:flex; gap:8px; margin-top:6px;">
                                <input type="number" @bind="actionMontant" class="form-input" style="flex:1; font-size:0.85rem; padding:6px 10px;"
                                       placeholder="Ex: 200" @ref="actionInputRef" />
                                <button class="btn btn-primary btn-sm" @onclick="ConfirmerBoost" disabled="@isProcessing">OK</button>
                                <button class="btn btn-sm" style="background:var(--bg-secondary);border:1px solid var(--border-color);" @onclick="AnnulerAction">✕</button>
                            </div>
                        </div>
                    }
                    @* ─── PANEL RETRAIT FORCÉ INLINE ─── *@
                    else if (actionPocheId == p.Id && actionType == "retrait")
                    {
                        <div class="pocket-inline-action" style="border-color:var(--danger);">
                            <span style="font-size:0.75rem; color:var(--danger); font-weight:700;">
                                ⚠ Retrait anticipé — Cette poche est surveillée par un tuteur.
                            </span>
                            <div style="display:flex; gap:8px; margin-top:8px;">
                                <button class="btn btn-danger btn-sm" style="flex:1;" @onclick="() => CasserPoche(p.Id, tuteur: true)" disabled="@isProcessing">
                                    Confirmer le retrait
                                </button>
                                <button class="btn btn-sm" style="background:var(--bg-secondary);border:1px solid var(--border-color);" @onclick="AnnulerAction">Annuler</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="pocket-actions">
                            <button class="btn btn-primary btn-sm" style="flex:1;" @onclick="() => OuvrirBoost(p)" disabled="@isProcessing">Booster</button>
                            @if (p.DateCible > DateTime.UtcNow && estTuteur)
                            {
                                <button class="btn btn-danger btn-sm" style="flex:1;" @onclick="() => OuvrirRetraitForce(p)" disabled="@isProcessing">
                                    Retrait anticipé
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-success btn-sm" style="flex:1;" @onclick="() => CasserPoche(p.Id)" disabled="@isProcessing">
                                    Récupérer les fonds
                                </button>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        @* État vide engageant : icône de marque + bénéfice + CTA vers le formulaire *@
        <div class="epargne-empty">
            <div class="epargne-empty-icon"><i class="bi bi-piggy-bank"></i></div>
            <h5>Commencez votre première épargne</h5>
            <p>
                Fixez-vous un objectif — voyage, frais scolaires, projet perso — et mettez de
                côté à votre rythme. Votre argent reste récupérable à tout moment.
            </p>
            <button class="btn btn-primary" style="width: auto;" @onclick="FocusCreation">
                <i class="bi bi-plus-lg"></i> Créer mon premier objectif
            </button>
        </div>
    }
</div>

@code {
    private string nouvelObjectif = "";
    private decimal? montantInitial;
    private decimal? montantCible;
    private DateTime dateCible = DateTime.UtcNow.AddMonths(3);
    private List<SavingsPocket> mesPoches = new();
    private bool tuteurVisible;
    private bool tuteurAutorise => Bank.Profil.TuteurAutorise;
    private string emailTuteur = "";
    private long totalEpargne;
    private bool isProcessing;

    // Actions inline (boost / retrait forcé)
    private int? actionPocheId;
    private string actionType = "";
    private decimal? actionMontant;
    private ElementReference actionInputRef;

    // CTA de l'état vide → focus sur le champ « Nom de l'objectif »
    private ElementReference objectifInputRef;
    private async Task FocusCreation()
    {
        try { await objectifInputRef.FocusAsync(); } catch { }
    }

    protected override async Task OnInitializedAsync()
    {
        await ChargerPoches();
        emailTuteur = Bank.Profil.TuteurEmail;
    }

    private async Task ChargerPoches()
    {
        mesPoches = await Bank.GetPocketsAsync();
        totalEpargne = mesPoches.Sum(p => p.MontantActuel); // centimes
    }

    private async Task ValiderTuteur()
    {
        if (isProcessing || string.IsNullOrWhiteSpace(emailTuteur)) return;
        isProcessing = true;
        try
        {
            var success = await Bank.DefinirTuteur(emailTuteur);
            if (success)
                Notif.Notify($"Tuteur {emailTuteur} autorisé", NotificationType.SUCCESS);
            else
                Notif.Notify("Erreur lors de l'autorisation", NotificationType.ERROR);
        }
        finally { isProcessing = false; }
    }

    private async Task RevoquerTuteur()
    {
        if (isProcessing) return;
        isProcessing = true;
        try
        {
            var success = await Bank.RevoquerTuteur();
            if (success)
            {
                emailTuteur = "";
                Notif.Notify("Tuteur révoqué", NotificationType.INFO);
            }
        }
        finally { isProcessing = false; }
    }

    private async Task CreerPoche()
    {
        if (isProcessing) return;
        if ((montantInitial ?? 0) < 100)
        {
            Notif.Notify("Le minimum requis est de 100 DH", NotificationType.ERROR);
            return;
        }
        if ((montantCible ?? 0) > 0 && (montantCible ?? 0) < (montantInitial ?? 0))
        {
            Notif.Notify("L'objectif cible doit être supérieur au montant initial", NotificationType.ERROR);
            return;
        }

        isProcessing = true;
        try
        {
            var initCents = (long)((montantInitial ?? 0) * 100);
            var cibleCents = (montantCible ?? 0) > 0 ? (long)((montantCible ?? 0) * 100) : initCents * 4;
            if (await Bank.CreerPocheEpargne(nouvelObjectif, initCents, dateCible, cibleCents, tuteurVisible))
            {
                Notif.Notify($"Objectif '{nouvelObjectif}' ouvert avec succès", NotificationType.SUCCESS);
                nouvelObjectif = "";
                montantInitial = null;
                montantCible = null;
                tuteurVisible = false;
                await ChargerPoches();
            }
        }
        finally { isProcessing = false; }
    }

    private void OuvrirBoost(SavingsPocket p)
    {
        actionPocheId = p.Id;
        actionType    = "boost";
        actionMontant = null;
    }

    private void OuvrirRetraitForce(SavingsPocket p)
    {
        actionPocheId = p.Id;
        actionType    = "retrait";
    }

    private void AnnulerAction()
    {
        actionPocheId = null;
        actionType    = "";
        actionMontant = null;
    }

    private async Task ConfirmerBoost()
    {
        if (isProcessing || actionPocheId == null || actionMontant is null or <= 0) return;
        isProcessing = true;
        try
        {
            var success = await Bank.BoosterPocheAsync(actionPocheId.Value, (long)(actionMontant.Value * 100));
            if (success)
            {
                Notif.Notify($"Poche boostée de {actionMontant.Value:N2} DH", NotificationType.SUCCESS);
                AnnulerAction();
                await ChargerPoches();
            }
            else
                Notif.Notify("Fonds insuffisants", NotificationType.ERROR);
        }
        finally { isProcessing = false; }
    }

    private async Task CasserPoche(int id, bool tuteur = false)
    {
        if (isProcessing) return;
        isProcessing = true;
        try
        {
            if (await Bank.CasserPocheEpargne(id))
            {
                Notif.Notify(tuteur ? "Retrait effectué." : "Épargne récupérée.", NotificationType.INFO);
                AnnulerAction();
                await ChargerPoches();
            }
        }
        finally { isProcessing = false; }
    }
}
