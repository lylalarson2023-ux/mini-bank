@page "/"
@attribute [Authorize]
@inject BankService BankService
@inject CurrencyState Currency
@inject NavigationManager NavManager

<div class="content-area" style="max-width: 700px;">
    @if (isLoading)
    {
        <div class="adn-loader">CHARGEMENT...</div>
    }
    else
    {
        @* ─── BALANCE + CARTE ─── *@
        <div class="balance-card">
            <div class="balance-label">SOLDE TOTAL</div>
            <div class="balance-value">@((balance / 100m).ToString("N2")) <span class="currency">DH</span></div>
            <div class="balance-value-alt">@Currency.Formater(balance, Devise.XAF)</div>
        </div>

        <div class="bank-card @(carteDesign.FondClair ? "bank-card-clair" : "")" style="@CarteStyle">
            <div class="bank-card-top">
                <div style="display: flex; align-items: center;">
                    <div class="card-chip"></div>
                    <div class="card-contactless"></div>
                    <button class="card-palette-btn" title="Personnaliser le design de la carte" @onclick="OuvrirGalerie">
                        <i class="bi bi-palette-fill"></i>
                    </button>
                </div>
                <div class="card-status">
                    <div class="card-status-label">STATUT</div>
                    <div class="card-status-value">@BankService.Profil.GetRank()</div>
                    @if (BankService.Profil.Statut == UserStatus.STANDARD)
                    {
                        <a href="/profil" class="card-status-upgrade">Passer en Premium →</a>
                    }
                </div>
            </div>
            <div class="card-footer">
                <div>
                    <div class="card-footer-label">TITULAIRE</div>
                    <div class="card-footer-value">@BankService.Profil.Prenom?.ToUpper() @BankService.Profil.Nom?.ToUpper()</div>
                </div>
            </div>
            <div class="card-network"><span>ADN</span></div>
            <div class="card-disclaimer">Carte virtuelle · sans valeur bancaire réelle</div>
        </div>

        @* ─── GALERIE DE DESIGNS DE CARTE ─── *@
        @if (showGallery)
        {
            <div class="carte-gallery-overlay" @onclick="FermerGalerie"></div>
            <div class="carte-gallery">
                <div class="carte-gallery-head">
                    <h6 class="section-title" style="margin: 0;">DESIGN DE CARTE</h6>
                    <button class="carte-gallery-close" @onclick="FermerGalerie" title="Fermer">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <div class="carte-gallery-grid">
                    @foreach (var d in designsDebloques)
                    {
                        <button class="carte-swatch @(d.Id == carteDesign.Id ? "carte-swatch-active" : "")"
                                style="background: @d.Gradient; color: @d.Texte;@(d.Bord is null ? "" : $" box-shadow: inset 0 0 0 1.5px {d.Bord};")"
                                @onclick="() => ChoisirDesign(d)">
                            <span class="carte-swatch-nom">@d.Nom</span>
                            @if (d.Id == carteDesign.Id)
                            {
                                <i class="bi bi-check-circle-fill carte-swatch-check"></i>
                            }
                        </button>
                    }
                </div>
                @if (nbVerrouilles > 0)
                {
                    <div class="carte-gallery-hint">
                        <i class="bi bi-lock-fill"></i>
                        @if (BankService.Profil.Statut == UserStatus.PREMIUM)
                        {
                            <span>@nbVerrouilles designs exclusifs à débloquer en VIP</span>
                        }
                        else
                        {
                            <span>+@nbPremium designs en Premium · +@nbVip de plus en VIP</span>
                        }
                    </div>
                }
                @if (galleryErreur != null)
                {
                    <div class="carte-gallery-erreur">@galleryErreur</div>
                }
            </div>
        }

        @* ─── ACTIONS RAPIDES (fonctionnalités) ─── *@
        <div class="action-grid">
            <button class="action-btn" @onclick="HandleAddMoney">
                <i class="bi bi-plus-lg icon-gold"></i>
                Dépôt
            </button>
            <button class="action-btn" @onclick="HandleTransfer">
                <i class="bi bi-arrow-up-right icon-green"></i>
                Virement
            </button>
            <button class="action-btn" @onclick='() => NavManager.NavigateTo("/retrait")'>
                <i class="bi bi-cash-stack icon-blue"></i>
                Retrait
            </button>
            <button class="action-btn" @onclick='() => NavManager.NavigateTo("/epargne")'>
                <i class="bi bi-piggy-bank icon-gold"></i>
                Épargne
            </button>
        </div>

        @* ─── STATS MENSUELLES (cliquables → historique filtré) ─── *@
        <div class="form-row" style="margin-bottom: 16px;">
            <div class="stat-card stat-card-clickable" title="Voir les entrées des 30 derniers jours"
                 @onclick='() => NavManager.NavigateTo("/historique?type=entrees&periode=30j")'>
                <div class="stat-label">REVENUS (CE MOIS)</div>
                <div class="stat-value green">+@((revenusMois / 100m).ToString("N2")) DH</div>
            </div>
            <div class="stat-card stat-card-clickable" title="Voir les sorties des 30 derniers jours"
                 @onclick='() => NavManager.NavigateTo("/historique?type=sorties&periode=30j")'>
                <div class="stat-label">DÉPENSES (CE MOIS)</div>
                <div class="stat-value" style="color: var(--danger);">-@((depensesMois / 100m).ToString("N2")) DH</div>
            </div>
            <div class="stat-card stat-card-clickable" title="Voir les mouvements d'épargne"
                 @onclick='() => NavManager.NavigateTo("/historique?q=épargne")'>
                <div class="stat-label">ÉPARGNE TOTALE</div>
                <div class="stat-value" style="color: var(--blue-500);">@((totalEpargne / 100m).ToString("N2")) DH</div>
            </div>
        </div>

        @* ─── COURBE SOLDE 30 JOURS ─── *@
        @if (balanceCurve.Count > 1)
        {
            <div class="cyber-panel" style="padding: 16px; margin-bottom: 16px;">
                <h6 class="section-title" style="margin-bottom: 10px;">ÉVOLUTION DU SOLDE (30 JOURS)</h6>
                @((MarkupString)svgContent)
            </div>
        }

        @* ─── RÉSUMÉ ÉPARGNE ─── *@
        @if (savingsPockets.Any())
        {
            <h5 class="section-title" style="margin-top: 24px;">OBJECTIFS D'ÉPARGNE</h5>
            <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px;">
                @foreach (var p in savingsPockets)
                {
                    var pct = p.Progression;
                    <div class="card pocket-mini-clickable" style="border-left: 3px solid var(--blue-500); padding: 12px;"
                         title="Gérer cette épargne" @onclick='() => NavManager.NavigateTo("/epargne")'>
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
                            <span style="font-weight: 600; font-size: 0.8rem;">@p.Objectif.ToUpper()</span>
                            <span style="font-size: 0.75rem; font-weight: 700; color: var(--success);">
                                @((p.MontantActuel / 100m).ToString("N2")) / @((p.MontantCible / 100m).ToString("N2")) DH
                                <i class="bi bi-chevron-right" style="font-size: 0.65rem; color: var(--text-muted); margin-left: 4px;"></i>
                            </span>
                        </div>
                        <div class="mini-progress">
                            <div class="mini-progress-fill" style="width: @((int)Math.Min(pct, 100))%;"></div>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-top: 4px;">
                            <span style="font-size: 0.55rem; color: var(--text-muted);">@pct% atteint</span>
                            <span style="font-size: 0.55rem; color: var(--text-muted);">Échéance: @p.DateCible.ToShortDateString()</span>
                        </div>
                    </div>
                }
            </div>
        }

        @* ─── TRANSACTIONS RÉCENTES ─── *@
        <h5 class="section-title" style="margin-top: 24px;">ACTIVITE RECENTE</h5>
        @if (recentTransactions.Any())
        {
            @foreach (var tr in recentTransactions)
            {
                <div class="transaction-item tx-clickable" title="Voir le détail" @onclick="() => ToggleDetailTx(tr.Id)">
                    <div class="transaction-info">
                        <div class="tx-type">@tr.Type</div>
                        <div class="tx-date">@tr.Date.ToString("dd/MM HH:mm")</div>
                    </div>
                    <div style="display: flex; align-items: center; gap: 10px;">
                        <div class="transaction-amount @(tr.IsEntree ? "tx-positive" : "tx-negative")">
                            @(tr.IsEntree ? "+" : "-") @((tr.Montant / 100m).ToString("N2"))
                        </div>
                        <i class="bi bi-chevron-down tx-chevron @(detailTxId == tr.Id ? "open" : "")"></i>
                    </div>
                </div>
                @if (detailTxId == tr.Id)
                {
                    <div class="tx-detail">
                        <div><span>Libellé</span><strong>@(string.IsNullOrEmpty(tr.Libelle) ? tr.Type : tr.Libelle)</strong></div>
                        @if (!string.IsNullOrEmpty(tr.Motif))
                        {
                            <div><span>Motif</span><strong>@tr.Motif</strong></div>
                        }
                        <div><span>Date</span><strong>@tr.Date.ToString("dd/MM/yyyy à HH:mm")</strong></div>
                        @if (tr.Frais > 0)
                        {
                            <div><span>Frais</span><strong>@((tr.Frais / 100m).ToString("N2")) DH</strong></div>
                        }
                        <div><span>Solde après</span><strong>@((tr.SoldeApres / 100m).ToString("N2")) DH</strong></div>
                        <a href="/historique">Voir tout l'historique →</a>
                    </div>
                }
            }
        }
        else
        {
            <div class="empty-state">
                <p>AUCUNE TRANSACTION RECENTE</p>
            </div>
        }
    }
</div>

@code {
    private long balance;
    private List<Transaction> recentTransactions = new();
    private long revenusMois;
    private long depensesMois;
    private long totalEpargne;
    private List<SavingsPocket> savingsPockets = new();
    private bool isLoading = true;

    // Courbe 30 jours
    private List<(DateTime Jour, long Solde)> balanceCurve = new();
    private string svgContent = "";

    // Galerie de designs de carte (déblocage cumulatif selon le statut)
    private CarteDesign carteDesign = CarteDesigns.ParId(null);
    private List<CarteDesign> designsDebloques = new();
    private bool showGallery;
    private string? galleryErreur;
    private int nbVerrouilles, nbPremium, nbVip;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            carteDesign = CarteDesigns.ParId(BankService.Profil.CarteDesign);
            designsDebloques = CarteDesigns.Debloques(BankService.Profil.Statut);
            nbVerrouilles = CarteDesigns.Tous.Count - designsDebloques.Count;
            nbPremium = CarteDesigns.Tous.Count(d => d.StatutMin == UserStatus.PREMIUM);
            nbVip = CarteDesigns.Tous.Count(d => d.StatutMin == UserStatus.VIP);

            balance = await BankService.GetBalanceAsync();
            recentTransactions = await BankService.GetRecentTransactionsAsync(5);
            savingsPockets = await BankService.GetPocketsAsync();
            var stats = await BankService.GetDashboardStatsAsync();
            revenusMois = stats.RevenusMois;
            depensesMois = stats.DepensesMois;
            totalEpargne = stats.TotalEpargne;
            balanceCurve = await BankService.GetBalanceCurve30DaysAsync();
            BuildSvgData();
        }
        finally { isLoading = false; }
    }

    private void BuildSvgData()
    {
        if (balanceCurve.Count < 2) return;

        // Géométrie : gouttière gauche pour l'axe Y, zone de tracé à droite
        const double gutterL = 58;   // espace réservé aux étiquettes de montant
        const double padTop  = 12;
        const double H       = 74;   // hauteur de la zone de tracé
        const double plotW   = 530;  // largeur de la zone de tracé
        const double x0      = gutterL;
        const double x1      = gutterL + plotW;
        const double baseY   = padTop + H;

        long minS = balanceCurve.Min(p => p.Solde);
        long maxS = balanceCurve.Max(p => p.Solde);
        double range = Math.Max(maxS - minS, 1);
        int n = balanceCurve.Count - 1;

        (double px, double py) Pt(int i)
        {
            double frac = (maxS == minS) ? 0.5 : (balanceCurve[i].Solde - minS) / range;
            return (x0 + (i / (double)n) * plotW, padTop + (1.0 - frac) * H);
        }

        // Coordonnées SVG TOUJOURS en culture invariante (séparateur '.'),
        // sinon la culture FR produit des virgules qui cassent le path/les attributs.
        static string Inv(FormattableString fs) => FormattableString.Invariant(fs);

        var pts = Enumerable.Range(0, balanceCurve.Count).Select(Pt).ToList();
        string stroke = "M" + string.Join(" L", pts.Select(p => Inv($"{p.px:F1},{p.py:F1}")));
        string fill   = Inv($"M{x0:F1},{baseY:F1} L") + string.Join(" L", pts.Select(p => Inv($"{p.px:F1},{p.py:F1}"))) + Inv($" L{x1:F1},{baseY:F1} Z");
        var    last   = pts[^1];

        // Format compact des montants (1,1M / 12k / 540)
        static string Compact(long centimes)
        {
            decimal dh = centimes / 100m;
            if (Math.Abs(dh) >= 1_000_000m) return (dh / 1_000_000m).ToString("0.#") + "M";
            if (Math.Abs(dh) >= 1_000m)     return (dh / 1_000m).ToString("0.#") + "k";
            return dh.ToString("0");
        }
        string maxLbl = Compact(maxS) + " DH";
        string minLbl = Compact(minS) + " DH";
        string d0  = System.Net.WebUtility.HtmlEncode(balanceCurve[0].Jour.ToString("dd/MM"));
        string d14 = System.Net.WebUtility.HtmlEncode(balanceCurve[14].Jour.ToString("dd/MM"));
        string d29 = System.Net.WebUtility.HtmlEncode(balanceCurve[^1].Jour.ToString("dd/MM"));
        double xMid = x0 + plotW / 2;

        string yMaxLabels = maxS != minS
            ? Inv($@"<text x=""{x0 - 8:F1}"" y=""{padTop + 3:F1}"" fill=""#6b7280"" font-size=""9"" text-anchor=""end"">{maxLbl}</text>")
              + Inv($@"<text x=""{x0 - 8:F1}"" y=""{baseY:F1}"" fill=""#6b7280"" font-size=""9"" text-anchor=""end"">{minLbl}</text>")
            : "";

        svgContent = Inv($@"<svg viewBox=""0 0 600 120"" style=""width:100%;display:block;"">
  <defs>
    <linearGradient id=""balGrad"" x1=""0"" y1=""0"" x2=""0"" y2=""1"">
      <stop offset=""0%"" stop-color=""#30B880"" stop-opacity=""0.28""/>
      <stop offset=""100%"" stop-color=""#30B880"" stop-opacity=""0""/>
    </linearGradient>
  </defs>
  <line x1=""{x0:F1}"" y1=""{padTop:F1}"" x2=""{x1:F1}"" y2=""{padTop:F1}"" stroke=""#ffffff"" stroke-opacity=""0.05""/>
  <line x1=""{x0:F1}"" y1=""{baseY:F1}"" x2=""{x1:F1}"" y2=""{baseY:F1}"" stroke=""#ffffff"" stroke-opacity=""0.05""/>
  <path d=""{fill}"" fill=""url(#balGrad)""/>
  <path d=""{stroke}"" fill=""none"" stroke=""#30B880"" stroke-width=""2"" stroke-linejoin=""round"" stroke-linecap=""round""/>
  <circle cx=""{last.px:F1}"" cy=""{last.py:F1}"" r=""3.5"" fill=""#30B880""/>
  {yMaxLabels}
  <text x=""{x0:F1}"" y=""114"" fill=""#6b7280"" font-size=""9"" text-anchor=""start"">{d0}</text>
  <text x=""{xMid:F1}"" y=""114"" fill=""#6b7280"" font-size=""9"" text-anchor=""middle"">{d14}</text>
  <text x=""{x1:F1}"" y=""114"" fill=""#6b7280"" font-size=""9"" text-anchor=""end"">{d29}</text>
</svg>");
    }

    private void HandleAddMoney() => NavManager.NavigateTo("/depot");
    private void HandleTransfer() => NavManager.NavigateTo("/virement");

    // Détail de transaction déplié en place (clic sur une ligne)
    private int? detailTxId;
    private void ToggleDetailTx(int id) => detailTxId = detailTxId == id ? null : id;

    // --- Galerie de designs de carte ---
    private string CarteStyle =>
        $"background: {carteDesign.Gradient}; color: {carteDesign.Texte};"
        + (carteDesign.Bord is null ? "" : $" border: 1.5px solid {carteDesign.Bord};");

    private void OuvrirGalerie()
    {
        galleryErreur = null;
        showGallery = true;
    }

    private void FermerGalerie() => showGallery = false;

    // Applique le design immédiatement (persisté serveur) ; la galerie reste
    // ouverte pour essayer plusieurs designs.
    private async Task ChoisirDesign(CarteDesign d)
    {
        var (ok, msg) = await BankService.ChangerCarteDesignAsync(d.Id);
        if (ok)
        {
            carteDesign = d;
            galleryErreur = null;
        }
        else
        {
            galleryErreur = msg;
        }
    }
}
