@inject BankService Bank

<div class="bank-card">
    <div class="bank-card-watermark">ADN</div>
    <div class="bank-card-top">
        <div class="card-chip"></div>
        <div class="card-status">
            <div class="card-status-label">STATUT</div>
            <div class="card-status-value">@Bank.Profil.GetRank()</div>
            @if (Bank.Profil.Statut == UserStatus.STANDARD)
            {
                <a href="/profil" class="card-status-upgrade">Passer en Premium →</a>
            }
        </div>
    </div>
    <div class="card-number">
        **** **** **** @(Bank.Profil.Id.ToString("D4"))
    </div>
    <div class="card-footer">
        <div>
            <div class="card-footer-label">TITULAIRE</div>
            <div class="card-footer-value">@Bank.Profil.Prenom.ToUpper() @Bank.Profil.Nom.ToUpper()</div>
        </div>
        <div style="text-align: right;">
            <div class="card-footer-label">SOLDE</div>
            <div class="card-balance" style="font-size: 1rem;">@((Bank.Profil.Solde / 100m).ToString("N2")) DH</div>
        </div>
    </div>
    <div class="card-disclaimer">Carte virtuelle · sans valeur bancaire réelle</div>
</div>
