@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Authorization
@inject MBANK_ETUDIANT.Services.BankService Bank
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<div class="page">
    @if (isCheckingSession)
    {
        <div class="auth-loading">
            <div class="scanner"></div>
            <p>VERIFICATION ADN_ID...</p>
        </div>
    }
    else if (!Bank.EstConnecte)
    {
        <main class="auth-layout">
            @Body
        </main>
    }
    else
    {
        @* Overlay for mobile sidebar *@
        @if (sidebarOpen)
        {
            <div class="sidebar-overlay" @onclick="ToggleSidebar"></div>
        }

        <div class="sidebar @(sidebarOpen ? "sidebar-open" : "")">
            <div class="logo-area">
                <div class="logo-text">
                    <span class="gold">M</span>BANK<span class="suffix">ADN</span>
                </div>
                <div class="logo-divider"></div>
            </div>
            <NavMenu />
        </div>

        <div class="main-area">
            <div class="top-bar">
                <div class="top-bar-left">
                    <button class="hamburger" @onclick="ToggleSidebar" aria-label="Menu">
                        <span></span>
                        <span></span>
                        <span></span>
                    </button>
                    <div class="server-status">
                        <span class="dot"></span>
                        <span class="status-label">SYSTEME: OPERATIONNEL</span>
                    </div>
                </div>

                <div class="user-info">
                    <button class="theme-toggle-btn" @onclick="ToggleTheme" title="Changer le thème">
                        <i id="theme-icon" class="bi bi-sun-fill"></i>
                    </button>
                    <button class="notif-bell" @onclick="GoToNotifications" title="Notifications">
                        <i class="bi bi-bell-fill"></i>
                        @if (notifCount > 0)
                        {
                            <span class="notif-badge">@notifCount</span>
                        }
                    </button>
                    <div class="user-badge">
                        <div class="rank">STUDENT</div>
                        <div class="name">@Bank.Profil.Prenom?.ToUpper() @Bank.Profil.Nom?.ToUpper()</div>
                    </div>
                    <button class="btn-logout" @onclick="HandleLogout" title="DECONNEXION">
                        <i class="bi bi-power"></i>
                    </button>
                </div>
            </div>

            <div class="content-area">
                @Body
            </div>

            <footer class="legal-footer-bar">
                <div class="footer-links">
                    <a href="/cgu">CGU</a>
                    <a href="/confidentialite">Confidentialité</a>
                    <a href="/mentions-legales">Mentions Légales</a>
                </div>
                <span class="footer-copy">&copy; @DateTime.Now.Year MBANK CORPORATION. Tous droits réservés.</span>
            </footer>
        </div>

        <MBANK_ETUDIANT.Components.Layout.NotificationOverlay />
    }
</div>

@code
{
    private bool isCheckingSession = true;
    private bool sidebarOpen = false;
    private int notifCount;

    private async Task ToggleTheme()
    {
        try { await JS.InvokeVoidAsync("mbankTheme.toggle"); }
        catch { }
    }

    protected override async Task OnInitializedAsync()
    {
        isCheckingSession = true;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var userId = int.Parse(user.FindFirst(ClaimTypes.NameIdentifier)!.Value);
            await Bank.InitializeAsync(userId);
            notifCount = await Bank.GetUnreadCountAsync();
        }

        isCheckingSession = false;

        if (!Bank.EstConnecte && !Nav.Uri.Contains("/login") && !Nav.Uri.EndsWith("/register") && !Nav.Uri.Contains("access-denied")
            && !Nav.Uri.EndsWith("/cgu") && !Nav.Uri.EndsWith("/confidentialite") && !Nav.Uri.EndsWith("/mentions-legales"))
        {
            Nav.NavigateTo("/login");
        }
    }

    private void ToggleSidebar()
    {
        sidebarOpen = !sidebarOpen;
    }

    private async Task HandleLogout()
    {
        Bank.Deconnexion();
        Nav.NavigateTo("/api/auth/logout", forceLoad: true);
    }

    private void GoToNotifications()
    {
        Nav.NavigateTo("/notifications");
    }
}
