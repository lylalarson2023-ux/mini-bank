@implements IDisposable
@inherits LayoutComponentBase
@inject ADN_pay.Services.BankService Bank
@inject ADN_pay.Services.CurrencyState Currency
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@using ADN_pay.Models
@using Microsoft.AspNetCore.Components.Routing

<div class="page">
    @if (isCheckingSession)
    {
        <div class="auth-loading">
            <span class="adn-wordmark" style="font-size: 2.2rem; margin-bottom: 22px;">
                <span class="wm-adn">ADN</span><span class="wm-pay">_pay</span>
            </span>
            <div class="scanner"></div>
            <p>VÉRIFICATION ADN_ID...</p>
        </div>
    }
    else if (!Bank.EstConnecte)
    {
        <main class="auth-layout">
            @Body
        </main>
    }
    else
    {
        @* Overlay for mobile sidebar *@
        @if (sidebarOpen)
        {
            <div class="sidebar-overlay" @onclick="ToggleSidebar"></div>
        }

        <div class="sidebar @(sidebarOpen ? "sidebar-open" : "")">
            <div class="logo-area">
                <img src="images/logo_adn_pay_blanc.png" alt="ADN_pay" class="sidebar-logo" />
                <div class="logo-divider"></div>
                <div class="adncorp-sidebar">ADN_corp</div>
            </div>
            <NavMenu />
        </div>

        <div class="main-area">
            <div class="top-bar">
                <div class="top-bar-left">
                    <button class="hamburger" @onclick="ToggleSidebar" aria-label="Menu">
                        <span></span>
                        <span></span>
                        <span></span>
                    </button>
                    <div class="server-status">
                        <span class="dot"></span>
                        <span class="status-label">SYSTEME: OPERATIONNEL</span>
                    </div>
                </div>

                <div class="user-info">
                    <div class="solde-badge" title="Solde disponible (équivalent en euros)">
                        <i class="bi bi-wallet2"></i>
                        <span class="solde-badge-value">@Currency.Formater(Bank.Profil.Solde, Devise.EUR)</span>
                    </div>
                    <button class="theme-toggle-btn" @onclick="ToggleTheme" title="Changer le thème">
                        <i id="theme-icon" class="bi bi-sun-fill"></i>
                    </button>
                    <div class="notif-wrapper">
                        @if (showNotifDropdown)
                        {
                            <div class="notif-overlay" @onclick="CloseNotifDropdown"></div>
                        }
                        <button class="notif-bell" @onclick="ToggleNotifDropdown" title="Notifications">
                            <i class="bi bi-bell-fill"></i>
                            @if (notifCount > 0)
                            {
                                <span class="notif-badge">@notifCount</span>
                            }
                        </button>
                        @if (showNotifDropdown)
                        {
                            <div class="notif-dropdown">
                                @if (recentNotifs.Any())
                                {
                                    @foreach (var n in recentNotifs)
                                    {
                                        <div class="notif-dropdown-item @(!n.Lu ? "notif-unread-bg" : "")" @onclick="() => NaviguerNotification(n)">
                                            <div class="notif-dd-icon">
                                                @if (n.Type == "SUCCESS") { <i class="bi bi-check-circle-fill" style="color: var(--success);"></i> }
                                                else if (n.Type == "ERROR") { <i class="bi bi-exclamation-circle-fill" style="color: var(--danger);"></i> }
                                                else { <i class="bi bi-info-circle-fill" style="color: var(--blue-500);"></i> }
                                            </div>
                                            <div class="notif-dd-body">
                                                <div class="notif-dd-cat">@n.Categorie</div>
                                                <div class="notif-dd-msg">@n.Message</div>
                                                <div class="notif-dd-date">@n.Date.ToString("dd/MM HH:mm")</div>
                                            </div>
                                        </div>
                                    }
                                    <div class="notif-dropdown-footer" @onclick="GoToNotifPage">
                                        VOIR TOUT
                                    </div>
                                }
                                else
                                {
                                    <div class="notif-dropdown-empty">Aucune notification</div>
                                }
                            </div>
                        }
                    </div>
                    <div class="user-badge">
                        <div class="rank">STUDENT</div>
                        <div class="name">@Bank.Profil.Prenom?.ToUpper() @Bank.Profil.Nom?.ToUpper()</div>
                    </div>
                </div>
            </div>

            <div class="content-area">
                @if (!Bank.Profil.EmailVerifie && !Nav.Uri.Contains("/verifier-email"))
                {
                    <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap; justify-content:space-between;
                                background: rgba(240,170,40,0.12); border:1px solid rgba(240,170,40,0.5); color:#c98a10;
                                padding:12px 16px; border-radius:10px; margin-bottom:16px; font-size:0.82rem;">
                        <span><i class="bi bi-exclamation-triangle-fill"></i> Votre adresse e-mail n'est pas encore confirmée.</span>
                        <a href="/verifier-email" class="btn btn-primary btn-sm" style="white-space:nowrap;">Confirmer maintenant</a>
                    </div>
                }
                @Body
            </div>

            <footer class="legal-footer-bar">
                <div class="footer-links">
                    <a href="/cgu">CGU</a>
                    <a href="/confidentialite">Confidentialité</a>
                    <a href="/mentions-legales">Mentions Légales</a>
                </div>
                <div style="display: flex; align-items: center; gap: 20px;">
                    <span class="footer-copy" style="display: flex; align-items: center; gap: 8px;">
                        <svg width="22" height="16" viewBox="0 0 40 30" fill="none" style="opacity: 0.5;">
                            <defs>
                                <linearGradient id="adncorpGradFooter" x1="0%" y1="0%" x2="100%" y2="100%">
                                    <stop offset="0%" stop-color="#0099CC"/>
                                    <stop offset="100%" stop-color="#30B880"/>
                                </linearGradient>
                            </defs>
                            <ellipse cx="12" cy="8" rx="4" ry="7" stroke="url(#adncorpGradFooter)" stroke-width="1.2" fill="none" opacity="0.6"/>
                            <ellipse cx="12" cy="22" rx="4" ry="7" stroke="url(#adncorpGradFooter)" stroke-width="1.2" fill="none" opacity="0.6"/>
                            <ellipse cx="28" cy="8" rx="4" ry="7" stroke="url(#adncorpGradFooter)" stroke-width="1.2" fill="none" opacity="0.6"/>
                            <ellipse cx="28" cy="22" rx="4" ry="7" stroke="url(#adncorpGradFooter)" stroke-width="1.2" fill="none" opacity="0.6"/>
                            <line x1="8" y1="10" x2="16" y2="20" stroke="url(#adncorpGradFooter)" stroke-width="1" opacity="0.4"/>
                            <line x1="8" y1="20" x2="16" y2="10" stroke="url(#adncorpGradFooter)" stroke-width="1" opacity="0.4"/>
                            <line x1="24" y1="10" x2="32" y2="20" stroke="url(#adncorpGradFooter)" stroke-width="1" opacity="0.4"/>
                            <line x1="24" y1="20" x2="32" y2="10" stroke="url(#adncorpGradFooter)" stroke-width="1" opacity="0.4"/>
                        </svg>
                        &copy; @DateTime.Now.Year <span class="adn-wordmark" style="font-size: 0.85rem;"><span class="wm-adn">ADN</span><span class="wm-pay">_pay</span></span> by <strong style="color: var(--blue-500); font-weight: 800;">ADNcorp</strong>
                    </span>
                    <span class="footer-build" title="Version actuellement déployée (date de build · commit git)"
                          style="opacity: 0.45; font-size: 0.7rem; letter-spacing: 0.3px;">
                        v@(ADN_pay.Services.BuildInfo.Short)
                    </span>
                </div>
            </footer>
        </div>

        <ADN_pay.Components.Layout.NotificationOverlay />
    }
</div>

@code
{
    private bool isCheckingSession = true;
    private bool sidebarOpen = false;
    private int notifCount;
    private Action? _notifHandler;
    private bool showNotifDropdown;
    private List<NotificationHistory> recentNotifs = new();

    private async Task ToggleTheme()
    {
        try { await JS.InvokeVoidAsync("adnTheme.toggle"); }
        catch { }
    }

    protected override async Task OnInitializedAsync()
    {
        isCheckingSession = true;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var userId = int.Parse(user.FindFirst(ClaimTypes.NameIdentifier)!.Value);
            await Bank.InitializeAsync(userId);
            notifCount = await Bank.GetUnreadCountAsync();
        }

        isCheckingSession = false;

        if (!Bank.EstConnecte && !Nav.Uri.Contains("/login") && !Nav.Uri.EndsWith("/register") && !Nav.Uri.Contains("access-denied")
            && !Nav.Uri.Contains("/mot-de-passe-oublie")
            && !Nav.Uri.EndsWith("/cgu") && !Nav.Uri.EndsWith("/confidentialite") && !Nav.Uri.EndsWith("/mentions-legales"))
        {
            Nav.NavigateTo("/login");
        }

        _notifHandler = () =>
        {
            notifCount = Bank.NotifCount;
            StateHasChanged();
        };
        Bank.NotifCountChanged += _notifHandler;

        // Solde affiché dans la barre : rechargé depuis la base à chaque changement
        // de page (couvre aussi les crédits hors session, ex. dépôt validé par l'admin).
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
        => _ = InvokeAsync(async () =>
        {
            if (Bank.EstConnecte)
            {
                try { await Bank.RefreshSoldeAsync(); } catch { }
            }
            StateHasChanged();
        });

    public void Dispose()
    {
        if (_notifHandler != null)
            Bank.NotifCountChanged -= _notifHandler;
        Nav.LocationChanged -= OnLocationChanged;
    }

    private void ToggleSidebar()
    {
        sidebarOpen = !sidebarOpen;
    }

    private async Task ToggleNotifDropdown()
    {
        showNotifDropdown = !showNotifDropdown;
        if (showNotifDropdown)
        {
            recentNotifs = await Bank.GetNotificationsAsync(3);
        }
    }
    private void CloseNotifDropdown()
    {
        showNotifDropdown = false;
    }
    private void GoToNotifPage()
    {
        showNotifDropdown = false;
        // La liste des notifications vit dans Paramètres > onglet Notifications.
        Nav.NavigateTo("/parametres/notifications");
    }
    private void NaviguerNotification(NotificationHistory n)
    {
        showNotifDropdown = false;
        var cat = n.Categorie;
        var route = cat switch
        {
            "CONNEXION" or "SECURITE" => "/parametres/securite",
            "PARAMETRES" or "PLAFOND" or "TUTEUR" => "/parametres",
            "PROFIL" or "COMPTE" or "KYC" => "/profil",
            "EPARGNE" => "/epargne",
            "VIREMENT" or "BENEFICIAIRE" => "/virement",
            "DÉPÔT" or "DEPOT" => "/depot",
            "RETRAIT" => "/retrait",
            "CRÉDIT" => "/credits",
            _ => "/parametres/notifications"
        };
        Nav.NavigateTo(route);
    }
}
