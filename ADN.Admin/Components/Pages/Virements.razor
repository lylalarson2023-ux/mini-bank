@page "/virements"
@attribute [Authorize(Policy = "AdminOnly")]
@rendermode InteractiveServer
@using ADN_pay.Models
@inject BankTransferService Transferts
@inject ADN_pay.Admin.Services.ToastService Toasts

<PageTitle>Dépôts manuels — ADN_pay Admin</PageTitle>

<div class="page">
    <h1 class="page-title">Dépôts manuels</h1>
    <div class="page-sub">Valider les virements bancaires et envois Mobile Money à réception des fonds</div>

    <div class="panel" style="margin-top:20px">
        <div class="panel-head"><i class="bi bi-bank"></i> Demandes en attente</div>
        <div class="panel-body">
            @if (loading)
            {
                <div class="empty">Chargement…</div>
            }
            else if (pending.Count == 0)
            {
                <div class="empty">Aucune demande de virement en attente</div>
            }
            else
            {
                @foreach (var d in pending)
                {
                    <div class="req-row" @key="d.Id">
                        <div>
                            <div class="rr-name">
                                @d.User?.Prenom @d.User?.Nom <span class="muted">· réf</span> <strong>@d.Reference</strong>
                                <span class="muted">· @(d.Canal == BankTransferRequest.CanalMobileMoney ? "Mobile Money" : "Virement")</span>
                            </div>
                            <div class="muted">
                                #@d.UserId · @d.User?.Email · demandé le @d.DateCreation.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                @if (d.MontantConverti is not null)
                                {
                                    <text> · montant attendu : <strong>@d.MontantConverti @d.DeviseConvertie</strong></text>
                                }
                                @if (d.FraisCentimes > 0)
                                {
                                    <text> · frais de change : <strong>@Money(d.FraisCentimes) MAD</strong></text>
                                }
                            </div>
                        </div>
                        <div class="req-amount">+@Money(d.MontantCentimes) MAD</div>
                        <div class="actions">
                            <button class="btn btn-primary btn-sm" disabled="@busy" @onclick="() => Valider(d.Id)">Virement reçu — créditer</button>
                            <button class="btn btn-ghost btn-sm danger" disabled="@busy" @onclick="() => OpenReject(d.Id)">Rejeter</button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="panel" style="margin-top:16px">
        <div class="panel-body muted" style="font-size:.85rem">
            <i class="bi bi-info-circle"></i>
            Validez uniquement après avoir vu les fonds arriver (relevé bancaire pour un
            virement, SMS de l'opérateur pour un envoi Mobile Money) avec la bonne référence
            en motif et le montant attendu. Le crédit est idempotent : un double-clic ne
            créditera jamais deux fois la même référence.
        </div>
    </div>
</div>

@if (rejectId > 0)
{
    <div class="modal-overlay" @onclick="() => rejectId = 0">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-head"><i class="bi bi-x-circle-fill" style="color:var(--danger)"></i> Rejeter la demande de virement</div>
            <div class="modal-body">
                <p class="muted">Demande #@rejectId</p>
                <div class="field">
                    <label>Motif du rejet</label>
                    <textarea class="input" rows="3" @bind="rejectMotif" placeholder="Visible par l'utilisateur (ex. virement jamais reçu, montant différent…)"></textarea>
                </div>
                <div class="actions" style="margin-top:14px">
                    <button class="btn btn-primary danger btn-block" disabled="@(busy || string.IsNullOrWhiteSpace(rejectMotif))" @onclick="ConfirmReject">@(busy ? "…" : "Rejeter la demande")</button>
                    <button class="btn btn-ghost btn-block" @onclick="() => rejectId = 0">Annuler</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private bool busy;
    private List<BankTransferRequest> pending = new();
    private int rejectId;
    private string rejectMotif = "";

    private static string Money(long c) => (c / 100m).ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("fr-FR"));

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        loading = true;
        pending = await Transferts.GetDemandesEnAttenteAsync();
        loading = false;
    }

    private async Task Valider(int id)
    {
        busy = true;
        try
        {
            if (await Transferts.ValiderAsync(id))
            {
                Toasts.Success("Virement validé, compte crédité.");
                await Reload();
            }
            else Toasts.Error("Échec : demande introuvable ou déjà traitée.");
        }
        finally { busy = false; }
    }

    private void OpenReject(int id) { rejectId = id; rejectMotif = ""; }

    private async Task ConfirmReject()
    {
        busy = true;
        try
        {
            if (await Transferts.RejeterAsync(rejectId, rejectMotif))
            {
                Toasts.Success("Demande rejetée, l'utilisateur est notifié.");
                rejectId = 0;
                await Reload();
            }
            else Toasts.Error("Échec du rejet.");
        }
        finally { busy = false; }
    }
}
