@page "/credits"
@attribute [Authorize(Policy = "AdminOnly")]
@rendermode InteractiveServer
@inject AdminService Admin
@inject CreditService Credit
@inject ADN_pay.Admin.Services.ToastService Toasts

<PageTitle>Crédits — ADN_pay Admin</PageTitle>

<div class="page">
    <h1 class="page-title">Crédits</h1>
    <div class="page-sub">Octroi et traitement des demandes de crédit</div>

    <div class="grid two-col" style="margin-top:20px">
        <div class="panel">
            <div class="panel-head"><i class="bi bi-currency-exchange"></i> Octroi de crédit</div>
            <div class="panel-body">
                @if (target is null)
                {
                    <UserSearchBox OnSelect="OnPick" Placeholder="Chercher le bénéficiaire…" />
                }
                else
                {
                    <div class="selected">
                        <div>
                            <strong>#@target.Id @target.Prenom @target.Nom</strong>
                            <div class="muted">@target.Email · Solde @Money(target.Solde) MAD · @target.NiveauEtude</div>
                        </div>
                        <button class="btn btn-ghost btn-sm" @onclick="() => target = null">Changer</button>
                    </div>

                    <div class="field" style="margin-top:14px">
                        <label>Montant du crédit (MAD)</label>
                        <input class="input" type="number" min="0" step="0.01" @bind="amount" placeholder="0.00" />
                    </div>
                    <button class="btn btn-primary btn-block" disabled="@(amount is null or <= 0 || busy)" @onclick="Accorder">
                        @(busy ? "Traitement…" : "Accorder le crédit")
                    </button>
                    <button class="btn btn-ghost btn-block" style="margin-top:8px" disabled="@busy" @onclick="Eligibilite">
                        Vérifier l'éligibilité
                    </button>
                }
            </div>
        </div>

        <div class="panel">
            <div class="panel-head"><i class="bi bi-hourglass-split"></i> Demandes en attente</div>
            <div class="panel-body">
                @if (loading)
                {
                    <div class="empty">Chargement…</div>
                }
                else if (pending.Count == 0)
                {
                    <div class="empty">Aucune demande de crédit en attente</div>
                }
                else
                {
                    @foreach (var u in pending)
                    {
                        <div class="req-row" @key="u.Id">
                            <div>
                                <div class="rr-name">@u.Prenom @u.Nom</div>
                                <div class="muted">#@u.Id · @u.Email · @u.NiveauEtude</div>
                            </div>
                            <div class="req-amount">+@Money(u.PendingCreditAmount) MAD</div>
                            <div class="actions">
                                <button class="btn btn-primary btn-sm" disabled="@busy" @onclick="() => Approuver(u.Id)">Approuver</button>
                                <button class="btn btn-ghost btn-sm danger" disabled="@busy" @onclick="() => OpenReject(u.Id)">Rejeter</button>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@if (rejectId > 0)
{
    <div class="modal-overlay" @onclick="() => rejectId = 0">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-head"><i class="bi bi-x-circle-fill" style="color:var(--danger)"></i> Rejeter la demande de crédit</div>
            <div class="modal-body">
                <p class="muted">Utilisateur #@rejectId</p>
                <div class="field">
                    <label>Motif du rejet</label>
                    <textarea class="input" rows="3" @bind="rejectMotif" placeholder="Visible par l'utilisateur"></textarea>
                </div>
                <div class="actions" style="margin-top:14px">
                    <button class="btn btn-primary danger btn-block" disabled="@(busy || string.IsNullOrWhiteSpace(rejectMotif))" @onclick="ConfirmReject">@(busy ? "…" : "Rejeter le crédit")</button>
                    <button class="btn btn-ghost btn-block" @onclick="() => rejectId = 0">Annuler</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private bool busy;
    private UserProfile? target;
    private decimal? amount;
    private List<UserProfile> pending = new();
    private int rejectId;
    private string rejectMotif = "";

    private static string Money(long c) => (c / 100m).ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("fr-FR"));

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        loading = true;
        var dossiers = await Admin.GetDossiersEnAttenteAsync();
        pending = dossiers.Where(u => u.PendingCreditRequest).ToList();
        loading = false;
    }

    private void OnPick(UserProfile u) { target = u; amount = null; }

    private async Task Accorder()
    {
        if (busy || target is null || amount is null or <= 0) return;
        busy = true;
        try
        {
            if (await Admin.ApprouverCredit(target.Id, (long)(amount.Value * 100)))
            {
                Toasts.Success($"Crédit de {amount.Value:N2} MAD accordé au compte #{target.Id}.");
                target = null; amount = null;
                await Reload();
            }
            else Toasts.Error("Échec : compte introuvable.");
        }
        finally { busy = false; }
    }

    private async Task Eligibilite()
    {
        if (busy || target is null) return;
        busy = true;
        try
        {
            var ok = await Credit.VerifierEligibiliteCredit(target.Id);
            if (ok) Toasts.Success("Bénéficiaire éligible au crédit.");
            else Toasts.Error("Non éligible (statut STANDARD ou solde insuffisant).");
        }
        finally { busy = false; }
    }

    private async Task Approuver(int id)
    {
        if (busy) return;
        busy = true;
        try
        {
            if (await Admin.ApprouverCredit(id)) { Toasts.Success("Crédit approuvé et versé."); await Reload(); }
            else Toasts.Error("Échec de l'approbation.");
        }
        finally { busy = false; }
    }

    private void OpenReject(int id) { rejectId = id; rejectMotif = ""; }

    private async Task ConfirmReject()
    {
        if (busy || rejectId <= 0 || string.IsNullOrWhiteSpace(rejectMotif)) return;
        busy = true;
        try
        {
            if (await Admin.RejeterCreditAsync(rejectId, rejectMotif)) { Toasts.Success("Demande de crédit rejetée."); rejectId = 0; await Reload(); }
            else Toasts.Error("Échec du rejet.");
        }
        finally { busy = false; }
    }
}
