@inherits LayoutComponentBase
@using System.Security.Claims
@inject AuthenticationStateProvider AuthProvider
@inject Microsoft.EntityFrameworkCore.IDbContextFactory<ADN_pay.Data.BankDbContext> DbFactory
@inject UserContext UserCtx
@inject IWebHostEnvironment HostEnv

<div class="admin-shell">
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="logo">ADN_pay</div>
            <div class="sub">ADMINISTRATION</div>
        </div>
        <nav class="sidebar-nav">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All"><i class="bi bi-speedometer2"></i> Tableau de bord</NavLink>
            <NavLink class="nav-link" href="kyc"><i class="bi bi-shield-check"></i> Dossiers KYC</NavLink>
            <NavLink class="nav-link" href="credits"><i class="bi bi-currency-exchange"></i> Crédits</NavLink>
            <NavLink class="nav-link" href="depot"><i class="bi bi-cash-stack"></i> Dépôt</NavLink>
            <NavLink class="nav-link" href="virements"><i class="bi bi-bank"></i> Dépôts manuels</NavLink>
            <NavLink class="nav-link" href="retraits-mobilemoney"><i class="bi bi-phone"></i> Retraits Mobile Money</NavLink>
            <NavLink class="nav-link" href="utilisateurs"><i class="bi bi-people"></i> Utilisateurs</NavLink>
            <NavLink class="nav-link" href="scoring"><i class="bi bi-bar-chart-line"></i> Scoring</NavLink>
            <NavLink class="nav-link" href="transactions"><i class="bi bi-activity"></i> Transactions</NavLink>
            <NavLink class="nav-link" href="tuteurs"><i class="bi bi-people-fill"></i> Tuteurs</NavLink>
            <NavLink class="nav-link" href="logs"><i class="bi bi-journal-text"></i> Logs</NavLink>
        </nav>
        <div class="sidebar-foot">
            <a class="btn btn-ghost btn-block btn-sm" href="/auth/signout"><i class="bi bi-box-arrow-right"></i> Déconnexion</a>
        </div>
    </aside>

    <div class="content">
        <header class="topbar">
            <div><span class="dot"></span> Session admin active</div>
            <div style="display:flex; align-items:center; gap:14px;">
                @* Bandeau base active : évite de réinitialiser un mot de passe sur la base
                   DEV en croyant toucher la PROD (bases distinctes selon le lanceur). *@
                <span title="@dbPath"
                      style="@($"font-size:.68rem; font-weight:700; letter-spacing:.5px; padding:3px 10px; border-radius:6px; {(isProd ? "background:rgba(48,184,128,.15); color:#30B880; border:1px solid rgba(48,184,128,.4);" : "background:rgba(240,170,40,.15); color:#f0aa28; border:1px solid rgba(240,170,40,.5);")}")">
                    @(isProd ? "PROD" : "DEV") · @dbLabel
                </span>
                <div class="who">Connecté : <strong>@adminName</strong></div>
            </div>
        </header>
        @Body
    </div>
    <ToastHost />
</div>

@code {
    private string adminName = "admin";
    private bool isProd;
    private string dbPath = "";
    private string dbLabel = "";

    protected override async Task OnInitializedAsync()
    {
        isProd = HostEnv.IsProduction();
        // Même résolution que Program.cs : ADN_DB_PATH sinon la base à côté du binaire.
        dbPath = Environment.GetEnvironmentVariable("ADN_DB_PATH")
            ?? System.IO.Path.Combine(AppContext.BaseDirectory, "AdnPayData.db");
        // Deux derniers segments pour distinguer « ADN_pay\… » (dev) de « publish\… » (prod).
        var parts = dbPath.Replace('/', '\\').Split('\\', StringSplitOptions.RemoveEmptyEntries);
        dbLabel = parts.Length >= 2 ? string.Join("\\", parts[^2..]) : dbPath;

        var state = await AuthProvider.GetAuthenticationStateAsync();
        var user = state.User;
        if (user.Identity?.IsAuthenticated != true) return;

        adminName = $"{user.FindFirst(ClaimTypes.GivenName)?.Value} {user.FindFirst(ClaimTypes.Surname)?.Value}".Trim();
        if (string.IsNullOrWhiteSpace(adminName)) adminName = user.Identity!.Name ?? "admin";

        // Peuple le UserContext (identité de l'admin) pour que AdminService journalise
        // correctement les actions — équivalent du UserContextMiddleware de l'API.
        if (!UserCtx.EstConnecte
            && int.TryParse(user.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var uid))
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var profil = await db.UserProfiles.FindAsync(uid);
            if (profil != null) { UserCtx.Profil = profil; UserCtx.EstConnecte = true; }
        }
    }
}
